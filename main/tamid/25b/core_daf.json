  "tosafot": [
    {
      "source_ref": "Mefaresh on Tamid 25b: 1",
      "gemara_segment_ids": [
        0
      ],
      "text": "מתני' בשלשה מקומות - משום דבעי לאורויי במעשה",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 1",
      "gemara_segment_ids": [
        0
      ],
      "text": "דתמיד עבודת כהנים נקט תחלה שמירתן ומקום",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 1",
      "gemara_segment_ids": [
        0
      ],
      "text": "שכיבתן עד שהוא מסדר כל הסדר שבתחלה טובלין",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 1",
      "gemara_segment_ids": [
        0
      ],
      "text": "וכו' כאשר הוא מסודר במשנה ובגמ' נפקא לן מקרא",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 1",
      "gemara_segment_ids": [
        0
      ],
      "text": "דבית המקדש צריך שימור דאי לא נפקא לן מקרא",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 1",
      "gemara_segment_ids": [
        0
      ],
      "text": "הוה אמינא דלא צריכי שומרים דאין עניות במקום",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 1",
      "gemara_segment_ids": [
        0
      ],
      "text": "עשירות ואי גנבי כלי המקדש קנו אחרים ועוד",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 1",
      "gemara_segment_ids": [
        0
      ],
      "text": "דהוה אמינא דבחד שומר סגי ומקום שמירתן היא",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 1",
      "gemara_segment_ids": [
        0
      ],
      "text": "בבית אבטינס ובבית הניצוץ ובבית המוקד:",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "הכי גרסינן בבית אבטינס ובבית הניצוץ היו",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "עליות - בית אבטינס היא לשכת מפטמי הקטורת",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "כדתנן בפ\"ק דיומא (דף יח:) הוליכוהו לעליית",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "בית אבטינס גבי כהן גדול ללמדו לשם הלכות",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "חפינה שהיא אחת מעבודות קשות שבמקדש כדמפרש",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "ביומא (דף מט:) ולפי שהיו אומנין על מעשה",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "הקטרת נקראת על שמם ומספקא לן ביומא במקום",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "עליית בית אבטינס היכן היא דאמרינן בפ\"ק דיומא",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "(דף יט.) שתי לשכות היו לכהן גדול לשכת",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "פרהדרין ולשכת בית אבטינס אחת בצפון ואחת",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "בדרום ולא ידענא אי לשכת פרהדרין בצפון ולשכת",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "בית אבטינס בדרום או לשכת בית אבטינס בצפון",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "ולשכת פרהדרין בדרום ושם היה כהן גדול ישן",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 2",
      "gemara_segment_ids": [
        0
      ],
      "text": "וביומא (דף ח:) מפרש למה נקרא כן:",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 3",
      "gemara_segment_ids": [
        0
      ],
      "text": "בית הניצוץ - לא שמעתי בו טעם למה נקרא כן:",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "היו עליות - לשמירת כהנים צריך עליות מקום",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "גבוה כדנפקא לן בגמרא וילוו עליך וישרתוך",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "וגזירת הכתוב היא ושמירת לוים לא היתה אלא",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "למטה אצל השערים ולכך קרי ליה הפסוק ללוים",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "שוערים במקרא לפי שלא היתה שמירתן אלא אצל",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "השער והכהנים היו שומרין אותו בעליות על מקום",
      "left": "0px",
      "right": "",
      "width": "185px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "גבוה כדרך שומרי עיר וכל שומרי עיר בין ביום",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "בין בלילה לא היו ישנים. ועשרים וארבעה שומרים",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "בעשרים וארבעה מקומות נפקא לן בגמ' שצריך לבית",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "המקדש שהיו שומרים יום ולילה שלשה בכהנים",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "ועשרים ואחד בלוים ואפילו היו אותן עליות",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "בנויות מקצתן בעזרה יכולים כהנים לישב שם",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "כשהיו עייפים דגגין ועליות לא נתקדשו כדאמרינן",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "בפסחים (דף פה:) ובעזרה אין אדם יכול לישב",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 4",
      "gemara_segment_ids": [
        0
      ],
      "text": "דאין ישיבה בעזרה אלא למלכי בית דוד:",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 5",
      "gemara_segment_ids": [
        0
      ],
      "text": "והרובין שומרין שם - רובין קרי כהנים שלא",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 5",
      "gemara_segment_ids": [
        0
      ],
      "text": "הגיעו עדיין לעשות עבודה כגון פחותים מי\"ג שנה",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 5",
      "gemara_segment_ids": [
        0
      ],
      "text": "כמו (שמואל א ב) ויגדל הנער [ומתרגמינן] ורבא",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 5",
      "gemara_segment_ids": [
        0
      ],
      "text": "רביא ולפי שעדיין לא הגיעו לעשות עבודה (אין",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 5",
      "gemara_segment_ids": [
        0
      ],
      "text": "יכולין לעשותה) עבדינן להו שומרים שאותן",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 5",
      "gemara_segment_ids": [
        0
      ],
      "text": "שיכולין לעבוד אינן רוצין לשמור ועוד הואיל",
      "left": "0px",
      "right": "",
      "width": "930px"
    },
    {
      "source_ref": "Mefaresh on Tamid 25b: 5",
      "gemara_segment_ids": [
        0
      ],
      "text": "ויכולין לעבוד אין אנו מניחין אותן לשמור:",
      "left": "0px",
      "right": "",
      "width": "930px"
    }
  ]
}