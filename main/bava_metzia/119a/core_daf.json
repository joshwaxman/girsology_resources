  ],
  "tosafot": [
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "<big><b><span class=\"dh-divergent\">ותניא</span> <span class=\"dh-divergent\">נמי</span> <span class=\"dh-divergent\">גבי</span> <span class=\"dh-divergent\">מקח</span> <span class=\"dh-divergent\">וממכר</span> <span class=\"dh-divergent\">כה&quot;ג</span> <span class=\"dh-divergent\">(שייך</span> <span class=\"dh-divergent\">לעמוד</span> <span class=\"dh-divergent\">ב,</span> <span class=\"dh-divergent\">לפי</span> <span class=\"dh-divergent\">גירסת</span> <span class=\"dh-divergent\">מהרש&quot;ל)</span>.</b></big> תניא גרסינן דאינה משנה",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "390px",
      "right": "",
      "left": "0px",
      "text": "בשום מקום ולא הוי כה\"ג ממש דאפילו אמר ר\"י היוצא",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "מן הגזע של בעל הקרקע לא יקשה כלום שהרי עומד באוירו של בעל",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "הקרקע וגם יונק מן הקרקע ועוד שלא היה בדעת המוכר למכור אלא",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "זה האילן שהיה בעת (הגהת הרש\"ש) שמכר אבל לא",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אילן חדש שעתיד לצאת מן הגזע דלא",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "חשיב כאילן עצמו כהענפים (הגהת הרש\"ש) המתחדשים",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אלא נחשב כאילן אחר וכן ר' מאיר",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אם היה אומר כאן של בעל האילן",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לא היה קשה על משנתנו שכמו",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שהענפים המתחדשים בכל שנה הם",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "של בעל האילן ה\"נ היוצא מן הגזע",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "יהיו שלו והא דקאמר כה\"ג היינו",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שמיפה ר\"מ כאן כחו של בעל הקרקע",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "טפי מרבי יהודה כמו במתני' ולהכי",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לא עביד צריכותא בסמוך אלא אערלה",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ואמקח וממכר ולא אמתניתין",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<big><b>שבור מלכא</b></big>. נראה לפרש כפי'",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "200px",
      "right": "",
      "left": "0px",
      "text": "הקונטרס דשבור מלכא",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "היה בקי בהלכות כדאמרינן בסוף",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מסכת ע\"ז (<a href=\"/avodah_zarah/76b\">דף עו:</a>) שנעץ הסכין עשר",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "פעמים בקרקע קשה כשחתך האתרוג",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בסכין לרב יהודה",
      "source_ref": "Tosafot on Bava Metzia 119a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
