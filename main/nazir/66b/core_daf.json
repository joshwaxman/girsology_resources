      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אמרינן ליה חטוף ובריך:",
      "source_ref": "Tosafot on Nazir 66b:3:1",
      "gemara_segment_ids": [
        1
      ]
    }
  ]
