  "tosafot": [
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "<big><b><span class=\"dh-divergent\">היו</span> <span class=\"dh-divergent\">מסרבים</span> <span class=\"dh-divergent\">בו</span> <span class=\"dh-divergent\">לאכול</span> <span class=\"dh-divergent\">ואמר</span> <span class=\"dh-divergent\">אכילנא</span> <span class=\"dh-divergent\">אכילנא</span> <span class=\"dh-divergent\">ותו</span> <span class=\"dh-divergent\">אמר</span> ״שְׁבוּעָה <span class=\"dh-divergent\">שאוכל</span> <span class=\"dh-divergent\">דאכילנא</span> <span class=\"dh-divergent\">משמע</span> <span class=\"dh-divergent\">וכו</span>.</b></big> ר\"ן ד\"ה היו מסרבים",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "360px",
      "right": "90px",
      "left": "",
      "text": "בו לאכול ואמר אכילנא אכילנא ותו אמר שבועה שאוכל",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "דאכילנא משמע וכו' לפום האי לישנא משמע דכי היכי דצריך",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "הוכחה לומר דשאוכל דלא אכילנא משמע ה\"נ צריך הוכחה דשאוכל",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אכילנא משמע ובריש פרק שבועות",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שתים בתרא באוקמתיה דאביי גופיה",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לא משמע הכי אלא דסתמא בלא",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שום הוכחה שאוכל דאכילנא משמע",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "וכבר כתבתי שם שזו מן הסוגיות",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "המתחלפות וכתבתי שם גם כן",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דסוגיא דהתם עדיפא טפי.",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<big><b>על סיפא דאידך קתני",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לה שבועה",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שאיני",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ישן שאיני מדבר",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "שאיני מהלך אסור</b></big>.",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "ר\"ן ד\"ה על סיפא דאידך קתני לה שבועה שאיני ישן",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "שאיני מדבר שאיני מהלך אסור ובהא שייך למימר חומר בשבועות",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "מבנדרים דנדרא מיהא הוי מדרבנן וכרבינא דאוקמא לעיל בבל",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "יחל מדרבנן אלא דשבועה חמורה מנדר דאסור מדאורייתא ונקיט",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "לה הש\"ס להאי פרוקא אליבא דרבינא משום דקושטא דמילתא כוותיה",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "היא דבל יחל דמתני' דרבנן קאמר והאי דלא דייקינן נמי גבי חומר",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "בנדרים מבשבועות מכלל דשבועה מיהא איתא משום דאין הכי נמי",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "דאיתא ולקי בה משום שבועת שוא אלא שאינה חלה לבטל את המצוה.",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "<big><b>הא דאמר הנאת סוכה עלי הא",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "דאמר שבועה שלא",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "אהנה מסוכה</b></big>.",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "ר\"ן ד\"ה הא דאמר הנאת סוכה עלי הא דאמר",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "שבועה שלא אהנה מסוכה כלומר סברא הוא דלה' לא קאי אשבועה",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "אלא אכי ידור נדר משום דנדר בדין הוא שיחול על דבר מצוה לפי",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "שהוא אוסר על עצמו הנאת סוכה שלשון נדר כך הוא ואין מאכילין",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "את האדם דבר האסור לו אבל לשון שבועה היינו שלא אשב בסוכה",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "ולא כל הימנו להפקיע עצמו ממצות סוכה שהוא מצווה בה. <big><b>אלא אמר",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "רבא הא דאמר",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "ישיבת סוכה עלי הא דאמר",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "שלא אשב בסוכה</b></big>. ר\"ן ד\"ה אלא אמר רבא הא דאמר ישיבת",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "סוכה עלי הא דאמר שלא אשב בסוכה וא\"ת וכי אמר ישיבת סוכה",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "עלי מאי הוי הא דבר שאין בו ממש הוא י\"ל דהכא במאי עסקינן",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "כגון דאמר קונם סוכה לישיבתה עלי ורבא לא חש לתרוצי אלא לשון הנאה דאמר אביי אבל אין ה\"נ דבאומר סוכה לישיבתה עסקינן",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "אבל בתוספות אמרו שאפילו אמר קונם ישיבת סוכה עלי מהני דלא מקרי דבר שאין בו ממש אלא בשאינו מזכיר שם החפץ שאוסר עליו",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "כגון שאני ישן שאני מדבר אבל כשמזכיר החפץ הנאסר דבר שיש בו ממש הוא ולפי זה מאי דאמרינן בפרק אע\"פ (<a href=\"/ketubot/58b\">כתובות דף נח:</a>) ובפרק",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "בתרא דמכילתין /נדרים/ (<a href=\"/nedarim/85b\">דף פה:</a>) גבי מקדיש מעשה ידי אשתו דמוקמינן באומר יקדשו ידי לעושיהן לאו דוקא באומר אלא נעשה כאומר קאמר",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "כיון שהזכיר את הידים וא\"ת ואפילו כי אמר ישיבת סוכה עלי למה אסור בישיבה של מצוה והא כיון דמצות לאו ליהנות נתנו הרי אינו נהנה מן",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "הסוכה כלל תירצו בתוספות דמ\"מ כיון שאסר ישיבתה עליו אע\"פ שאין לו בו הנאה חל ולפי זה אמר קונם זריקת צרור לים עליו אסור אע\"פ",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "שאין לו בזריקתו הנאה אסור לזורקו מיהו דוקא במפרש ישיבת סוכה או זריקת צרור אבל באומר קונם סוכה עלי קונם צרור זה עלי יושב",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "ישיבה של מצוה וזורק אותו צרור שנאסר בו לים אם רצה דמסתמא לא אסר על עצמו אלא הנאה בלבד דהא מקדיש בהמתו אסרה עליו ועל",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "כל העולם ואפ\"ה אינה אסורה בנגיעה הכא נמי איסור סתם אכילה והנאה משמע אבל כל שפירש לאסור על עצמו אפילו נגיעה חייל.",
      "source_ref": "Tosafot on Nedarim 16b:6:1",
      "gemara_segment_ids": [
        4
      ]
    }
  ]
}