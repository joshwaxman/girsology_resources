    },
    {
      "width": "930px",
      "right": "",
      "left": "0px",
      "text": "<big><b>גמ'",
      "source_ref": "Tosafot on Nedarim 33a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "0px",
      "text": "אלמא אברוחי",
      "source_ref": "Tosafot on Nedarim 33a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "930px",
