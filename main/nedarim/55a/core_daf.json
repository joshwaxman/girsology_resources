    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<a class=\"piska-quote-link\" data-piska-quote-group=\"piska-quote-184\" href=\"/nedarim/55a#gemara-line-1\" title=\"Mishnah source: Nedarim 55a\">אֲבָל הַנּוֹדֵר מִן הַדָּגָן — אָסוּר בַּכֹּל, וּמוּתָּר</a>",
      "segment_ids": [
        0
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<a class=\"piska-quote-link\" data-piska-quote-group=\"piska-quote-184\" href=\"/nedarim/55a#gemara-line-1\" title=\"Mishnah source: Nedarim 55a\">בְּפֵירוֹת הָאִילָן וּבַיָּרָק</a><span class=\"sugya-marker sugya-marker-vilna-piska\" data-sugya-kind=\"vilna-piska\" data-sugya-id=\"184\" data-raw-symbol=\"׃\">׃</span> <span class=\"sugya-marker sugya-marker-steinsaltz\" data-sugya-kind=\"steinsaltz\" data-sugya-id=\"184\" data-sentence-id=\"1\" data-steinsaltz-label=\"ב גמרא\">§</span> <span class=\"sentence\" id=\"1\" type=\"start\">&star;</span><big><strong>גְּמָ׳</strong></big> לְמֵימְרָא דְּ״דָגָן״ —",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "כֹּל דְּמִידְּגַן מַשְׁמַע. מֵתִיב <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yosef I, third-generation Amora\" data-authority-id=\"1764\" data-full-name=\"Rav Yosef I\" data-name-he=\"רב יוסף בר חייא\">רַב יוֹסֵף</span>: ״וְכִפְרֹץ",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הַדָּבָר הִרְבּוּ בְנֵי יִשְׂרָאֵל [רֵאשִׁית] דָּגָן תִּירוֹשׁ",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וְיִצְהָר וְכֹל תְּבוּאַת שָׂדֶה <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"of Rav, first-generation Amora\" data-authority-id=\"2578\" data-full-name=\"of Rav\" data-name-he=\"רב\">לָרֹב</span> וְגוֹ׳״, וְאִי",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אָמְרַתְּ דָּגָן — כֹּל דְּמִידְּגַן מַשְׁמַע, מַאי ״כִּפְרֹץ",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הַדָּבָר הִרְבּוּ״? אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Abaye, fourth-generation Amora\" data-authority-id=\"121\" data-full-name=\"Abaye\" data-name-he=\"אביי\">אַבָּיֵי</span>: לְאֵתוֹיֵי פֵּירוֹת הָאִילָן וְיָרָק.",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sugya-marker sugya-marker-vilna-piska\" data-sugya-kind=\"vilna-piska\" data-sugya-id=\"185\" data-raw-symbol=\"׃\">׃</span> <span class=\"sugya-marker sugya-marker-steinsaltz\" data-sugya-kind=\"steinsaltz\" data-sugya-id=\"185\" data-sentence-id=\"2\" data-steinsaltz-label=\"ג\">§</span> <span class=\"sentence\" id=\"2\" type=\"start\">&star;</span><a class=\"piska-quote-link\" data-piska-quote-group=\"piska-quote-186\" href=\"/nedarim/55a#gemara-line-3\" title=\"Mishnah source: Nedarim 55a\"><span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Meir, fifth-generation Tanna\" data-authority-id=\"2068\" data-full-name=\"Rabbi Meir\" data-name-he=\"רבי מאיר\">רַבִּי מֵאִיר</span> אוֹמֵר: הַנּוֹדֵר מִן הַתְּבוּאָה</a>",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<a class=\"piska-quote-link\" data-piska-quote-group=\"piska-quote-186\" href=\"/nedarim/55a#gemara-line-3\" title=\"Mishnah source: Nedarim 55a\">וְכוּ׳</a><span class=\"sugya-marker sugya-marker-vilna-piska\" data-sugya-kind=\"vilna-piska\" data-sugya-id=\"186\" data-raw-symbol=\"׃\">׃</span> אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabbi Yoḥanan II, second-generation Amora\" data-authority-id=\"1570\" data-full-name=\"Rabbi Yoḥanan II\" data-name-he=\"רבי יוחנן\">רַבִּי יוֹחָנָן</span>: הַכֹּל מוֹדִים בְּנוֹדֵר מִן",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הַתְּבוּאָה שֶׁאֵין אָסוּר אֶלָּא מֵחֲמֵשֶׁת הַמִּינִין.",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "תַּנְיָא נָמֵי הָכִי: שָׁוִין בַּנּוֹדֵר מִן הַתְּבוּאָה",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שֶׁאֵין אָסוּר אֶלָּא מֵחֲמֵשֶׁת הַמִּינִין. פְּשִׁיטָא! מַהוּ",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דְּתֵימָא: ״תְּבוּאָה״ — כׇּל מִלֵּי מַשְׁמַע, קָמַשְׁמַע לַן",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דְּלָא מַשְׁמַע כׇּל מִלִּי. <span class=\"sentence\" id=\"3\" type=\"start\">&star;</span>מֵתִיב <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yosef I, third-generation Amora\" data-authority-id=\"1764\" data-full-name=\"Rav Yosef I\" data-name-he=\"רב יוסף בר חייא\">רַב יוֹסֵף</span>: ״וְכִפְרֹץ",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הַדָּבָר הִרְבּוּ בְנֵי יִשְׂרָאֵל כּוּ׳״, אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabba I, fourth-generation Amora\" data-authority-id=\"2582\" data-full-name=\"Rabba I\" data-name-he=\"רבא\">רָבָא</span>: ״תְּבוּאָה״",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לְחוּד, ״תְּבוּאַת שָׂדֶה״ לְחוּד. <span class=\"sugya-marker sugya-marker-steinsaltz\" data-sugya-kind=\"steinsaltz\" data-sugya-id=\"186\" data-sentence-id=\"4\" data-steinsaltz-label=\"ד\">§</span> <span class=\"sentence\" id=\"4\" type=\"start\">&star;</span><span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"of Master Shmuel, fifth-generation Amora\" data-authority-id=\"2761\" data-full-name=\"of Master Shmuel\" data-name-he=\"מר שמואל\">בַּר מָר שְׁמוּאֵל</span>",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "פַּקֵּיד דְּלִיתְּנוּן תְּלֵיסַר אַלְפֵי זוּזִי <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabba I, fourth-generation Amora\" data-authority-id=\"2582\" data-full-name=\"Rabba I\" data-name-he=\"רבא\">לְרָבָא</span> מִן",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "עֲלַלְתָּא דִּנְהַר פַּנְיָא. שַׁלְחַהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabba I, fourth-generation Amora\" data-authority-id=\"2582\" data-full-name=\"Rabba I\" data-name-he=\"רבא\">רָבָא</span> לְקַמֵּיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yosef I, third-generation Amora\" data-authority-id=\"1764\" data-full-name=\"Rav Yosef I\" data-name-he=\"רב יוסף בר חייא\" data-crossline-group=\"name-ref-crossline-53382\">דְּרַב</span>",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yosef I, third-generation Amora\" data-authority-id=\"1764\" data-full-name=\"Rav Yosef I\" data-name-he=\"רב יוסף בר חייא\" data-crossline-group=\"name-ref-crossline-53382\">יוֹסֵף</span>: ״עֲלַלְתָּא״ הֵיכִי מִיקַּרְיָא? אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yosef I, third-generation Amora\" data-authority-id=\"1764\" data-full-name=\"Rav Yosef I\" data-name-he=\"רב יוסף בר חייא\">רַב יוֹסֵף</span>,",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מַתְנִיתִין הִיא: וְשָׁוִין בַּנּוֹדֵר מִן הַתְּבוּאָה",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שֶׁאֵין אָסוּר אֶלָּא מֵחֲמֵשֶׁת הַמִּינִין. אֲמַר לֵיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Abaye, fourth-generation Amora\" data-authority-id=\"121\" data-full-name=\"Abaye\" data-name-he=\"אביי\">אַבָּיֵי</span>:",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "מִי דָּמֵי? ״תְּבוּאָה״ — לָא מַשְׁמַע אֶלָּא מֵחֲמֵשֶׁת הַמִּינִין, ״עֲלַלְתָּא״ — כׇּל מִילֵּי מַשְׁמַע.",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "<span class=\"sentence\" id=\"5\" type=\"start\">&star;</span>אַהְדְּרוּהוּ לְקַמֵּיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabba I, fourth-generation Amora\" data-authority-id=\"2582\" data-full-name=\"Rabba I\" data-name-he=\"רבא\">דְּרָבָא</span>. אֲמַר: הָא לָא קָא מִיבַּעְיָא לִי דַּ״עֲלַלְתָּא״ כׇּל מִילֵּי",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "מַשְׁמַע. הָדָא הוּא דְּאִיבַּעְיָא לִי: שְׂכַר בָּתִּים וּשְׂכַר סְפִינוֹת מַאי? מִי אָמְרִינַן:",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "כֵּיוָן דְּפָחֲתָן, לָאו עֲלַלְתָּא הִיא. אוֹ דִילְמָא: כֵּיוָן דְּלָא יְדִיעַ פְּחָתַיְיהוּ — עֲלַלְתָּא",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "הִיא. אַמְרוּהָ רַבָּנַן קַמֵּיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yosef I, third-generation Amora\" data-authority-id=\"1764\" data-full-name=\"Rav Yosef I\" data-name-he=\"רב יוסף בר חייא\">דְּרַב יוֹסֵף</span>, אָמַר: וְכִי מֵאַחַר דְּלָא צְרִיךְ לַן, אַמַּאי שְׁלַח",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "לַן? אִיקְּפַד <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yosef I, third-generation Amora\" data-authority-id=\"1764\" data-full-name=\"Rav Yosef I\" data-name-he=\"רב יוסף בר חייא\">רַב יוֹסֵף</span>. <span class=\"sentence\" id=\"6\" type=\"start\">&star;</span>שְׁמַע <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabba I, fourth-generation Amora\" data-authority-id=\"2582\" data-full-name=\"Rabba I\" data-name-he=\"רבא\">רָבָא</span>, וַאֲתָא לְקַמֵּיהּ בְּמַעֲלֵי יוֹמָא דְכִפּוּרֵי. אַשְׁכְּחֵיהּ",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Ashmedai I, first-generation Tanna\" data-authority-id=\"2924\" data-full-name=\"Ashmedai I\" data-name-he=\"שמעיה\">לְשַׁמָּעֵיהּ</span> דַּהֲוָה קָא מָזֵיג קַמֵּיהּ כָּסָא דְחַמְרָא. אֲמַר לֵיהּ: הַב לִי דְּאֶמְזִיג לֵיהּ",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "אֲנָא. יְהַב לֵיהּ, וְקָא מָזֵיג אִיהוּ כָּסָא דְחַמְרָא. כִּי קָא שָׁתֵי אֲמַר: הָדֵין מִיזְגָּא",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "דָּמֵי לְמִיזְגָּא <span class=\"name-reference-marker name-reference-unknown\" data-sage-type=\"unknown\" title=\"Rav Yosef. Rav Yosef\" data-authority-id=\"21357\" data-full-name=\"Rav Yosef. Rav Yosef\" data-name-he=\"רבא בריה דרב יוסף\">דְּרָבָא בְּרֵיהּ דְּרַב יוֹסֵף</span> <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"bar Chama, fourth-generation Amora\" data-authority-id=\"733\" data-full-name=\"bar Chama\" data-name-he=\"בר חמא\">בַּר חָמָא</span>. אֲמַר לֵיהּ: הוּא נִיהוּ. <span class=\"sentence\" id=\"7\" type=\"start\">&star;</span>אֲמַר לֵיהּ:",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "לָא תִּיתֵּיב אַכַּרְעָךְ עַד דְּאָמְרַתְּ לִי פֵּירוּשָׁא דְּהָדֵין מִילְּתָא: מַאי דִּכְתִיב:",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "״וּמִמִּדְבָּר מַתָּנָה וּמִמַּתָּנָה נַחֲלִיאֵל וּמִנַּחֲלִיאֵל בָּמוֹת״? <span class=\"sentence\" id=\"8\" type=\"start\">&star;</span>אֲמַר לֵיהּ: כֵּיוָן שֶׁעוֹשֶׂה",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "אָדָם אֶת עַצְמוֹ כַּמִּדְבָּר, שֶׁהוּא מוּפְקָר לַכֹּל — תּוֹרָה נִיתְּנָה לוֹ בְּמַתָּנָה, שֶׁנֶּאֱמַר:",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "״וּמִמִּדְבָּר מַתָּנָה״. וְכֵיוָן שֶׁנִּיתְּנָה לוֹ בְּמַתָּנָה — נְחָלוֹ אֵל, שֶׁנֶּאֱמַר: ״וּמִמַּתָּנָה נַחֲלִיאֵל״.",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "וְכֵיוָן שֶׁנְּחָלוֹ אֵל — עוֹלֶה לִגְדוּלָּה, שֶׁנֶּאֱמַר: ״וּמִנַּחֲלִיאֵל בָּמוֹת״. וְאִם הִגְבִּיהַּ עַצְמוֹ —",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "הַקָּדוֹשׁ בָּרוּךְ הוּא מַשְׁפִּילוֹ, שֶׁנֶּאֱמַר: ״וּמִבָּמוֹת הַגַּיְא״, וְלֹא עוֹד אֶלָּא שֶׁשּׁוֹקְעִין אוֹתוֹ",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "בַּקַּרְקַע, שֶׁנֶּאֱמַר: ״וְנִשְׁקָפָה עַל פְּנֵי הַיְשִׁימוֹן״. וְאִם חוֹזֵר בּוֹ — הַקָּדוֹשׁ בָּרוּךְ הוּא מַגְבִּיהוֹ",
      "segment_ids": [
        8
      ]
    }
  ],
  "rashi": [
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "<b><span class=\"dh-divergent\">מתני&#x27;</span> <span class=\"dh-divergent\">אלא</span> <span class=\"dh-divergent\">מחמשת</span> <span class=\"dh-divergent\">מינין</span></b> חטה ושעורה וכוסמין ושיפון ושבולת",
      "source_ref": "Rashi on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "שועל: <b><span class=\"dh-divergent\">רבי</span> <span class=\"dh-divergent\">מאיר</span> <span class=\"dh-divergent\">אומר</span> <span class=\"dh-divergent\">בו&#x27;</span>.</b> בהא ודאי מודינא לך",
      "source_ref": "Rashi on Nedarim 55a:1:2",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "שהנודר מן התבואה אינו אסור אלא מחמשת מינין אבל הנודר מן",
      "source_ref": "Rashi on Nedarim 55a:1:2",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "הדגן אסור בכל מין דמידגן משמע דבר שעושין ממנו כר",
      "source_ref": "Rashi on Nedarim 55a:1:2",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ופול המצרי יבש עושין ממנו כרי",
      "source_ref": "Rashi on Nedarim 55a:1:2",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ולהכי אסור: <b>גְּמָ׳ לְמֵימְרָא דְּ״דָגָן״.</b>",
      "source_ref": "Rashi on Nedarim 55a:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דכתיב בקרא כל מין דמידגן משמע",
      "source_ref": "Rashi on Nedarim 55a:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "וחייב במעשר מן התורה ואפי' משאר",
      "source_ref": "Rashi on Nedarim 55a:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מינין מדקתני הנודר מן הדגן אסור",
      "source_ref": "Rashi on Nedarim 55a:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בכל: <b><span class=\"dh-divergent\">וכפרוץ</span> הַדָּבָר.</b> כלומר קיבלו",
      "source_ref": "Rashi on Nedarim 55a:2:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "עליהם תקנתא של חזקיהו לעשר הכל",
      "source_ref": "Rashi on Nedarim 55a:2:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כדכתיב הרבו בני ישראל וגו' אי",
      "source_ref": "Rashi on Nedarim 55a:2:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אמרת בשלמא דדגן לא משמע אלא",
      "source_ref": "Rashi on Nedarim 55a:2:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מחמשת מינין היינו דאתא קרא",
      "source_ref": "Rashi on Nedarim 55a:2:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "למימר הרבו בני ישראל דאפי' דבר",
      "source_ref": "Rashi on Nedarim 55a:2:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שלא נתחייב במעשר מן התורה כגון",
      "source_ref": "Rashi on Nedarim 55a:2:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שאר מיני דמידגני היו מעשרים כדי",
      "source_ref": "Rashi on Nedarim 55a:2:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "להחזיק בתקנה אלא אי אמרת דגן",
      "source_ref": "Rashi on Nedarim 55a:2:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כל מיני דמידגן משמע מאי וכפרוץ",
      "source_ref": "Rashi on Nedarim 55a:2:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הדבר הרבו כלומר מה הוסיפו על",
      "source_ref": "Rashi on Nedarim 55a:2:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מה שכתוב בתורה: <b>אֲמַר: <span class=\"dh-divergent\">אביי</span>.</b>",
      "source_ref": "Rashi on Nedarim 55a:2:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כל דמידגן משמע ומאי וכפרוץ הדבר",
      "source_ref": "Rashi on Nedarim 55a:2:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הרבו לאיתויי פירות האילן וירק",
      "source_ref": "Rashi on Nedarim 55a:2:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דהרבו בו בני ישראל ליתן מהן",
      "source_ref": "Rashi on Nedarim 55a:2:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מעשר דמדאורייתא לא מחייב במעשר",
      "source_ref": "Rashi on Nedarim 55a:2:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אלא מידי דמידגן דלא משמע אלא",
      "source_ref": "Rashi on Nedarim 55a:2:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מחמשת מינין: <b><span class=\"dh-divergent\">ותבואת</span> <span class=\"dh-divergent\">השדה</span> <span class=\"dh-divergent\">לרוב</span>.</b>",
      "source_ref": "Rashi on Nedarim 55a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אלמא דתבואה משמע כל מילי דהא",
      "source_ref": "Rashi on Nedarim 55a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דכתיב ותבואת השדה לאו מחמשת",
      "source_ref": "Rashi on Nedarim 55a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מינין דאיקרו תבואה: תבואה",
      "source_ref": "Rashi on Nedarim 55a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "סתם לא משמע אלא מחמשת מינין",
      "source_ref": "Rashi on Nedarim 55a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "תבואת השדה משמע כל מידי הגדל",
      "source_ref": "Rashi on Nedarim 55a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מן השדה: <b>פַּקֵּיד</b> צוה בצוואתו:",
      "source_ref": "Rashi on Nedarim 55a:5:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>הֵיכִי מִיקַּרְיָא</b> כלומר ממה אגבה",
      "source_ref": "Rashi on Nedarim 55a:5:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אותו ממון: <b>אֶלָּא מֵחֲמֵשֶׁת <span class=\"dh-divergent\">מינין</span>.</b>",
      "source_ref": "Rashi on Nedarim 55a:5:3",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ואינו גובה אלא מחמשת מינין:",
      "source_ref": "Rashi on Nedarim 55a:5:3",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>עֲלַלְתָּא.</b> משמע כל מילי שעולה",
      "source_ref": "Rashi on Nedarim 55a:5:4",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ומשבח ואפי' משאר פירות שמשבחין",
      "source_ref": "Rashi on Nedarim 55a:5:4",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "צוה לגבות מהן: <b><span class=\"dh-divergent\">אהדרוה</span> לְקַמֵּיהּ</b>",
      "source_ref": "Rashi on Nedarim 55a:6:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>דְּרָבָא</b> לאותה תשובה: <b>שכר</b> <b>בתים</b>",
      "source_ref": "Rashi on Nedarim 55a:6:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>וּשְׂכַר סְפִינוֹת</b> גובה מהן או לא: <b>מי</b>",
      "source_ref": "Rashi on Nedarim 55a:6:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>אָמְרִינַן: כֵּיוָן דְּפָחֲתָן</b> שמתחסרין כל",
      "source_ref": "Rashi on Nedarim 55a:6:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "זמן שמתיישנין: <b>לָאו עֲלַלְתָּא.</b> מיקרו",
      "source_ref": "Rashi on Nedarim 55a:6:4",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שאין עולה ומשביח ולא גבי מינייהו:",
      "source_ref": "Rashi on Nedarim 55a:6:4",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>אוֹ דִילְמָא: כֵּיוָן דְּלָא יְדִיעַ פְּחָתַיְיהוּ.</b>",
      "source_ref": "Rashi on Nedarim 55a:6:5",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שעל יד על יד מתחסר ואינו ניכר",
      "source_ref": "Rashi on Nedarim 55a:6:5",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "פחיתותו להדיא והואיל ונוטל הימנו",
      "source_ref": "Rashi on Nedarim 55a:6:5",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שכר עולה ומשביח הוי ויהבו ליה",
      "source_ref": "Rashi on Nedarim 55a:6:5",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מההוא אגרא: <b>אַמְרוּהָ קַמֵּיהּ דְּרַב</b>",
      "source_ref": "Rashi on Nedarim 55a:6:6",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>יוֹסֵף.</b> הא דאמר רבא דהא לא",
      "source_ref": "Rashi on Nedarim 55a:6:6",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מיבעיא ליה דעללתא כל מידי משמע:",
      "source_ref": "Rashi on Nedarim 55a:6:6",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>דָּמֵי <span class=\"dh-divergent\">למזיגא</span> דְּרָבָא.</b> שכשהיה רבא",
      "source_ref": "Rashi on Nedarim 55a:7:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לומד לפניו היה מוזג לו בענין זה:",
      "source_ref": "Rashi on Nedarim 55a:7:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "<b>לָא תִּיתֵּיב אַכַּרְעָךְ <span class=\"dh-divergent\">כו&#x27;</span></b> לפי שהגיס לבו שאל לו מקרא זה כדי להשפיל דעתו: <b>כמדבר</b> <b>שהוא</b> <b>מופקר</b> <b>לכל.</b>",
      "source_ref": "Rashi on Nedarim 55a:8:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "מלמד תורה בחנם לכל: <b>נַחֲלִיאֵל.</b> נעשית לו התורה כמו נחלה: <b>ששוקעין</b> <b>אותו</b> <b>בארץ.</b> כמו המשקוף:",
      "source_ref": "Rashi on Nedarim 55a:9:2",
      "gemara_segment_ids": [
        7
      ]
    }
  ],
  "vilna_piskaot": [
    {
      "id": 184,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 6,
      "mishnah_ref": "Nedarim 55a",
      "mishnah_href": "/nedarim/55a#gemara-line-1",
      "mishnah_line_number": 1,
      "quote_text": "מַתְנִי׳ הַנּוֹדֵר מִן הַדָּגָן — אָסוּר בְּפוֹל הַמִּצְרִי יָבֵשׁ, דִּבְרֵי רַבִּי מֵאִיר. וַחֲכָמִים אוֹמְרִים: אֵינוֹ אָסוּר אֶלָּא בַּחֲמֵשֶׁת הַמִּינִין. רַבִּי מֵאִיר אוֹמֵר: הַנּוֹדֵר מִן הַתְּבוּאָה — אֵינוֹ אָסוּר אֶלָּא מֵחֲמֵשֶׁת הַמִּינִין. אֲבָל הַנּוֹדֵר מִן הַדָּגָן — אָסוּר בַּכֹּל, וּמוּתָּר בְּפֵירוֹת הָאִילָן וּבַיָּרָק"
    },
    {
      "id": 185,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 12
    },
    {
      "id": 186,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 13,
      "mishnah_ref": "Nedarim 55a",
      "mishnah_href": "/nedarim/55a#gemara-line-3",
      "mishnah_line_number": 3,
      "quote_text": "רַבִּי מֵאִיר אוֹמֵר: הַנּוֹדֵר מִן הַתְּבוּאָה וְכוּ׳"
    }
  ],
