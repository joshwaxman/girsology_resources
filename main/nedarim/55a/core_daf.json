  "tosafot": [
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "<big><b>מַתְנִיתִין.</b></big> ר\"ן ד\"ה תוספתא (ד:ג) הנודר מן התירוש אסור בכל מיני מתיקה ומותר",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "390px",
      "right": "",
      "left": "0px",
      "text": "ביין וגרסינן עלה בירושלמי כמאן דאמר הלכו בנדרים אחר לשון בני",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "אדם כלומר שדרכן לקרות תירוש לדברים המתוקים ולא",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "ליין ברם כמאן דאמר לא",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "הלכו בנדרים אחר לשון בני אדם",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "התורה קראה אותו תירוש תירושך זה",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "יין הילכך אנן דמשתעינן בלשון לעז אם",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "נדר מן התירוש בלשון הקדש אסור ביין",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ומותר בכל מיני מתיקה דאנן לא",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "קרינן תירוש אלא ליין כלשון תורה",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ותנן בפ' בכל מערבין (עירובין דף ל) הנודר מן",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "המזון מותר במים ומלח והוינן בה מים ומלח",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "(גירסת כתב יד) הוא דלא איקרו",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מזון הא כל מידי איקרי מזון לימא תיהוי",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "תיובתיה דרב ושמואל דרב ושמואל אמרי",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "תרוייהו אין",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מברכין בורא מיני מזונות",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אלא על ה'",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "המינים בלבד אמר רב יוסף באומר כל",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "הזן עלי דכה\"ג אסור בכל דבר חוץ ממים ומלח אבל הנודר מן המזון",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אינו אסור אלא מה' מינין. <big><b>תניא",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "כיצד א\"ר יהודה וכו' והצר</b></big>. ר\"ן ד\"ה",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "תניא כיצד א\"ר יהודה וכו' והצר",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שהמלבוש היה צר ונצטער בו ומסתברא",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לי דברייתא פליגא אמתני' בסברא דרבי",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "יהודה דתנא דמתניתין סבירא ליה",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דרבי יהודה מודה לת\"ק דכל היכא דליכא הוכחה לבישה משמע ולא טעינה ורבי יהודה דברייתא משמע",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דסבירא ליה דלמשרי טעינה נמי בעי הוכחה",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אבל כל היכא דליכא הוכחה אסור אפילו בטעינה",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ומסתברא דכמתניתין קיימא לן הילכך סתמא לבישה משמע",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ולא טעינה אבל היה טעון ומתוך כך נדר אסור בטעינה ומותר בלבישה",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "זהו",
      "source_ref": "Tosafot on Nedarim 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    }
  ]
}