    }
  ],
  "tosafot": [
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "<big><b>ומהדרינן.</b></big> ר\"ן ד\"ה ומהדרינן אין בעלמא דרשינן ק\"ו אלא דשאני הכא דאתא קרא",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "ואפקיה ומקשו הכא א\"כ דאי לאו קרא מודו רבנן לר\"א בק\"ו דידיה",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "מאי מהדרי ליה מקוה יוכיח דהא אינהו גופייהו מודו ליה אלא דקרא",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "קדרשי ואיכא למימר דהכי אמרי ליה לא תדחוק נפשך למדחי דרשא",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דילן משום קל וחומר דידך דמקוה",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "יוכיח דאיכא למידן קל וחומר ואתא",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "קרא ואפקיה דמקוה שאינו מציל",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מדרשא נפקא לן מדכתיב והנוגע (כן צריך להגיה)",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בנבלתם יטמא הלל אומר אפילו הן",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בתוך המים ואדם שמציל על טהרה",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בלועה מקרא נמי נפיק אלמא אתי",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "קרא לאפוקי ק\"ו וכי האי גוונא בהפר'",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "נדרים נמי לא תפלוג אדרשא דילן",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לקיומי ק\"ו (דילן) [דילך] דכי היכי דהתם",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "את גופך מודית דאתא קרא",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ואפקיה הכא נמי אתא קרא ואפקיה",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ונהי דעד השתא הוה סברינן למימר",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דרבנן פרכי ליה דליכא למידן בכי",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "האי גוונא קולא וחומרא כלל במסקנא",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דסוגיין מסקי' דהכי קאמרי ליה מקוה",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "יוכיח דאתי קרא ומפיק ק\"ו כי האי",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "גוונא.",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Nedarim 76b:1:1",
      "gemara_segment_ids": [
