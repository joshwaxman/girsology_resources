  "segments": [
    {
      "segment_id": 15,
      "original_text": "וְעֶצֶם רַגְלוֹ, אַף עַל פִּי שֶׁאֵינוֹ נִיכָּר. מוּמִין אֵלּוּ מָנָה אִילָא בְּיַבְנֶה, וְהוֹדוּ לוֹ חֲכָמִים. וְעוֹד שְׁלֹשָׁה הוֹסִיף, אָמְרוּ לוֹ: לֹא שָׁמַעְנוּ אֶת אֵלּוּ. שֶׁגַּלְגַּל עֵינוֹ עָגוֹל כְּשֶׁל אָדָם, וּפִיו דּוֹמֶה כְּשֶׁל חֲזִיר, וְשֶׁנִּיטַּל רוֹב הַמְדַבֵּר בִּלְשׁוֹנוֹ. בֵּית דִּין שֶׁל אַחֲרֵיהֶן",
      "reconstructed_text": "וְעֶצֶם רַגְלוֹ, אַף עַל פִּי שֶׁאֵינוֹ נִיכָּר. מוּמִין אֵלּוּ מָנָה אִילָא בְּיַבְנֶה, וְהוֹדוּ לוֹ חֲכָמִים. וְעוֹד שְׁלֹשָׁה הוֹסִיף, אָמְרוּ לוֹ: לֹא שָׁמַעְנוּ אֶלא אֵלּוּ. שֶׁגַּלְגַּל עֵינוֹ עָגוֹל כְּשֶׁל אָדָם, וּפִיו דּוֹמֶה כְּשֶׁל חֲזִיר, וְשֶׁנִּיטַּל רוֹב הַמְדַבֵּר בִּלְשׁוֹנוֹ. בֵּית דִּין שֶׁל אַחֲרֵיהֶן",
