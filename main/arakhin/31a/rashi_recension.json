  "segments": [
    {
      "segment_id": 10,
      "original_text": "הִתִּירַתּוּ! אָמַר רַבִּי יוֹחָנָן: לָא קַשְׁיָא, הָא רַבִּי יְהוּדָה וְהָא רַבָּנַן. דְּתַנְיָא: הֲרֵי שֶׁהָיָה נוֹשֶׁה בַּחֲבֵירוֹ מָנֶה, וְעָשָׂה לוֹ שָׂדֵהוּ מֶכֶר, בִּזְמַן שֶׁהַמּוֹכֵר אוֹכֵל פֵּירוֹת — מוּתָּר, לוֹקֵחַ אוֹכֵל פֵּירוֹת —",
      "reconstructed_text": "הִתִּירַתּוּ! אָמַר רַבִּית ואם לאו לָא קַשְׁיָא, יהָא רַבִּית יְהוּדָה וְהָא רַבָּנַן. דְּתַנְיָא: הֲרֵי שֶׁהָיָה נוֹשֶׁה בַּחֲבֵירוֹ מָנֶה, וְעָשָׂה לוֹ שָׂדֵהוּ מֶכֶר, בִּזְמַן שֶׁהַמּוֹכֵר אוֹכֵל פֵּירוֹת — מוּתָּר, לוֹקֵחַ אוֹכֵל פֵּירוֹת —",
