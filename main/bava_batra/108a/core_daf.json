  "tosafot": [
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "<big><b><span class=\"dh-divergent\">מתני&#x27;</span> <span class=\"dh-divergent\">יש</span> נוֹחֲלִין וְאֵלּוּ נוֹחֲלִין וּמַנְחִילִין.</b></big> איכא דוכתי דנקיט אדסליק",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "390px",
      "right": "",
      "left": "0px",
      "text": "מיניה ואיכא אדפתח ביה ובמס' נדרים (<a href=\"/nedarim/2b\">דף ב:</a>)",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "מפרש לה <big><b>האב את הבנים והבנים את האב</b></big>. תימה והאב את",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "הבנים היינו בנים את האב שאם האב נוחל את בנו אם כן בנו מנחילו",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ואם הוא מנחיל לבנו א''כ בנו נוחלו",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ואור''י דאייתר למידק מיניה בנים",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ולא בנות אע''ג דקתני לה בהדיא",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בסמוך מכל מקום תנא ליה הכא אגב",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אורחיה ולקמן נמי תניא למנות",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "סדר נחלות וכן משמע בגמ' דקאמר",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "הבנים את האב מנלן אמר קרא ובן",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אין לו הא יש לו בן בן קודם לבת",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "משמע דמתני' לאקדומי בן לבת",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "איצטריך אבל מרישא דקתני האב את",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "הבנים ליכא למידק הכי דהאב מנחיל",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בנים ולא בנות דהא לא מייתר ואם",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "תאמר דקתני בני אחיות ודייק בגמ'",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "עלה ולא בנות אחיות אע''ג דלא",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מייתר ומתוך כך צריך לומר דמתני' '",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "איני יודע מי שנאה לימא דבנים לאו",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דוקא אלא הוא הדין בנות ואתיא שפיר",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "כרבי זכריה בן הקצב אע''ג דתנא",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בגמ' בני אחיות ולא בנות אחיות [יש]",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לומר דברייתא פליגא אמתניתין ויודע",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מי שנאה ואור''י דקים ליה דברייתא",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "נשנית על המשנה לפיכך דייק מינה",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ועוד אומר ר''י דכיון דבנים את האב",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אייתר למידק בנים ולא בנות אית לן",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "למימר דכולהו בנים דמתני' דוקא ולא בנות לקדום <big><b>ואחין מן האב</b></big>.",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "הקשה ר''י אמאי לא קתני אחי האב נוחלין ומנחילין שהן כתובין",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "נמי בפרשה ותירץ משום דאחי האב וכל שאר אב נפקי מהנך האב",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "את הבנים והבנים את האב והאחין מן האב דכיון שנודע שהבנים",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "קודמין ואחר הבנים האב ואחר האב אחין הרי אחי האב נפקי מכלל",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "זה על ידי משמוש דאם היה אבי (גירסת מהר\"ם שי\"ף) האב קיים היה יורש ועכשיו שאינו",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "קיים הרי הוא יורש בקבר להנחיל לבנו שהוא אחי אביו של מת",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "ומשמוש שמעינן מדתנן בסמוך בני אחות שמנחילה בקבר נכסי",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "אחיה לבנה וא''ת אם כן אחין מן האב נמי לא ליתני דשמעינן ליה",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "מהאב את הבנים על ידי משמוש נחלה שהאב יורש את בנו להנחיל",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "לשאר בניו הקיימין שהן אחי המת ויש לומר דנקט לה (הגהת הב\"ח) אגב דבעי",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "למיתני אחים מן האם לא נוחלין ולא מנחילין דההוא איצטריך למיתני",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "אע''ג דתנא האשה אינה נוחלת את בנה סד''א נהי דאינו יורש אחיו",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "מן האם מכח אמו מכח אח הוה אמינא דיורש דכתיב ונתתם את",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "נחלתו לאחיו לא שנא מן האב ולא שנא מן האם וכי תימא דמכל מקום",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "לא איצטריך למיתני דשמעי' מרישא דקתני אחין מן האב דוקא ולא",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "אחין מן האם איצטריך דהוה אמינא אחין מן האב לרבותא נקט",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "אף על פי שאין כל כך ודאין כמו אחין מן האם ואם תאמר אם",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "כן אחי האב נמי ליתני אגב אחי האם דסיפא ויש לומר דאי הוי",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "תני אחי האב תו לא הוה צריך למיתני אחי האם דמכלל אחי",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "האב שמעינן להו ועוד דלא שייך למיתני אגב אחי האם דהיא",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "גופה משנה דלא צריכא היא כדדייקינן בגמ' דהיינו בני אחות:",
      "source_ref": "Tosafot on Bava Batra 108a:4:1",
      "gemara_segment_ids": [
        2
      ]
    }
  ]
}