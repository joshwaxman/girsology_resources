      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לַעֲשׂוֹת כְּדִבְרֵי <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda HaNasi, sixth-generation Tanna\" data-authority-id=\"1508\" data-full-name=\"Rabbi Yehuda HaNasi\" data-name-he=\"רבי יהודה הנשיא\">רַבִּי</span>, וְאִם עָשָׂה – עָשׂוּי. קָא סָבַר:",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מַטִּין אִיתְּמַר. <span class=\"sentence\" id=\"4\" type=\"start\">&star;</span>תָּנֵי <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Naḥman bar Ya’akov, third-generation Amora\" data-authority-id=\"2285\" data-full-name=\"Rav Naḥman bar Ya’akov\" data-name-he=\"רב נחמן בר יעקב\">רַב נַחְמָן</span> בִּשְׁאָר סִפְרֵי דְּבֵי",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"of Rav, first-generation Amora\" data-authority-id=\"2578\" data-full-name=\"of Rav\" data-name-he=\"רב\">רַב</span>: ״בְּכׇל אֲשֶׁר יִמָּצֵא לוֹ״ – פְּרָט לְשֶׁבַח",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שֶׁהִשְׁבִּיחוּ יוֹרְשִׁין לְאַחַר מִיתַת אֲבִיהֶן. אֲבָל",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שֶׁבַח שֶׁשָּׁבְחוּ נְכָסִים לְאַחַר מִיתַת אֲבִיהֶן –",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שָׁקֵיל. וּמַנִּי – <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda HaNasi, sixth-generation Tanna\" data-authority-id=\"1508\" data-full-name=\"Rabbi Yehuda HaNasi\" data-name-he=\"רבי יהודה הנשיא\">רַבִּי</span> הִיא. <span class=\"sentence\" id=\"5\" type=\"start\">&star;</span>תָּנֵי <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rami bar Ḥama, third and fourth-generation Amora\" data-authority-id=\"2681\" data-full-name=\"Rami bar Ḥama\" data-name-he=\"רמי בר חמא\">רָמֵי בַּר חָמָא</span> בִּשְׁאָר",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "סִפְרֵי דְּבֵי <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"of Rav, first-generation Amora\" data-authority-id=\"2578\" data-full-name=\"of Rav\" data-name-he=\"רב\">רַב</span>: ״בְּכׇל אֲשֶׁר יִמָּצֵא לוֹ״ – פְּרָט",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לְשֶׁבַח שֶׁשָּׁבְחוּ נְכָסִים לְאַחַר מִיתַת אֲבִיהֶן,",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וְכׇל שֶׁכֵּן שֶׁבַח שֶׁהִשְׁבִּיחוּ יוֹרְשִׁין לְאַחַר",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מִיתַת אֲבִיהֶן – דְּלָא שָׁקֵיל. וּמַנִּי – רַבָּנַן הִיא. <span class=\"sentence\" id=\"6\" type=\"start\">&star;</span>אָמַר",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yehuda bar Yeḥezkel, second-generation Amora\" data-authority-id=\"1394\" data-full-name=\"Rav Yehuda bar Yeḥezkel\" data-name-he=\"רב יהודה בר יחזקאל\">רַב יְהוּדָה</span> אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Shmuel II, first-generation Amora\" data-authority-id=\"2763\" data-full-name=\"Shmuel II\" data-name-he=\"שמואל\">שְׁמוּאֵל</span>: אֵין בְּכוֹר נוֹטֵל פִּי",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שְׁנַיִם בַּמִּלְוָה. לְמַאן? אִילֵּימָא לְרַבָּנַן, הַשְׁתָּא",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שְׁבָחָא דְּאִיתֵיהּ בִּרְשׁוּתֵיהּ – אָמְרִי רַבָּנַן לָא",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שָׁקֵיל; מִלְוָה מִבַּעְיָא?! <span class=\"sentence\" id=\"7\" type=\"start\">&star;</span>אֶלָּא <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda HaNasi, sixth-generation Tanna\" data-authority-id=\"1508\" data-full-name=\"Rabbi Yehuda HaNasi\" data-name-he=\"רבי יהודה הנשיא\">לְרַבִּי</span>. <span class=\"sentence\" id=\"8\" type=\"start\">&star;</span>וְאֶלָּא הָא",
      "segment_ids": [
        7,
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דְּתַנְיָא: יָרְשׁוּ שְׁטַר חוֹב – בְּכוֹר נוֹטֵל פִּי שְׁנַיִם,",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בֵּין בַּמִּלְוָה בֵּין בָּרִבִּית. מַנִּי? לָא <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda HaNasi, sixth-generation Tanna\" data-authority-id=\"1508\" data-full-name=\"Rabbi Yehuda HaNasi\" data-name-he=\"רבי יהודה הנשיא\">רַבִּי</span> וְלָא",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "רַבָּנַן! <span class=\"sentence\" id=\"9\" type=\"start\">&star;</span>לְעוֹלָם לְרַבָּנַן, וְאִצְטְרִיךְ – סָלְקָא דַעְתָּךְ",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אָמֵינָא: מִלְוָה – כֵּיוָן דְּנָקֵיט שְׁטָרָא, כְּמַאן דְּגַבְיָא",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דָּמְיָא; קָא מַשְׁמַע לַן. <span class=\"sentence\" id=\"10\" type=\"start\">&star;</span>שְׁלַחוּ מִתָּם: בְּכוֹר נוֹטֵל",
      "segment_ids": [
        10
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "פִּי שְׁנַיִם בַּמִּלְוָה, אֲבָל לֹא בָּרִבִּית. <span class=\"sentence\" id=\"11\" type=\"start\">&star;</span>לְמַאן?",
      "segment_ids": [
        11
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אִילֵּימָא לְרַבָּנַן, הַשְׁתָּא שְׁבָחָא דְּאִיתֵיהּ בִּרְשׁוּתֵיהּ –",
      "segment_ids": [
        11
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אָמְרִי רַבָּנַן דְּלָא שָׁקֵיל; מִלְוָה",
      "segment_ids": [
        11
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מִבַּעְיָא?! <span class=\"sentence\" id=\"12\" type=\"start\">&star;</span>אֶלָּא <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda HaNasi, sixth-generation Tanna\" data-authority-id=\"1508\" data-full-name=\"Rabbi Yehuda HaNasi\" data-name-he=\"רבי יהודה הנשיא\">לְרַבִּי</span>. <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda HaNasi, sixth-generation Tanna\" data-authority-id=\"1508\" data-full-name=\"Rabbi Yehuda HaNasi\" data-name-he=\"רבי יהודה הנשיא\">וּלְרַבִּי</span>, בָּרִבִּית לָא?! וְהָתַנְיָא,",
      "segment_ids": [
        12
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda HaNasi, sixth-generation Tanna\" data-authority-id=\"1508\" data-full-name=\"Rabbi Yehuda HaNasi\" data-name-he=\"רבי יהודה הנשיא\">רַבִּי</span> אוֹמֵר: בְּכוֹר נוֹטֵל פִּי שְׁנַיִם, בֵּין בַּמִּלְוָה",
      "segment_ids": [
        12
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בֵּין בָּרִבִּית! <span class=\"sentence\" id=\"13\" type=\"start\">&star;</span>לְעוֹלָם רַבָּנַן הִיא, וּמִלְוָה כְּמַאן",
      "segment_ids": [
        13
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דְּגַבְיָא דָּמְיָא. <span class=\"sentence\" id=\"14\" type=\"start\">&star;</span>אֲמַר לֵיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Adda bar Natan, seventh-generation Amora\" data-authority-id=\"296\" data-full-name=\"Rav Adda bar Natan\" data-name-he=\"רב אחא בר רב\">רַב אַחָא בַּר רַב</span> <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Ravina II, sixth and seventh-generation Amora\" data-authority-id=\"2647\" data-full-name=\"Ravina II\" data-name-he=\"רבינא\">לְרָבִינָא</span>:",
      "segment_ids": [
        14
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אִיקְּלַע <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Ameimar, sixth-generation Amora\" data-authority-id=\"514\" data-full-name=\"Ameimar\" data-name-he=\"אמימר\">אַמֵּימָר</span> לְאַתְרִין, וְדָרֵישׁ: בְּכוֹר נוֹטֵל פִּי",
      "segment_ids": [
        14
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שְׁנַיִם בַּמִּלְוָה, אֲבָל לֹא בָּרִבִּית. אֲמַר לֵיהּ: <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Neharde’a, Amora\" data-authority-id=\"2237\" data-full-name=\"Neharde’a\" data-name-he=\"נהרדעי\">נְהַרְדָּעֵי</span> לְטַעְמַיְיהוּ –",
      "segment_ids": [
        14
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"15\" type=\"start\">&star;</span>דְּאָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabba bar Naḥmani, third-generation Amora\" data-authority-id=\"2581\" data-full-name=\"Rabba bar Naḥmani\" data-name-he=\"רבה בר נחמני\">רַבָּה</span>: גָּבוּ קַרְקַע – יֵשׁ לוֹ,",
      "segment_ids": [
        15
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "גָּבוּ מָעוֹת – אֵין לוֹ. <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Naḥman bar Ya’akov, third-generation Amora\" data-authority-id=\"2285\" data-full-name=\"Rav Naḥman bar Ya’akov\" data-name-he=\"רב נחמן בר יעקב\">וְרַב נַחְמָן</span> אָמַר: גָּבוּ מָעוֹת – יֵשׁ",
      "segment_ids": [
        15
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לוֹ, גָּבוּ קַרְקַע – אֵין לוֹ. <span class=\"sentence\" id=\"16\" type=\"start\">&star;</span>אֲמַר לֵיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Abaye, fourth-generation Amora\" data-authority-id=\"121\" data-full-name=\"Abaye\" data-name-he=\"אביי\">אַבָּיֵי</span> <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabba bar Naḥmani, third-generation Amora\" data-authority-id=\"2581\" data-full-name=\"Rabba bar Naḥmani\" data-name-he=\"רבה בר נחמני\">לְרַבָּה</span>:",
      "segment_ids": [
        16
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לְדִידָךְ קַשְׁיָא, <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Naḥman bar Ya’akov, third-generation Amora\" data-authority-id=\"2285\" data-full-name=\"Rav Naḥman bar Ya’akov\" data-name-he=\"רב נחמן בר יעקב\">לְרַב נַחְמָן</span> קַשְׁיָא. לְדִידָךְ קַשְׁיָא,",
      "segment_ids": [
        16
      ]
    }
  ],
