  "tosafot": [
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "<big><b>אִם כֵּן, בִּטַּלְתָּ יְרוּשַּׁת בְּנוֹ.</b></big> דבשלמא מכל אדם שיש עליו כתובת",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "420px",
      "right": "",
      "left": "0px",
      "text": "אשה ובעל חוב אף על פי שנכסים משועבדין להן מ\"מ אין",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "ירושת בני הבכור בטילה משום דמלוה ואשה מחסרי גוביינא וצריכי",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "אדרכתא ואכרזתא ושומא אבל למס המלך אפילו קרקע שוה אלף זוז",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "משועבדת לדבר מועט והקרקעות",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "עיקר הן של המלך וכבר הוא מוחזק",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ולא מחסרי גוביינא, ר\"י ור\"ת.",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<big><b>אנדיסקי</b></big>. פי' כותבי שטרות",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "160px",
      "right": "",
      "left": "0px",
      "text": "המלך דדיסקא הוא",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שטר כדאמר בהגוזל בתרא (ב\"ק דף",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "קיב:) האי מאן דנקיט דיסקא מב\"ד",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "הגדול ובפרק השולח (<a href=\"/gittin/36a\">גיטין דף לו.</a>)",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מעיקרא במאי אפקינהו בדיסקי.",
      "source_ref": "Tosafot on Bava Batra 55a:1:1",
      "gemara_segment_ids": [
        3
      ]
    }
  ]
}