  "tosafot": [
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "<big><b>אַמַּאי קָא סָמְכַתְּ אַהַאי שְׁטָרָא.</b></big>",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "370px",
      "right": "80px",
      "left": "",
      "text": "תימה דליהמניה במיגו דאי בעי אמר שטרא מעליא הוא",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "ותירץ ר\"י בר' מרדכי דלא אמרי' מיגו להוציא ממון ומה שהוא",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "מוחזק בקרקע אינו כלום דקרקע בחזקת בעליה קיימא כיון שאין לו",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שטר ולא חזקה אלא בדברים בעלמא",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שאומר שטרא מעליא הוה לי ואירכס",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ולא אמרי' מיגו אלא להחזיק ממון",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שיכול לפטור עצמו ע\"י מיגו אי נמי",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אם יש לו שטר או חזקה וזה בא",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לפסול ראייתו אז זה יכול לקיימו ע\"י",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מיגו כמו קמי דידי זבנה מינך מיגו",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דאי בעי אמר מינך זבינתיה ואכלתיה",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שני חזקה ואין נראה לר\"י מדלא",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מפרש טעמא הכי בהדיא משמע",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דלאו משום הכי הוא ונראה לר\"י",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דטעמא דרב יוסף דלא אמרי' מיגו",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הכא כיון דלית ליה הכא מיגו אא\"כ",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שקר תחלה שהוצרך לשקר תחלה ולומר",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "והא שטרא א\"נ משום הכי לא אמרי'",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הכא מיגו משום דהוי חוזר וטוען",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דמעיקרא טען והא שטרא ועתה חוזר",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בו ומודה דחספא בעלמא הוא אלא",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שטרא מעליא הוה לי.",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<big><b>והלכתא כוותי' דרבה בארעא</b></big>.",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "רבינו שמואל פירש",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דמספקא ליה כמאן הלכתא וצריך",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לדחוק ולפרש ולחלק בין ספיקא דתרי",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ותרי לספיקא דדינא דהא דלא אוקמה",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בחזקת מרה קמא כמו בנכסי דבר",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שטיא דאמרי' (<a href=\"/ketubot/20a\">כתובות דף כ.</a>) אוקי",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "תרי בהדי תרי ואוקי נכסי בחזקת בר",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שטיא התם הוו תרי ותרי כמאן",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דליתנהו דמי ואוקמי' ארעא בחזקת",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מרה קמא אבל הכא דמספקא לן דינא",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כמאן התם לא שייך כולי האי למימר",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אוקמה אחזקת מרה קמא ונוציא מיד",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "המוחזק ודוחק הוא ועוד דהילכתא",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "משמע דלגמרי פוסק כרבה ולא",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מספק אפי' עבד כרב יוסף בדיעבד",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לא עבד ונראה לר\"י דהיינו טעמא",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דהלכתא בארעא כרבה וכרב יוסף",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בזוזי משום דאמרי' מיגו לאוקמי",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ממונא ואית לן לאוקמי ארעא בחזקת",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מרה דקיימא השתא ובהכותב (כתובות",
      "source_ref": "Tosafot on Bava Batra 32b:2:1",
      "gemara_segment_ids": [
        2
