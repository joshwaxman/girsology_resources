    {
      "right": "275px",
      "width": "380px",
      "text": "כְּווֹתֵיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yosef I, third-generation Amora\" data-authority-id=\"1764\" data-full-name=\"Rav Yosef I\" data-name-he=\"רב יוסף בר חייא\">דְּרַב יוֹסֵף</span> בְּזוּזֵי. הִלְכְתָא <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabba bar Naḥmani, third-generation Amora\" data-authority-id=\"2581\" data-full-name=\"Rabba bar Naḥmani\" data-name-he=\"רבה בר נחמני\">כְּרַבָּה</span> בְּאַרְעָא –",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דְּהֵיכָא דְּקָיְימָא אַרְעָא, תֵּיקוּם. וְהִלְכְתָא כְּווֹתֵיהּ",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yosef I, third-generation Amora\" data-authority-id=\"1764\" data-full-name=\"Rav Yosef I\" data-name-he=\"רב יוסף בר חייא\">דְּרַב יוֹסֵף</span> בְּזוּזֵי – דְּהֵיכָא דְּקָיְימִי זוּזֵי, לוֹקְמוּ<span class=\"sugya-marker sugya-marker-vilna-piska\" data-sugya-kind=\"vilna-piska\" data-sugya-id=\"122\" data-raw-symbol=\"׃\">׃</span>",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"5\" type=\"start\">&star;</span>הָהוּא עָרְבָא דַּאֲמַר לֵיהּ לְלֹוֶה: הַב לִי מְאָה זוּזִי",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דִּפְרַעְתִּי לְמַלְוֶה עִילָּוָךְ, וְהָא שְׁטָרָא. אֲמַר",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לֵיהּ: לָאו פְּרַעְתָּיךְ? אֲמַר: לָאו הֲדַרְתְּ",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שְׁקַלְתִּינְהוּ מִינַּאי? <span class=\"sentence\" id=\"6\" type=\"start\">&star;</span>שַׁלְחַהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Dimi bar Abba I, third and fourth-generation Amora\" data-authority-id=\"343\" data-full-name=\"Rav Dimi bar Abba I\" data-name-he=\"רב אידי בר אבין\">רַב אִידִי בַּר אָבִין</span>",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לְקַמֵּיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Abaye, fourth-generation Amora\" data-authority-id=\"121\" data-full-name=\"Abaye\" data-name-he=\"אביי\">דְּאַבָּיֵי</span>: כִּי הַאי גַוְונָא מַאי? שְׁלַח",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לֵיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Abaye, fourth-generation Amora\" data-authority-id=\"121\" data-full-name=\"Abaye\" data-name-he=\"אביי\">אַבָּיֵי</span>: מַאי תִּיבְּעֵי לֵיהּ? הָא אִיהוּ דְּאָמַר:",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הִלְכְתָא כְּווֹתֵיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabba bar Naḥmani, third-generation Amora\" data-authority-id=\"2581\" data-full-name=\"Rabba bar Naḥmani\" data-name-he=\"רבה בר נחמני\">דְּרַבָּה</span> בְּאַרְעָא, וְהִלְכְתָא",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "כְּווֹתֵיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yosef I, third-generation Amora\" data-authority-id=\"1764\" data-full-name=\"Rav Yosef I\" data-name-he=\"רב יוסף בר חייא\">דְּרַב יוֹסֵף</span> בְּזוּזֵי – דְּהֵיכָא דְּאוֹקְמוּ זוּזֵי,",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לוֹקְמוּ! <span class=\"sentence\" id=\"7\" type=\"start\">&star;</span>וְהָנֵי מִילֵּי, דְּאָמַר לֵיהּ: הֲדַרְתְּ אוֹזִפְתִּינְהוּ",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מִינַּאי. אֲבָל אֲמַר לֵיהּ: הַדַּרְתִּינְהוּ נִיהֲלָךְ מֵחֲמַת דַּהֲווֹ",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שַׁיְיפִי וְסוּמָּקֵי – אַכַּתִּי אִיתֵיהּ לְשִׁעְבּוּדָא דִשְׁטָרָא.",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"8\" type=\"start\">&star;</span><span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rava bar Sharshom, fourth-generation Amora\" data-authority-id=\"2632\" data-full-name=\"Rava bar Sharshom\" data-name-he=\"רבא בר שרשום\">רָבָא בַּר שַׁרְשׁוּם</span> נָפֵק עֲלֵיהּ קָלָא דְּקָא אָכֵיל",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אַרְעָא דְיַתְמֵי. אֲמַר לֵיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Abaye, fourth-generation Amora\" data-authority-id=\"121\" data-full-name=\"Abaye\" data-name-he=\"אביי\">אַבָּיֵי</span>: אֵימָא לִי אִיזִי, גּוּפָא",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דְעוֹבָדָא הֵיכִי הֲוָה? אֲמַר לֵיהּ: אַרְעָא בְּמַשְׁכַּנְתָּא",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הֲוָה נָקֵיטְנָא מֵאֲבוּהוֹן דְּיַתְמֵי; וַהֲוָה לִי",
      "segment_ids": [
        8
      ]
    }
  ],
