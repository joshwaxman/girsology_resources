    }
  ],
  "tosafot": [
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "<big><b><span class=\"dh-divergent\">תנו</span> <span class=\"dh-divergent\">מנה</span> לִפְלוֹנִי, <span class=\"dh-divergent\">ומת</span> <span class=\"dh-divergent\">יתנו</span> <span class=\"dh-divergent\">לאחר</span> <span class=\"dh-divergent\">מיתה</span> <span class=\"dh-divergent\">(המשך)</span>.</b></big> דאין נראה לומר דקמשמע לן ברישא דאין מעמד שלשתן מועיל",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "350px",
      "right": "",
      "left": "",
      "text": "בשטר א\"כ אף לדידיה תנו דמתני' היינו כתבו ותנו דכי (הגהת מהרש\"א) האי גוונא שלא",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "בא השטר לעולם לא מהני מעמד שלשתן ועל כרחך צריכין אנו",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "לומר הא כדאיתא והא כדאיתא רישא קמ''ל דאין גט לאחר מיתה",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "וסיפא קמ''ל דין של מעמד שלשתן",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "בממון ואע''ג דדייק התם בגמרא",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "דסיפא איירי בבריא דומיא דרישא",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "אלמא משמע שיש לנו לדמות אהדדי",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "היינו טעמא (כן הוא בדפוס ישן) דבעי לאוקומא",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "בחד גוונא דאיירי בחד גברא אבל",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "אינם דומות לגמרי אהדדי [הגה''ה]",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "ועוד י''ל דמצי לאוקומא רישא דגט",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "שחרור במעמד שלשתן כיון דאוקי",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "מתניתין בבריא (הגהה במהדורת עוז והדר) ואשמועינן ברישא",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "דאע''ג דאמר תנו גט לאשתי במעמד",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "שלשתן שאשתו רוצה בכך וכן העבד",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "לא קנו בכך אפילו אם תמצי לומר",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "שלענין זכות נייר השטר הוי ממון",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "ואהני ליה מעמד שלשתן לענין",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "שכתוב בתוכו לא מהני ואע''ג דתן",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "כזכי דמי הכא לא יזכה בו העבד",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "דאיכא לאוקמא דמיירי שאינו באותה",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "שעה ברשות הנפקד ואנן בעינן מסירה (כן הוא בדפוס ישן)",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "מיד ליד א''נ שאין הנפקד רוצה",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "לזכות לעבד וזוכה בעל כרחו במעמד",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "שלשתן במתנה אבל לא בגט שחרור",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "כדפרישנא לעיל בהמוכר את הספינה",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "(<a href=\"/bava_batra/76a\">דף עו.</a>) שמועיל מעמד שלשתן",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "בעל כרחו של נפקד מיהו אין",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "נראה להעמיד רישא בפלוגתא",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "דאמוראי דאיכא דמוקי לה במעמד",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "שלשתן ואיכא דמוקי לה בכתבו ותנו",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "אלא ודאי בסיפא הוא דפליגי ולא",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "הוי סיפא דומיא דרישא מכל וכל",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "כדפרישית לעיל ולא גרסי' נמי בהך",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "סיפא זה דאפילו בסתם מנה מיירי",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "מתניתין כדאיתא בפ''ק דגיטין (דף",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "יג. ושם) <big><b>מתנת שכיב מרע שכתוב בה קנין</b></big>. פירש רבינו שמואל",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "דמיירי בשכתב לו כל נכסיו וה''ה בלא שטר אלא שהקנה לו אמרי'",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "דאין קנין לאחר מיתה לשמואל והביא ראיה מדפריך לה לקמן מהא",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "מילתא דשמואל דאמר שכיב מרע שכתב כל נכסיו לאחרים אע''פ",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "שקנו לו כו' ואין נראה לרבינו יצחק בר מאיר דא''כ מתני' דקתני",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "שכיב מרע ששייר קרקע כל שהוא מתנתו מתנה במאי מיירי לרב",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "אי שלא בקנין אמאי מתנתו מתנה והא קי''ל לעיל דבעי קנין ואי",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "בקנין א''כ סיפא דקתני לא שייר קרקע. כל שהוא אין מתנתו מתנה",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "והא אית ליה לרב הכא דמתנתו מתנה בקנין ועוד דלשמואל דאמר",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "אין גט לאחר מיתה הוא הדין נמי דאין קנין לאחר מיתה א''כ מתני'",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "דקתני שייר קרקע כל שהוא מתנתו מתנה היינו בקנין איך יועיל",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "לשמואל כלום הלא שמא לא גמר להקנותו אלא לאחר מיתה ודוחק",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "הוא להעמיד משנתנו במייפה כחו וכגון שאמר וקנינא וכו' (הגהת הב\"ח) דבסמוך לא משמע",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "הכי ועוד קשה מדפסיק גמרא דהלכתא מתנת שכיב מרע במקצת",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "בעיא קנין ואם עמד אינו חוזר משמע הא בכולה אם עמד חוזר",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "ואפילו ע''י קנין והא ליתא לרב דאית ליה דקנין אלים כל כך בכל",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "נכסיו כמו במתנת בריא ועוד קשיא דוחק גדול הוא שהגמרא אינו",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "אומר אלא שטר והוא אמר דה''ה נמי קנין בלא שטר ועוד דלספרים",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "דגרסינן לקמן וכגון דכתב ליה וקנינא מיניה מוסיף על מתנתא",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "דמשמע שבתוך השטר כתב לו כן מיהו יש ספרים דגרסי' לקמן כגון",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "דא''ל וקנינא מיניה כו' ונראה לר''י לפרש דמיירי בשטר דוקא והיינו",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "טעמא דרב שסובר שלכך כתב לו קנין בתוך השטר לאלומי כחו יותר",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "שאפי' בכל נכסיו אם עמד אינו חוזר כיון שכתב לו בתוך השטר ושמואל",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "סבר דשטר זה אינו אלא מגרע כחו כי אע''פ שיש בו קנין אין בו בכך",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "ייפוי כח אלא יש לנו לומר שלא",
      "source_ref": "Tosafot on Bava Batra 152a:1:1",
      "gemara_segment_ids": [
        0
      ]
    }
  ]
}