  "tosafot": [
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "<big><b>הָא <span class=\"dh-divergent\">באמה</span> <span class=\"dh-divergent\">והא</span> <span class=\"dh-divergent\">בברתא</span>.</b></big> כלומר משנה וברייתא חד הוא ומפריח",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "410px",
      "right": "",
      "left": "0px",
      "text": "בריכה ראשונה דמתני' היינו בריכה ראשונה של כל אם ואם",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "[והא בברתא כלומר כל אם ואם בין בנות בין אמהות] וברייתא נמי",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "ה\"ק מפריח בריכה ראשונה ושניה היינו ראשונה לבריכה שהפריח",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "והיא שניה לאמה לבריכה הראשונה",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שבשבילה מפריח אלו והוא הדין שניה",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ושלישית ורביעית אלא דאטו כי רוכלא",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ליחשיב וליזל. <big><b>דבש בכוורתו",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אינו יוצא מידי מאכל לעולם</b></big>. פ\"ה עד",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שיקצהו למאכל דבורים בפירוש ואין",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "נראה לר\"י דאין לך דבר ראוי לאכילה",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שיועיל בו שום דבר עד שיפסל",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מאכילת כלב. <big><b>אינו יוצא מידי מאכל",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לעולם</b></big>. תימה לר\"י דבמס' מכשירין",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "(פ\"ו מ\"ד) חשיב דבש בהדי ז' משקים",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ואומר ר\"י דהיינו אחר שהופרש מן",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "השעוה אבל בכוורתו שהוא עם השעוה",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "יש עליו תורת אוכל ולא תורת משקה.",
      "source_ref": "Tosafot on Bava Batra 80a:2:1",
      "gemara_segment_ids": [
        0
      ]
    }
  ]
}