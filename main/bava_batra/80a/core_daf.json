  "vilna_piskaot": [
    {
      "id": 296,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 4,
      "mishnah_ref": "Bava Batra 80a",
      "mishnah_href": "/bava_batra/80a#gemara-line-1",
      "mishnah_line_number": 1,
      "quote_text": "מַתְנִי׳ הַלּוֹקֵחַ פֵּירוֹת שׁוֹבָךְ מֵחֲבֵירוֹ – מַפְרִיחַ בְּרִיכָה רִאשׁוֹנָה. פֵּירוֹת כַּוֶּורֶת – נוֹטֵל שְׁלֹשָׁה נְחִילִים, וּמְסָרֵס. חַלּוֹת דְּבַשׁ – מַנִּיחַ שְׁתֵּי חַלּוֹת. זֵיתִים לָקוֹץ – מַנִּיחַ שְׁתֵּי גְרוֹפִיּוֹת"
    },
    {
      "id": 297,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 10
    },
    {
      "id": 298,
