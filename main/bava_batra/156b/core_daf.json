    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<a class=\"piska-quote-link\" data-piska-quote-group=\"piska-quote-518\" href=\"/bava_batra/156b#gemara-line-29\" title=\"Mishnah source: Bava Batra 156b\">דִּבְרֵי <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Eliezer ben Hyrcanus, third-generation Tanna\" data-authority-id=\"417\" data-full-name=\"Rabbi Eliezer ben Hyrcanus\" data-name-he=\"רבי אליעזר בן הורקנוס\">רַבִּי אֱלִיעֶזֶר</span>. <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehoshua ben Ḥananya, second and third-generation Tanna\" data-authority-id=\"1527\" data-full-name=\"Rabbi Yehoshua ben Ḥananya\" data-name-he=\"רבי יהושע בן חנניה\">רַבִּי יְהוֹשֻׁעַ</span> אוֹמֵר: לַקָּטָן</a>",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<a class=\"piska-quote-link\" data-piska-quote-group=\"piska-quote-518\" href=\"/bava_batra/156b#gemara-line-29\" title=\"Mishnah source: Bava Batra 156b\">אָמְרוּ, קַל וָחוֹמֶר לַגָּדוֹל</a><span class=\"sugya-marker sugya-marker-vilna-piska\" data-sugya-kind=\"vilna-piska\" data-sugya-id=\"518\" data-raw-symbol=\"׃\">׃</span> <span class=\"sentence\" id=\"8\" type=\"start\">&star;</span><big><strong>גְּמָ׳</strong></big> מַתְנִיתִין מַנִּי?",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda bar Rabbi Elai, fifth-generation Tanna\" data-authority-id=\"1395\" data-full-name=\"Rabbi Yehuda bar Rabbi Elai\" data-name-he=\"רבי יהודה ברבי אילעאי\">רַבִּי יְהוּדָה</span> הִיא – דְּתַנְיָא: <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Meir, fifth-generation Tanna\" data-authority-id=\"2068\" data-full-name=\"Rabbi Meir\" data-name-he=\"רבי מאיר\">רַבִּי מֵאִיר</span> אוֹמֵר, <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Eliezer ben Hyrcanus, third-generation Tanna\" data-authority-id=\"417\" data-full-name=\"Rabbi Eliezer ben Hyrcanus\" data-name-he=\"רבי אליעזר בן הורקנוס\" data-crossline-group=\"name-ref-crossline-7441\">רַבִּי</span>",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Eliezer ben Hyrcanus, third-generation Tanna\" data-authority-id=\"417\" data-full-name=\"Rabbi Eliezer ben Hyrcanus\" data-name-he=\"רבי אליעזר בן הורקנוס\" data-crossline-group=\"name-ref-crossline-7441\">אֱלִיעֶזֶר</span> אוֹמֵר: בַּחוֹל – דְּבָרָיו קַיָּימִין, מִפְּנֵי",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שֶׁיָּכוֹל לִכְתּוֹב; אֲבָל לֹא בַּשַּׁבָּת. <span class=\"sentence\" id=\"9\" type=\"start\">&star;</span><span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehoshua ben Ḥananya, second and third-generation Tanna\" data-authority-id=\"1527\" data-full-name=\"Rabbi Yehoshua ben Ḥananya\" data-name-he=\"רבי יהושע בן חנניה\">רַבִּי יְהוֹשֻׁעַ</span>",
      "segment_ids": [
        9
      ]
    }
  ],
