  "tosafot": [
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<big><b>הֲלָכָה <span class=\"dh-divergent\">כר&#x27;</span> יוֹחָנָן בֶּן בְּרוֹקָה.</b></big> נראה",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "170px",
      "right": "",
      "left": "0px",
      "text": "דדוקא בן בין הבנים ובת",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בין הבנות כפירוש רבינו שמואל",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<big><b>האי מלא יוכל לבכר נפקא</b></big>. פירוש",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "200px",
      "right": "",
      "left": "0px",
      "text": "מדקאמר רחמנא דחלק בכורה",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אין יכול לשנות מכלל דחלק פשיטות",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "יכול לשנות ולמה לי קרא דביום",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "הנחילו את בניו והוה מצי למימר",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ולטעמיך לרבנן נמי יקשה אמאי",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אינו יכול לשנות חלק פשיטות הא",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "כיון דכתיב לא יוכל לבכר מכלל",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דחלק פשיטות יכול",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<big><b>שיכול</b></big>. ל''ג והלא דין הוא:",
      "source_ref": "Tosafot on Bava Batra 130a:8:1",
      "gemara_segment_ids": [
        6
      ]
    }
  ]
}