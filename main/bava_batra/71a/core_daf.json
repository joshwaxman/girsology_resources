  "vilna_piskaot": [
    {
      "id": 267,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 1,
      "mishnah_ref": "Bava Batra 71a",
      "mishnah_href": "/bava_batra/71a#gemara-line-1",
      "mishnah_line_number": 1,
      "quote_text": "אִיפְּכָא מַתְנִינַן לַהּ"
    },
    {
      "id": 268,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 13,
      "mishnah_ref": "Bava Batra 71a",
      "mishnah_href": "/bava_batra/71a#gemara-line-10",
      "mishnah_line_number": 10,
      "quote_text": "הַמַּקְדִּישׁ אֶת הַשָּׂדֶה – הִקְדִּישׁ אֶת כּוּלָּהּ. רַבִּי שִׁמְעוֹן אוֹמֵר: הַמַּקְדִּישׁ אֶת הַשָּׂדֶה – לֹא הִקְדִּישׁ אֶלָּא אֶת הֶחָרוּב הַמּוּרְכָּב, וְאֶת סַדַּן הַשִּׁקְמָה"
    },
    {
      "id": 269,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 22
    },
    {
      "id": 270,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 23,
      "mishnah_ref": "Bava Batra 71a",
      "mishnah_href": "/bava_batra/71a#gemara-line-10",
      "mishnah_line_number": 10,
      "quote_text": "הַמַּקְדִּישׁ אֶת הַשָּׂדֶה – הִקְדִּישׁ וְכוּ׳"
    }
  ],
