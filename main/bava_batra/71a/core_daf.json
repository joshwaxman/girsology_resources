  "tosafot": [
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "<big><b>הָאַחִין שֶׁחָלְקוּ, זָכוּ בַּשָּׂדֶה זָכוּ בְּכוּלָּהּ.</b></big> וא\"ת לרב דאמר לעיל",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "360px",
      "right": "",
      "left": "0px",
      "text": "(<a href=\"/bava_batra/65a\">דף סה.</a>) יש להן דרך זה על זה משום דמוכר בעין רעה",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "מוכר היכי אמר הכא זכו בכולה כמו גבי מתנה וי\"ל הכא לאו",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "משום עין יפה הוא אלא משום דרוצין להסתלק זה מזה ואין",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "משיירין לכל אחד אלא הצריך לחלקו",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "כגון דרך. <big><b>אמר רב הונא אף על",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "גב דאמור רבנן הקונה שני אילנות",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "כו</b></big>. וא\"ת לפי' רבינו שמואל דלר\"ע",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דאמר בעין יפה מוכר קנה אילן",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אחד יש לו קרקע מאי קאמר רב",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "הונא אף על גב דאמרי רבנן הקונה",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ב' אילנות אין לו קרקע כו' משמע",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דאי הוו אמרי (כן נראה להגיה) דקנה קרקע אז לא",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "היה חידוש במשייר ב' אילנות דיש",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לו קרקע א\"כ מאי קאמר ואפילו",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לר\"ע וכו' מה אפילו הא לדידיה קנה",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אילן אחד יש לו קרקע וי\"ל דה\"ק",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דאע\"ג דאמור רבנן דב' אילנות לא",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "קנה קרקע ובשלשה קנה משום דלא",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אזיל קרקע בתר אילנות אלא כשיש",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ג' ולא בב' ולא מטעם עין יפה אפ\"ה",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בשייר אזיל קרקע בתר שני והשתא",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ודאי אי לאו טעמא דעין יפה ה\"א",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דבשנים קנה קרקע כל שכן בשייר",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שני אילנות לפניו דיש לו קרקע.",
      "source_ref": "Tosafot on Bava Batra 71a:4:1",
      "gemara_segment_ids": [
        2
      ]
    }
  ]
}