    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"0\" type=\"start\">&star;</span><span class=\"name-reference-marker name-reference-unknown\" data-sage-type=\"unknown\" title=\"Diini Gvlh\" data-authority-id=\"20345\" data-full-name=\"Diini Gvlh\" data-name-he=\"דייני גולה\">וְדַיָּינֵי גוֹלָה</span> אָמְרוּ: מַחְזִיקִין. אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"of Rav, first-generation Amora\" data-authority-id=\"2578\" data-full-name=\"of Rav\" data-name-he=\"רב\">רַב</span>: הֲלָכָה",
      "segment_ids": [
        0
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-unknown\" data-sage-type=\"unknown\" title=\"Diini Gvlh\" data-authority-id=\"20345\" data-full-name=\"Diini Gvlh\" data-name-he=\"דייני גולה\">כְּדַיָּינֵי גוֹלָה</span>. אֲמַרוּ לֵיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Kahana, the brother of II, second-generation Amora\" data-authority-id=\"2004\" data-full-name=\"Rav Kahana, the brother of II\" data-name-he=\"רב כהנא\">רַב כָּהֲנָא</span> <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabbi Asi I, first-generation Amora\" data-authority-id=\"534\" data-full-name=\"Rabbi Asi I\" data-name-he=\"רב אסי\">וְרַב אַסִּי</span> <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"of Rav, first-generation Amora\" data-authority-id=\"2578\" data-full-name=\"of Rav\" data-name-he=\"רב\">לְרַב</span>:",
      "segment_ids": [
        0
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הֲדַר בֵּיהּ מָר מִשְּׁמַעְתֵּיהּ? אֲמַר לְהוּ: מִסְתַּבְּרָא אֲמַרִי –",
      "segment_ids": [
        0
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yosef I, third-generation Amora\" data-authority-id=\"1764\" data-full-name=\"Rav Yosef I\" data-name-he=\"רב יוסף בר חייא\">כִּדְרַב יוֹסֵף</span><span class=\"sugya-marker sugya-marker-vilna-piska\" data-sugya-kind=\"vilna-piska\" data-sugya-id=\"161\" data-raw-symbol=\"׃\">׃</span> <span class=\"sugya-marker sugya-marker-steinsaltz\" data-sugya-kind=\"steinsaltz\" data-sugya-id=\"159\" data-sentence-id=\"1\" data-steinsaltz-label=\"א\">§</span> <span class=\"sentence\" id=\"1\" type=\"start\">&star;</span>וְלֹא לְאִשָּׁה בְּנִכְסֵי בַעְלָהּ",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וְכוּ׳<span class=\"sugya-marker sugya-marker-vilna-piska\" data-sugya-kind=\"vilna-piska\" data-sugya-id=\"162\" data-raw-symbol=\"׃\">׃</span> פְּשִׁיטָא – כֵּיוָן דְּאִית לַהּ מְזוֹנֵי, מְזוֹנֵי הוּא",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דְּקָא אָכְלָה! לָא צְרִיכָא, דְּיַחֵד לַהּ אַרְעָא",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אַחֲרִיתִי לִמְזוֹנַהּ. <span class=\"sentence\" id=\"2\" type=\"start\">&star;</span>הָא רְאָיָה – יֵשׁ? לֵימָא לְגַלּוֹיֵי",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "זוּזֵי הוּא דְּבָעֵי! <span class=\"sentence\" id=\"3\" type=\"start\">&star;</span>שָׁמְעַתְּ מִינַּהּ, הַמּוֹכֵר שָׂדֶה לְאִשְׁתּוֹ –",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "קָנְתָה, וְלָא אָמְרִינַן: לְגַלּוֹיֵי זוּזֵי הוּא",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דְּבָעֵי?! לָא; אֵימָא: הָא רְאָיָה יֵשׁ – בִּשְׁטַר מַתָּנָה.",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"4\" type=\"start\">&star;</span>אֲמַר לֵיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Naḥman bar Ya’akov, third-generation Amora\" data-authority-id=\"2285\" data-full-name=\"Rav Naḥman bar Ya’akov\" data-name-he=\"רב נחמן בר יעקב\">רַב נַחְמָן</span> <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Huna I, second-generation Amora\" data-authority-id=\"895\" data-full-name=\"Rav Huna I\" data-name-he=\"רב הונא\">לְרַב הוּנָא</span>: לָא הֲוָה מָר",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "גַּבָּן בְּאוּרְתָּא בִּתְחוּמָא, דְּאָמְרִינַן מִילֵּי",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מְעַלְּיָיתָא. אֲמַר לֵיהּ: מַאי מִילֵּי מְעַלְּיָיתָא",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אָמְרִיתוּ? הַמּוֹכֵר שָׂדֶה לְאִשְׁתּוֹ – קָנְתָה, וְלָא",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אָמְרִינַן לְגַלּוֹיֵי זוּזֵי הוּא דְּבָעֵי. <span class=\"sentence\" id=\"5\" type=\"start\">&star;</span>אֲמַר לֵיהּ: פְּשִׁיטָא,",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דַּל זוּזֵי מֵהָכָא – וְתִיקְנֵי בִּשְׁטָרָא! מִי לָא תְּנַן:",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "נְכָסִים שֶׁיֵּשׁ לָהֶן אַחְרָיוּת נִקְנִין בְּכֶסֶף",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וּבִשְׁטָר וּבַחֲזָקָה? <span class=\"sentence\" id=\"6\" type=\"start\">&star;</span>אֲמַר לֵיהּ: וְלָאו אִיתְּמַר עֲלַהּ,",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Shmuel II, first-generation Amora\" data-authority-id=\"2763\" data-full-name=\"Shmuel II\" data-name-he=\"שמואל\">שְׁמוּאֵל</span>: לֹא שָׁנוּ אֶלָּא בִּשְׁטַר מַתָּנָה,",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אֲבָל בִּשְׁטַר מֶכֶר – לֹא קָנָה עַד שֶׁיִּתֵּן לוֹ",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דָּמֶיהָ? וְלָאו מוֹתֵיב <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Hamnuna II, second-generation Amora\" data-authority-id=\"977\" data-full-name=\"Rav Hamnuna II\" data-name-he=\"רב המנונא\">רַב הַמְנוּנָא</span>: בִּשְׁטָר – כֵּיצַד?",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "כָּתַב לוֹ עַל הַנְּיָיר אוֹ עַל הַחֶרֶס – אַף עַל פִּי שֶׁאֵין",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בּוֹ שָׁוֶה פְּרוּטָה: ״שָׂדִי מְכוּרָה לָךְ״, ״שָׂדִי קְנוּיָה לָךְ״ –",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הֲרֵי זוֹ מְכוּרָה וּנְתוּנָה? <span class=\"sentence\" id=\"7\" type=\"start\">&star;</span>וְלָאו הוּא מוֹתֵיב",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לַהּ וְהוּא מְפָרֵק לַהּ – בְּמוֹכֵר שָׂדֵהוּ מִפְּנֵי רָעָתָהּ?",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"8\" type=\"start\">&star;</span>(<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Beivai II, fourth-generation Amora\" data-authority-id=\"600\" data-full-name=\"Rav Beivai II\" data-name-he=\"רב ביבי\">רַב בִּיבִי</span> מְסַיֵּים בַּהּ מִשְּׁמֵיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Naḥman bar Ya’akov, third-generation Amora\" data-authority-id=\"2285\" data-full-name=\"Rav Naḥman bar Ya’akov\" data-name-he=\"רב נחמן בר יעקב\">דְּרַב נַחְמָן</span>)",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Ashi, sixth-generation Amora\" data-authority-id=\"571\" data-full-name=\"Rav Ashi\" data-name-he=\"רב אשי\">וְרַב אָשֵׁי</span> אָמַר: בְּמַתָּנָה בִּקֵּשׁ לִיתְּנָהּ לוֹ,",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וְלָמָּה כָּתַב לוֹ בִּלְשׁוֹן מֶכֶר? כְּדֵי לְיַפּוֹת כֹּחוֹ.",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"9\" type=\"start\">&star;</span>מֵיתִיבִי: לָוָה מִן הָעֶבֶד, וְשִׁחְרְרוֹ; מִן הָאִשָּׁה, וְגֵרְשָׁהּ –",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אֵין לָהֶן עָלָיו כְּלוּם. מַאי טַעְמָא? לָאו",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מִשּׁוּם דְּאָמְרִינַן: לְגַלּוֹיֵי זוּזֵי הוּא דְּבָעֵי? <span class=\"sentence\" id=\"10\" type=\"start\">&star;</span>שָׁאנֵי",
      "segment_ids": [
        10
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הָתָם, דְּלָא נִיחָא לֵיהּ לְשַׁוּוֹיֵיהּ נַפְשֵׁיהּ",
      "segment_ids": [
        10
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "״עֶבֶד לֹוֶה לְאִישׁ מַלְוֶה״. <span class=\"sentence\" id=\"11\" type=\"start\">&star;</span>שְׁלַח <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Huna bar Avin, fourth-generation Amora\" data-authority-id=\"899\" data-full-name=\"Rav Huna bar Avin\" data-name-he=\"רב הונא בר אבין\" data-crossline-group=\"name-ref-crossline-4810\">רַב הוּנָא</span>",
      "segment_ids": [
        11
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Huna bar Avin, fourth-generation Amora\" data-authority-id=\"899\" data-full-name=\"Rav Huna bar Avin\" data-name-he=\"רב הונא בר אבין\" data-crossline-group=\"name-ref-crossline-4810\">בַּר אָבִין</span>: הַמּוֹכֵר שָׂדֶה לְאִשְׁתּוֹ – קָנְתָה,",
      "segment_ids": [
        11
      ]
    }
  ],
