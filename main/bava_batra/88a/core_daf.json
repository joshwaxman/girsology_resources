  "tosafot": [
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "<big><b><span class=\"dh-divergent\">מר</span> סָבַר: גַּזְלָן הָוֵי.</b></big> וחייב להחזירה ליד הבעלים תימה הא תנן בהגוזל",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "410px",
      "right": "",
      "left": "0px",
      "text": "בתרא (<a href=\"/bava_kamma/118a\">ב&quot;ק דף קיח.</a>) גבי הגונב טלה מן העדר ולא ידעו בעלים",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "לא בגניבתו ולא בחזירתו ומנו הצאן והיא שלמה פטור וא\"ר יוחנן",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "לדעת מנין פוטר שלא לדעת אפילו מנין לא צריך א\"כ ה\"נ הכא",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אף על גב דגזלן הוי כשהחזירה ליד",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "התינוק שלקחה הימנו יהיה פטור",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אומר ר\"י שאני התם דמחזירה",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "למקום המשתמר אבל הכא מאבדה",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בידים שמוסרה ליד התינוק כדאמרי'",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לעיל דאבידה מדעת היא.",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<big><b>לעשרו אי אפשר מפני כו</b></big>.",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "130px",
      "right": "",
      "left": "0px",
      "text": "במעשר ראשון ובמעשר",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "עני אינו מפחיתו דבדמאי מעשרן והן",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שלו אלא מפחיתו במעשר שני שחייב",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לאכלו בירושלים ובתרומת מעשר",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דנותנו לכהן כדאמרי' בפרק בתרא",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דסוטה (<a href=\"/sotah/48a\">דף מח.</a>). <big><b>בירא שמים",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "עסקינן כגון רב ספרא כו</b></big>. ואם",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "תאמר כשגמר בלבו לקנות היאך",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מחזיר וי\"ל דמחזיר מדעת המוכר.",
      "source_ref": "Tosafot on Bava Batra 88a:4:1",
      "gemara_segment_ids": [
        2
      ]
    }
  ],
