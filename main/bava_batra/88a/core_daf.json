      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "גַּבְרָא דְּעָל לְבֵי טַבָּחָא, אַגְבַּהּ אַטְמָא",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דְבִישְׂרָא. בַּהֲדֵי דְּקָא אַגְבַּהּ, אֲתָא פָּרָשָׁא",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מִרְמֵא מִינֵּיהּ. אֲתָא לְקַמֵּיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yeimar, sixth and seventh-generation Amora\" data-authority-id=\"1804\" data-full-name=\"Rav Yeimar\" data-name-he=\"רב יימר\">דְּרַב יֵימַר</span>, חַיְּיבֵיהּ",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לְשַׁלּוֹמֵי דְּמָיהּ. וְהָנֵי מִילֵּי הוּא דְּקַיְצִי דְּמָיהּ.",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "<span class=\"sentence\" id=\"6\" type=\"start\">☆</span><span class=\"ein_mishpat_marker\" data-ein-mishpat-id=\"5\" data-marker-letter=\"ו\">ו</span>הַהוּא גַּבְרָא דְּאַיְיתִי קָארֵי לְפוּם נַהֲרָא. אֲתוֹ כּוּלֵּי עָלְמָא, שְׁקוּל קָרָא קָרָא. אֲמַר",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "לְהוּ: הֲרֵי הֵן מוּקְדָּשִׁין לַשָּׁמַיִם. <span class=\"sentence\" id=\"7\" type=\"start\">☆</span>אֲתוֹ לְקַמֵּיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Kahana This name is ambiguous; click to compare candidates\" data-full-name=\"Rav Kahana\" data-name-he=\"רַב כָּהֲנָא\" data-ambiguous-key=\"rav-kahana-ambiguous\" data-ambiguous-name-he=\"רַב כָּהֲנָא\" data-ambiguous-name-en=\"Rav Kahana\" data-ambiguous-candidate-ids=\"2006\" data-resolution-rule=\"rav_kahana_candidate_pool_reduction\" data-resolution-explanation=\"Narrowed this ambiguous Rav Kahana reference to Rav Kahana IV.\" data-resolution-reasons=\"[{&quot;type&quot;:&quot;method&quot;,&quot;label&quot;:&quot;Heuristics applied&quot;,&quot;detail&quot;:&quot;location_based_elimination:pum_nehara_rav_kahana_iv&quot;,&quot;attribution&quot;:&quot;Girsology review workbook&quot;},{&quot;type&quot;:&quot;status&quot;,&quot;label&quot;:&quot;Heuristics not yet applied&quot;,&quot;detail&quot;:&quot;page_level_toledot_citation_index ,  same_sugya_carryover_coreference ,  cross_sugya_parallel_text&quot;,&quot;attribution&quot;:&quot;Girsology review workbook&quot;}]\">דְּרַב כָּהֲנָא</span>, אֲמַר <span class=\"ein_mishpat_marker\" data-ein-mishpat-id=\"6\" data-marker-letter=\"ז\">ז</span>לְהוּ: אֵין אָדָם",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "מַקְדִּישׁ דָּבָר שֶׁאֵינוֹ שֶׁלּוֹ. וְהָנֵי מִילֵּי <span class=\"ein_mishpat_marker\" data-ein-mishpat-id=\"7\" data-marker-letter=\"ח\">ח</span>הוּא דְּקַיְצִי דְּמַיְיהוּ, אֲבָל לָא קַיְצִי דְּמַיְיהוּ – בִּרְשׁוּת",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "מָרַיְיהוּ קָיְימִי, וְשַׁפִּיר אַקְדֵּישׁ. <span class=\"sugya-marker sugya-marker-steinsaltz\" data-sentence-id=\"8\" data-sugya-id=\"314\" data-sugya-kind=\"steinsaltz\">§</span> <span class=\"sentence\" id=\"8\" type=\"start\">☆</span>תָּנוּ רַבָּנַן: <span class=\"ein_mishpat_marker\" data-ein-mishpat-id=\"8\" data-marker-letter=\"ט\">ט</span>הַלּוֹקֵחַ יָרָק מִן הַשּׁוּק, וּבֵירַר וְהִנִּיחַ –",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "אֲפִילּוּ כׇּל הַיּוֹם כּוּלּוֹ, לֹא קָנָה וְלֹא נִתְחַיֵּיב בְּמַעֲשֵׂר. <span class=\"sentence\" id=\"9\" type=\"start\">&star;</span>גָּמַר בְּלִבּוֹ לִקְנוֹתוֹ – קָנָה",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "וְנִתְחַיֵּיב בְּמַעֲשֵׂר. לְהַחְזִירוֹ אִי אֶפְשָׁר – שֶׁכְּבָר נִתְחַיֵּיב בְּמַעֲשֵׂר, וּלְעַשְּׂרוֹ אִי אֶפְשָׁר –",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "שֶׁכְּבָר מַפְחִיתָן בְּדָמִים. הָא כֵּיצַד? מְעַשְּׂרוֹ, וְנוֹתֵן לוֹ דְּמֵי מַעֲשֵׂר. <span class=\"sentence\" id=\"10\" type=\"start\">&star;</span>אַטּוּ",
      "segment_ids": [
        10
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "מִשּׁוּם דְּגָמַר בְּלִבּוֹ לִקְנוֹת, קָנָה וְנִתְחַיֵּיב בְּמַעֲשֵׂר?! אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabbi Oshaya I, first-generation II Amora\" data-authority-id=\"239\" data-full-name=\"Rabbi Oshaya I\" data-name-he=\"רבי אושעיא רבה\">רַב הוֹשַׁעְיָא</span>: הָכָא",
      "segment_ids": [
        10
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "בִּירֵא <span class=\"ein_mishpat_marker\" data-ein-mishpat-id=\"9\" data-marker-letter=\"י\">י</span>שָׁמַיִם עָסְקִינַן, כְּגוֹן <span class=\"name-reference-marker name-reference-amora\" data-authority-id=\"2398\" data-full-name=\"Rav Safra\" data-name-he=\"רב ספרא\" data-sage-type=\"amora\" title=\"Rav Safra, third and fourth-generation Amora\">רַב סָפְרָא</span>, דְּקַיֵּים בְּנַפְשֵׁיהּ ״וְדֹבֵר אֱמֶת בִּלְבָבוֹ״<span class=\"sugya-marker sugya-marker-vilna-piska\" data-raw-symbol=\"׃\" data-sugya-id=\"329\" data-sugya-kind=\"vilna-piska\">׃</span>",
      "segment_ids": [
        10
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "<span class=\"sugya-marker sugya-marker-steinsaltz\" data-sentence-id=\"11\" data-steinsaltz-label=\"א\" data-sugya-id=\"315\" data-sugya-kind=\"steinsaltz\"></span> <span class=\"sentence\" id=\"11\" type=\"start\">☆</span><big><strong>מַתְנִי׳</strong></big> <span class=\"ein_mishpat_marker\" data-ein-mishpat-id=\"10\" data-marker-letter=\"כ\">כ</span>הַסִּיטוֹן מְקַנֵּחַ מִדּוֹתָיו אֶחָד לִשְׁלשִׁים יוֹם. וּבַעַל הַבַּיִת, אֶחָד לִשְׁנֵים",
      "segment_ids": [
        11
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "עָשָׂר חֹדֶשׁ. <span class=\"name-reference-marker name-reference-tanna\" data-authority-id=\"2852\" data-full-name=\"Rabban Shimon ben Gamliel II\" data-name-he=\"רבן שמעון בן גמליאל\" data-sage-type=\"tanna\" title=\"Rabban Shimon ben Gamliel II, fifth-generation Tanna\">רַבָּן שִׁמְעוֹן בֶּן גַּמְלִיאֵל</span> אוֹמֵר: חִילּוּף הַדְּבָרִים. <span class=\"sentence\" id=\"12\" type=\"start\">☆</span><span class=\"ein_mishpat_marker\" data-ein-mishpat-id=\"11\" data-marker-letter=\"ל\">ל</span>חֶנְווֹנִי, מְקַנֵּחַ מִדּוֹתָיו",
      "segment_ids": [
        12
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "פַּעֲמַיִם בְּשַׁבָּת, וּמְמַחֶה <span class=\"ein_mishpat_marker\" data-ein-mishpat-id=\"12\" data-marker-letter=\"מ\">מ</span>מִשְׁקְלוֹתָיו פַּעַם אַחַת בְּשַׁבָּת, וּמְקַנֵּח <span class=\"ein_mishpat_marker\" data-ein-mishpat-id=\"13\" data-marker-letter=\"נ\">נ</span>מֹאזְנַיִם עַל",
      "segment_ids": [
        12
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "כׇּל מִשְׁקָל וּמִשְׁקָל. אָמַר <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabban Shimon ben Gamliel II, fifth-generation Tanna\" data-authority-id=\"2852\" data-full-name=\"Rabban Shimon ben Gamliel II\" data-name-he=\"רבן שמעון בן גמליאל\">רַבָּן שִׁמְעוֹן בֶּן גַּמְלִיאֵל</span>: בַּמֶּה דְּבָרִים אֲמוּרִים – בְּלַח, אֲבָל בְּיָבֵשׁ – אֵינוֹ צָרִיךְ.",
      "segment_ids": [
        12
      ]
    }
  ],
