  ],
  "tosafot": [
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "<big><b><span class=\"dh-divergent\">ואי</span> <span class=\"dh-divergent\">טעין</span> <span class=\"dh-divergent\">ואמר</span> <span class=\"dh-divergent\">לפירות</span> <span class=\"dh-divergent\">ירדתי</span> <span class=\"dh-divergent\">כו</span>.</b></big> פי' תחלה כי א\"ל מאי בעית",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "400px",
      "right": "50px",
      "left": "",
      "text": "בהאי ארעא אע\"ג דבשעה שאכל היה בעל השדה יכול לעכב",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "ולא היה נאמן לומר לפירות הורדתני מיהו כיון שכבר אכלו וזה בא",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "להוציא נאמן לומר לפירות ירדתי וא\"ת מאי איריא משום דלא חציף",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "תיפוק ליה משום דתפיס מידי דהוה",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אמטלטלין שאין עשויין להשאיל",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ולהשכיר דאי אמר לקוחין הן בידי",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "נאמן וי\"ל דאיצטריך טעמא דלא חציף",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אם לקטן והניח ברשות שאינן שלו",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דלא תפיס בהן וא\"ת כי לא אמר נמי",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לפירות ירדתי אלא דאייתי סהדי דאכל",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ב' שנים כי הך דשמעתין יהא נאמן",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בטענתיה במיגו דאי בעי אמר לפירות",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ירדתי לאו פירכא היא דאין זה מיגו",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שהרי בא לתבוע גם הקרקע ודוקא",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "פירי דתרתי שנין הדרי אבל פירי",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דשנה שלישית לא הדרי דאי מהימן",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "במאי דאמר שאכלה שלש שנין גם",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הקרקע תהיה שלו.",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<big><b>איזיל ואגדריה לדיקלא</b></big>. פי' לגדור",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "170px",
      "right": "80px",
      "left": "",
      "text": "תמרים שעל הדקל דגדירה",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שייכא בתמרים ולא איירי בקציצת",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הדקל דא\"כ ה\"ל למימר ואיקטליה",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כדאמרי' בפ' כל הנשבעין (שבועות דף",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מו. ושם) אר\"נ האי מאן דנקיט נרגא",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ואמר איזיל ואקטליה לדיקלא דפלניא",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כו' ונראה לר\"י ולריב\"ם שאם היה",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בא לקצוץ הדקל עצמו לא היה נאמן",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דדוקא פירות הוא דעבדי אינשי",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דמזבני אבל דקל אין דרך בני אדם",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "למכור לקוץ תדע דאמרי' בפ' החובל",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "(ב\"ק דף צא: ושם) שורי הרגת נטיעותי",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "קצצת אתה אמרת לי להרגו אתה",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אמרת לי לקצצו פטור ופריך א\"כ לא",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שבקת חיי לכל בריה וכו' משמע דאינו",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "נאמן במיגו דאי בעי אמר מכרת לי",
      "source_ref": "Tosafot on Bava Batra 33b:5:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לקצצו. <big><b>לָא <span class=\"dh-divergent\">חציף</span> <span class=\"dh-divergent\">איניש</span>.</b></big> לאו משום",
      "source_ref": "Tosafot on Bava Batra 33b:5:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "דקאמר בפרהסיא איזיל ואיגדריה קאמר דלא חציף דאפילו ליקט",
      "source_ref": "Tosafot on Bava Batra 33b:5:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "בצנעא נמי שייך לא חציף איניש אם לא שלקחם דרך גניבה.",
      "source_ref": "Tosafot on Bava Batra 33b:5:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "<big><b>אי הכי אפילו ארעא נמי</b></big>. למאי דפרישית לעיל דאינו נאמן אלא",
      "source_ref": "Tosafot on Bava Batra 33b:5:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "410px",
      "right": "40px",
      "left": "",
      "text": "בפירות שלקט כבר אבל מכאן ואילך אינו נאמן אפילו בפירות",
      "source_ref": "Tosafot on Bava Batra 33b:5:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "אע\"ג דשטרא בפירי לא עבדי אינשי צריך לפרש אפילו ארעא אם",
      "source_ref": "Tosafot on Bava Batra 33b:5:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "הוא טוען שהקרקע שלו שלקחה לא יחזיר פירות שכבר אכל אבל",
      "source_ref": "Tosafot on Bava Batra 33b:5:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "קרקע פשיטא שיחזיר דאינו נאמן להבא. <big><b>הַיְינוּ נְסָכָא <span class=\"dh-divergent\">דר&#x27;</span> אַבָּא.</b></big> לא",
      "source_ref": "Tosafot on Bava Batra 33b:7:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "אקרקע קאי דפשיטא שמחזיר הקרקע אחר שאין לו שנים עדים אלא",
      "source_ref": "Tosafot on Bava Batra 33b:7:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "השתא נמי אפירי מסיק וסבר השתא כאילו חד סהדא לאורועי למחזיק",
      "source_ref": "Tosafot on Bava Batra 33b:7:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "קאתי על הפירות שאכל ואינו יכול לכפור ולימא לא אכלתי וכאילו בא",
      "source_ref": "Tosafot on Bava Batra 33b:7:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "לחייבו שבועה על הפירות אם יכפור ויאמר לא אכלתי ואע\"פ שמעיד",
      "source_ref": "Tosafot on Bava Batra 33b:7:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "שהחזיק בה ג' שנים כיון דאין אחר עמו הרי כאילו אינו מעיד על",
      "source_ref": "Tosafot on Bava Batra 33b:7:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "החזקה אלא נעשה עד אחד לתובעו פירות הכי ס\"ד וטועה עד דאמר",
      "source_ref": "Tosafot on Bava Batra 33b:7:1",
      "gemara_segment_ids": [
        7
      ]
    }
  ]
}