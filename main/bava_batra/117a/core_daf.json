  "tosafot": [
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "<big><b>וּמַחְזִירִין אֵצֶל אֲבִיהֶן, וְחוֹזְרִין וְחוֹלְקִין בְּשָׁוֶה.</b></big> . בפירוש חומש פרש''י",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "360px",
      "right": "",
      "left": "0px",
      "text": "דמחזירין אצל אבי אביהן ורוצה לפרש אדם שיצא",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "ממצרים ולו שני בנים ולאותן שני בנים לזה בן אחד ולזה שלשה (הגהת דבש תמר)",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "והשתא כשמחזירין לאבי אביהן יש לחזור ולחלוק בשוה שמכחו באין",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ואין לו לירש לזה יותר מלזה שאם",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לא יצא אבי אביהן ממצרים אלא",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אבותיהן עצמן למה יחלקו בשוה",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "כשמחזיר כל אחד לאביו הלא כל אב",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "יחזיר ויוריש לבניו ולא לבני אחיו",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "הא דקאמר הכא משל לב' אחים",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "כהנים ואין מזכיר אביהן לא נקטינהו",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אלא למשל בעלמא וקשה דלפירוש זה",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "היה למיכתב לשמות מטות אבות",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אבותם דכשאין אבי אבות אלא אבות",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לבדם לא נפקא מינה מידי בחזרה",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ועוד בתוספתא שהביא רבינו שמואל",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לא קתני אלא שני אחין שהיו מיוצאי",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מצרים לזה יש לו ט' וכו' ולא קתני",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שני אחין ואביהן ונראה לריב''א",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דגזרת הכתוב הוא כשמחזירין אצל",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אביהן שחולקין אותו שני אחין בשוה",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אע''ג דבעלמא אין הדין כך הכא",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "גזרת הכתוב מהנך שני מקראות",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ודקאמר מתים יורשים את החיים לאו",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "כדין ירושה ממש אלא כעין ירושה",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "וא''ת מאי נפקא מינה בין למאן דאמר",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "ליוצאי מצרים נתחלקה הארץ בין למאן דאמר לבאי הארץ נתחלקה",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "דהשתא כשמחזירין כל באי הארץ לאבותיהן כל מה שנטלו והאבות",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "יחלקו בשוה הרי הוא כאילו ליוצאי מצרים נתחלקה וי''ל דדוקא כשהן",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "אחין חוזרין וחולקין בשוה אבל אם אינן אחין לא ואם לזה תשעה",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "בנים ולזה אחד זה נוטל ט' לתכים וזה נוטל לתך אחד אבל למאן",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "דאמר ליוצאי מצרים כולן נוטלין בשוה והא דפ''ה דראובן ושמעון",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "שיצאו ממצרים והולידו בנים במדבר זה עשרה וזה אחד אי אזלינן",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "בתר יוצאי מצרים היה נוטל האחד כנגד כולן אבל עכשיו י' נוטלים",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "עשרה והאחד נוטל חלק אחד לא מיירי בראובן ושמעון אחים דא''כ",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "גם למ''ד לבאי הארץ היו חולקין בשוה אלא נכרים הם ור''ת מפרש",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "דכשהבנים מחזירין לאבותיהן כל אבות ישראל חולקין בשוה ונפקא",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "מינה בין למ''ד ליוצאי מצרים בין למ''ד לבאי הארץ לענין טפלים",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "שאם היו האבות בני עשרים מיוצאי מצרים ומתו במדבר ובניהן",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "כשנכנסו לארץ כולם טפלים או נשים כבנות צלפחד למאן דאמר",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "ליוצאי מצרים נתחלקה היו נוטלין ולמ''ד לבאי הארץ לא היו נוטלים",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "כלום או איפכא אם יצאו ממצרים טפלים ולא אבות וכשבאו לארץ היו",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "בני עשרים או הם או בניהם למאן דאמר לבאי הארץ נוטלין ולמאן",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "דאמר ליוצאי מצרים אין נוטלין וקשיא לפירושו דאמאי נקט בתוספתא",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "שני אחין ועוד קשיא לריב''ם דלשמות מטות אבותם משמע אחין",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "דוקא דבכל מקום קוראין לאחין אבות כגון לא יומתו אבות על",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "בנים ומפקינן (<a href=\"/sanhedrin/27b\">סנהדרין דף כז:</a>) דבן אחיו פסול לו לעדות וגם",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "מבנים לא יומתו על אבות נפקא לן (שם) דאחי האב פסול וגם",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "משם יש להוכיח שיש להחזיר אצל האבות ולא אצל אבי אביהן",
      "source_ref": "Tosafot on Bava Batra 117a:4:1",
      "gemara_segment_ids": [
        2
      ]
    }
  ]
}