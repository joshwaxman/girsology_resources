x","left":"","text":""},{"width":"930px","right":"0px","left":"","text":""},{"width":"930px","right":"0px","left":"","text":""},{"width":"930px","right":"0px","left":"","text":""},{"width":"930px","right":"0px","left":"","text":""},{"width":"930px","right":"0px","left":"","text":""},{"width":"930px","right":"0px","left":"","text":""},{"width":"930px","right":"0px","left":"","text":""},{"width":"930px","right":"0px","left":"","text":""},{"width":"930px","right":"0px","left":"","text":""},{"width":"930px","right":"0px","left":"","text":""}],"vilna_piskaot":[{"id":339,"symbol":"׃","raw_symbol":"׃","line_number":4,"mishnah_ref":"Bava Batra 92a","mishnah_href":"/bava_batra/92a#gemara-line-1","mishnah_line_number":1,"quote_text":"הַמּוֹכֵר פֵּירוֹת לַחֲבֵרוֹ, וּזְרָעָן וְלֹא צִמֵּחוּ; וַאֲפִילּוּ זֶרַע פִּשְׁתָּן – אֵינוֹ חַיָּיב בְּאַחְרָיוּתָן. רַבָּן שִׁמְעוֹן בֶּן גַּמְלִיאֵל אוֹמֵר: זֵרְעוֹנֵי גִּינָּה שֶׁאֵינָן נֶאֱכָלִין, חַיָּיב בְּאַחְרָיוּתָן"}],"steinsaltz_sugyot":[{"id":332,"sentence_id":0,"line_number":1,"label":"א"},{"id":333,"sentence_id":1,"line_number":4,"label":"ב"}],"tosafot":[{"width":"450px","right":"","left":"0px","text":"<big><b><span class=\"dh-divergent\">המוכר</span> <span class=\"dh-divergent\">פירות.</span> זֵרְעוֹנֵי גִּינָּה <span class=\"dh-divergent\">שאינם</span> <span class=\"dh-divergent\">נאכלים</span> חַיָּיב בְּאַחְרָיוּתָן.</b></big>","source_ref":"Tosafot on Bava Batra 92a:1:1","gemara_segment_ids":[0]},{"width":"390px","right":"","left":"0px","text":"תימה אמאי חייב באחריותן לימה ליה מה שלא צמחו","source_ref":"Tosafot on Bava Batra 92a:1:1","gemara_segment_ids":[0]},{"width":"450px","right":"","left":"0px","text":"לפי שלא זרעת אותם בזמן שהיו ראוים לזריעה דהכי אמרי' בהמקבל","source_ref":"Tosafot on Bava Batra 92a:1:1","gemara_segment_ids":[0]},{"width":"450px","right":"","left":"0px","text":"(<a href=\"/bava_metzia/105b\">ב&quot;מ דף קה:</a>) דתנן המקבל שדה מחבירו ואכלה חגב או נשדפה אם","source_ref":"Tosafot on Bava Batra 92a:1:1","g