      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Pappeyas, third-generation Tanna\" data-authority-id=\"2534\" data-full-name=\"Rabbi Pappeyas\" data-name-he=\"רבי פפייס\" data-crossline-group=\"name-ref-crossline-16687\">פַּפְּיָיס</span> <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda ben Beteira I, second-generation Tanna\" data-authority-id=\"1423\" data-full-name=\"Rabbi Yehuda ben Beteira I\" data-name-he=\"רבי יהודה בן בתירא\">וְרַבִּי יְהוּדָה בֶּן בְּתִירָא</span> אָמְרוּ: שׁוֹנִין. וְשָׁוִין",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שֶׁאִם נָפַל לְתוֹכָן צְרוֹר אוֹ קֵיסָם, שֶׁשּׁוֹנִין. <span class=\"sentence\" id=\"2\" type=\"start\">&star;</span>תָּנֵי",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "תַּנָּא קַמֵּיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Ravina I, fifth-generation Amora\" data-authority-id=\"2646\" data-full-name=\"Ravina I\" data-name-he=\"רָבִינָא א׳\" data-resolution-rule=\"ravina_before_rav_ashi_in_same_sugya\" data-resolution-explanation=\"Resolved to Ravina I because Ravina appears before Rav Ashi in the same sugya.\" data-resolution-reasons=\"[{&quot;type&quot;:&quot;heuristic&quot;,&quot;label&quot;:&quot;Ravina before rav ashi in same sugya&quot;,&quot;detail&quot;:&quot;Resolved to Ravina I because Ravina appears before Rav Ashi in the same sugya.&quot;,&quot;attribution&quot;:&quot;Girsology disambiguation heuristics&quot;}]\">דְּרָבִינָא</span>: אֵין שׁוֹנִין קֶמַח בְּיוֹם טוֹב,",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אֲבָל נָפַל צְרוֹר אוֹ קֵיסָם — בּוֹרֵר בְּיָדוֹ. אֲמַר לֵיהּ: כׇּל",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שֶׁכֵּן דְּאָסוּר, דְּהָוֵה לֵיהּ כְּבוֹרֵר. <span class=\"sentence\" id=\"3\" type=\"start\">&star;</span>דָּרֵשׁ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rava bar Rav Huna the, fifth-generation Amora\" data-authority-id=\"2597\" data-full-name=\"Rava bar Rav Huna the\" data-name-he=\"רבא בר רב הונא זוטי\" data-crossline-group=\"name-ref-crossline-16690\">רָבָא בַּר</span>",
