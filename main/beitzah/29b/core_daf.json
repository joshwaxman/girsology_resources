      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rami bar Ḥama, third and fourth-generation Amora\" data-authority-id=\"2681\" data-full-name=\"Rami bar Ḥama\" data-name-he=\"רמי בר חמא\" data-crossline-group=\"name-ref-crossline-16697\">חָמָא</span> מָרָא דְעוֹבָדָא הֲוָה, וְאִי לָאו דַּחֲזַאי מִבֵּי",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "נָשָׁא לָא הֲוָה עָבְדָא<span class=\"sugya-marker sugya-marker-vilna-piska\" data-sugya-kind=\"vilna-piska\" data-sugya-id=\"153\" data-raw-symbol=\"׃\">׃</span> <span class=\"sugya-marker sugya-marker-steinsaltz\" data-sugya-kind=\"steinsaltz\" data-sugya-id=\"142\" data-sentence-id=\"5\" data-steinsaltz-label=\"ב\"></span> <span class=\"sentence\" id=\"5\" type=\"start\">&star;</span><big><strong>מַתְנִי׳</strong></big> הוֹלֵךְ אָדָם",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אֵצֶל חֶנְוָנִי הָרָגִיל אֶצְלוֹ וְאוֹמֵר לוֹ: תֵּן לִי בֵּיצִים",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וֶאֱגוֹזִים בְּמִנְיָן, שֶׁכֵּן דֶּרֶךְ בַּעַל הַבַּיִת לִהְיוֹת",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מוֹנֶה בְּתוֹךְ בֵּיתוֹ<span class=\"sugya-marker sugya-marker-vilna-piska\" data-sugya-kind=\"vilna-piska\" data-sugya-id=\"154\" data-raw-symbol=\"׃\">׃</span> <span class=\"sugya-marker sugya-marker-steinsaltz\" data-sugya-kind=\"steinsaltz\" data-sugya-id=\"143\" data-sentence-id=\"6\" data-steinsaltz-label=\"ג\"></span> <span class=\"sentence\" id=\"6\" type=\"start\">&star;</span><big><strong>גְּמָ׳</strong></big> תָּנוּ רַבָּנַן: הוֹלֵךְ אָדָם",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אֵצֶל רוֹעֶה הָרָגִיל אֶצְלוֹ וְאוֹמֵר לוֹ: תֵּן לִי גְּדִי",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אֶחָד אוֹ טָלֶה אֶחָד. אֵצֶל טַבָּח הָרָגִיל אֶצְלוֹ",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וְאוֹמֵר לוֹ: תֵּן לִי כַּף אַחַת אוֹ יָרֵךְ אַחַת. אֵצֶל",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "פַּטָּם הָרָגִיל אֶצְלוֹ וְאוֹמֵר לוֹ: תֵּן לִי תּוֹר אֶחָד",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אוֹ גּוֹזָל אֶחָד. אֵצֶל נַחְתּוֹם הָרָגִיל אֶצְלוֹ וְאוֹמֵר",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לוֹ: תֵּן לִי כִּכָּר אֶחָד אוֹ גְּלוּסְקָא אַחַת. <span class=\"sentence\" id=\"7\" type=\"start\">&star;</span>וְאֵצֶל",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "חֶנְוָנִי הָרָגִיל אֶצְלוֹ וְאוֹמֵר לוֹ: תֵּן לִי עֶשְׂרִים",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בֵּיצִים, אוֹ חֲמִשִּׁים אֱגוֹזִים, עֲשָׂרָה אֲפַרְסְקִין,",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וַחֲמִשָּׁה רִמּוֹנִים וְאֶתְרוֹג אֶחָד. וּבִלְבַד שֶׁלֹּא",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "יַזְכִּיר לוֹ סְכוּם מִדָּה. <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yishmael ben Elazar, sixth-generation Tanna\" data-authority-id=\"2846\" data-full-name=\"Rabbi Yishmael ben Elazar\" data-name-he=\"רבי שמעון בן אלעזר\">רַבִּי שִׁמְעוֹן בֶּן אֶלְעָזָר</span>",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אוֹמֵר: וּבִלְבַד שֶׁלֹּא יַזְכִּיר לוֹ סְכוּם מִקָּח<span class=\"sugya-marker sugya-marker-vilna-piska\" data-sugya-kind=\"vilna-piska\" data-sugya-id=\"155\" data-raw-symbol=\"׃\">׃</span>",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"8\" type=\"start\">&star;</span><br><br><big><strong>הֲדַרַן עֲלָךְ אֵין צָדִין</strong></big><br><br>",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "<span class=\"sugya-marker sugya-marker-steinsaltz\" data-sugya-kind=\"steinsaltz\" data-sugya-id=\"144\" data-sentence-id=\"9\" data-steinsaltz-label=\"א\"></span> <span class=\"sentence\" id=\"9\" type=\"start\">&star;</span><big><strong>הַמֵּבִיא</strong></big> כַּדֵּי יַיִן מִמָּקוֹם לְמָקוֹם — לֹא יְבִיאֵם בְּסַל וּבְקוּפָּה, אֲבָל",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "מֵבִיא הוּא עַל כְּתֵפוֹ אוֹ לְפָנָיו. וְכֵן הַמּוֹלִיךְ אֶת הַתֶּבֶן —",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "לֹא יַפְשִׁיל אֶת הַקּוּפָּה לַאֲחוֹרָיו, אֲבָל מְבִיאָהּ הוּא בְּיָדוֹ. וּמַתְחִילִין",
      "segment_ids": [
        9
      ]
    }
  ],
  "rashi": [
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "במדה ומכר ממנה עד שמכר חשבונו נמצא כל הנותר בחבית על ידי ברורין שהרתיח היין כשמוציאו ומעלה אופיא אישקומ\"א בלע\"ז ואין המדה מלאה והן נקראין ברורין לפי שמבררין אותן מן היין כששותה אי נמי על דקלישי וזיגי ושמן יש בו מצוי מפני שמודבק בשולי המדה ובדפנותיה וביין שכיחי ברורין ולא בשמן: <b>וחבריו כנסו כו&#x27;.</b> כדפרישית בברורין: <b>לפני</b> <b>הגזברים.</b> של הקדש לעשות בהן צרכי הקדש אם ירצו והם לא הקדישוה כסבורין אין יכולין להקדיש שאינו שלהם אי נמי יכולין הוה ליה גזל בעולה: <b>אמרו</b> <b>להם</b> <b>חכמים</b> <b>אין</b> <b>אתם</b> <b>זקוקין</b> <b>לכך.</b> הואיל ומתחלה לא נתכונתם לגזול שהלקוחות מוחלין על ידי טרדן ומרוצתם שאינם יכולין לשהות עוד וידעי וקא מחלי: <b>אף</b> <b>אנו</b> <b>אין</b> <b>רצוננו</b> <b>לכך.</b> לזה ליהנות משל אחרים: <b>אמרו</b> <b>להם.</b> חכמים א\"כ אין לכם לעשות הקדש אלא לעשות בהן צרכי רבים שהרי משל רבים היה ויהנו הבעלים מהן: <b>ואין</b> <b>יודע</b> <b>למי</b> <b>גזל.</b> שגזל אנשים הרבה: <b>שיחין</b> <b>ומערות.</b> שמתכנסין בהן מים ושותין מהן ובב\"ק (<a href=\"/bava_kamma/50b\">דף נ:</a>) מפרש מאי בור ומאי שיח ומאי מערה: <b>אדבריה.</b> הנהיגו ומטייל עמו במבואות העיר: <b>לא</b> <b>ימדוד</b> <b>אדם</b> <b>קב</b> <b>שעורין.</b> אפילו ליתן לבהמתו שנראה כמודד למכור: <b>אבל</b> <b>קודר</b> <b>הוא.</b> בקב עצמו נוקב בכרי וממלאו שלא כדרך מדה לתת בידו לתוכו: <b>קודר.</b> לשון נוקב: <b>נחתום.</b> מבשל קדרות נמי קרוי נחתום: <b>יקדיח.</b> ישרוף אאורשי\"ר בלע\"ז: <b>בעין</b> <b>יפה.</b> שיעור חלה אחד מכ\"ד לכהן וכשאינה יודעת מדת עיסתה היא מקמצת ואומרת אין כאן כל כך אבל כשיודעת מדת עיסתה יודעת מה תפריש ועינה יפה בה: <b>תנא</b> <b>דבי</b> <b>שמואל.</b> בתוספתא שסידר שמואל מתנאים שלפניו כמו שסדרו רבי חייא ורבי אושעיא וכמו שסידר רבי את המשנה: <b>השתא</b> <b>דאמר</b> <b>שמואל</b> <b>אסור.</b> והוא שנה במשנתו מותר שמואל בשמעתיה דאמר אסור הלכה למעשה אתא לאשמועינן שהבא לשאול הלכה לעשות מעשה מורין לו אסור ואי חזינן איניש דעביד לא מחינן בידיה דהלכה דמותר ואין מורין כן: <b>אין</b> <b>שונין</b> <b>קמח.</b> שרקדו מאתמול ובא לשנותו בנפה ליפותו אין שונין"
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "דאפשר לו מאתמול: <b>שׁוֹנִין</b> דליכא טרחא ודבר הנראה הוא שזו היא",
      "source_ref": "Rashi on Beitzah 29b:2:2",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "פעם שניה ואין זה כמרקד לברור: <b>תָּנֵי תַּנָּא קַמֵּיהּ דְּרָבִינָא: אֵין שׁוֹנִין.</b>",
      "source_ref": "Rashi on Beitzah 29b:3:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "ואפילו נפל לתוכן צרור או קיסם אלא בודק הקסמין והצרורות ובוררן",
      "source_ref": "Rashi on Beitzah 29b:3:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בידיו: <b>כׇּל שֶׁכֵּן דְּאָסוּר.</b> דמחזי",
      "source_ref": "Rashi on Beitzah 29b:3:2",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "כבורר ובורר אב מלאכה היא כהרקדה",
      "source_ref": "Rashi on Beitzah 29b:3:2",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "והשונה אינו מרקד שהרי נראה שהכל",
      "source_ref": "Rashi on Beitzah 29b:3:2",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "יוצא ואין כאן סובין: <b>לְאַבָּא</b> לחברי:",
      "source_ref": "Rashi on Beitzah 29b:4:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<b>שְׁקִילָא <span class=\"dh-divergent\">טיבותיך</span>.</b> אין אנו מחזיקין",
      "source_ref": "Rashi on Beitzah 29b:4:2",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לך טובה בכך נטולה היא טובתך",
      "source_ref": "Rashi on Beitzah 29b:4:2",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ומוטלת על הקוצים טיבותיך גרי\"ר",
      "source_ref": "Rashi on Beitzah 29b:4:2",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בלע\"ז: <b>מַהוֹלָתָא</b> נפות: <b>הדרן</b>",
      "source_ref": "Rashi on Beitzah 29b:4:3",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<b>בִּנְהַרְדְּעָא</b> שכולן יודעות שמותר:",
      "source_ref": "Rashi on Beitzah 29b:4:4",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<b>אַגַּבָּא דְּמַהוֹלְתָּא</b> באחורי הנפה כדי",
      "source_ref": "Rashi on Beitzah 29b:5:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לשנות: <b>רִפְתָּא מְעַלַּיְתָא.</b> אי את",
      "source_ref": "Rashi on Beitzah 29b:5:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "צריכה לשנות דשונין קמח ביום טוב:",
      "source_ref": "Rashi on Beitzah 29b:5:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<b>אַגַּבָּא דְּפָתוּרָא.</b> אחורי השלחן שיש",
      "source_ref": "Rashi on Beitzah 29b:5:3",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לו תוך שקורין טורנרוייר\"א והיא",
      "source_ref": "Rashi on Beitzah 29b:5:3",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "היתה שונה הקמח על אחוריו משום",
      "source_ref": "Rashi on Beitzah 29b:5:3",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שנוי: <b>הָא דִּידַן</b> זו אשתי ברתיה",
      "source_ref": "Rashi on Beitzah 29b:5:4",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דרמי בר חמא היא: <b>מָרָא דְעוֹבָדָא</b>",
      "source_ref": "Rashi on Beitzah 29b:5:5",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מדקדק במעשיו: <b>רוֹעֶה</b> זה המגדל",
      "source_ref": "Rashi on Beitzah 29b:7:1",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בהמות ופעמים שמוכר מהן: <b>הָרָגִיל</b>",
      "source_ref": "Rashi on Beitzah 29b:7:2",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<b>אֶצְלוֹ</b> שמתוך שרגיל אצלו מאמינו",
      "source_ref": "Rashi on Beitzah 29b:7:2",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ונותנו לו בלא פסוק דמים: <b>פַּטָּם</b>",
      "source_ref": "Rashi on Beitzah 29b:7:3",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "המפטם עופות לשון משמין: <b>סְכוּם</b>",
      "source_ref": "Rashi on Beitzah 29b:8:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<b>מִדָּה</b> קב או קבים: <b>סכום</b>",
      "source_ref": "Rashi on Beitzah 29b:8:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<b>מִקָּח.</b> דמים:",
      "source_ref": "Rashi on Beitzah 29b:8:2",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": ""
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<b>מַתְנִי׳ <span class=\"dh-divergent\">המביא</span> <span class=\"dh-divergent\">ממקום</span> <span class=\"dh-divergent\">למקום</span>.</b> בתוך",
      "source_ref": "Rashi on Beitzah 29b:10:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "התחום או ע\"י ערוב:",
      "source_ref": "Rashi on Beitzah 29b:10:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<b>לֹא יְבִיאֵם בְּסַל וּבְקוּפָּה.</b> לתת שלש",
      "source_ref": "Rashi on Beitzah 29b:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "וארבע בתוך קופה וישאם משום",
      "source_ref": "Rashi on Beitzah 29b:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דנראה כמעשה דחול לשאת משאות:",
      "source_ref": "Rashi on Beitzah 29b:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<b>אֲבָל מֵבִיא עַל כְּתֵפוֹ</b> אחת או שתים",
      "source_ref": "Rashi on Beitzah 29b:10:3",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דמוכח דלצורך י\"ט: <b>אוֹ לְפָנָיו</b> בידו:",
      "source_ref": "Rashi on Beitzah 29b:10:4",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<b>וְכֵן הַמּוֹלִיךְ אֶת הַתֶּבֶן.</b> להסק או",
      "source_ref": "Rashi on Beitzah 29b:10:5",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לבהמה לא יפשיל קופה לאחריו דגנאי",
      "source_ref": "Rashi on Beitzah 29b:10:5",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "יו\"ט שנראה כמתכוין למלאכה רבה",
      "source_ref": "Rashi on Beitzah 29b:10:5",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "או להוליך למקום רחוק כדרך חול:",
      "source_ref": "Rashi on Beitzah 29b:10:5",
      "gemara_segment_ids": [
        9
      ]
    }
  ],
