      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Ashi, sixth-generation Amora\" data-authority-id=\"571\" data-full-name=\"Rav Ashi\" data-name-he=\"רב אשי\" data-crossline-group=\"name-ref-crossline-16695\">אָשֵׁי</span>: הָא דִּידַן, בְּרַתֵּיה <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rami bar Ḥama, third and fourth-generation Amora\" data-authority-id=\"2681\" data-full-name=\"Rami bar Ḥama\" data-name-he=\"רמי בר חמא\">דְּרָמֵי בַּר חָמָא</span>, <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rami bar Ḥama, third and fourth-generation Amora\" data-authority-id=\"2681\" data-full-name=\"Rami bar Ḥama\" data-name-he=\"רמי בר חמא\" data-crossline-group=\"name-ref-crossline-16697\">וְרָמֵי בַּר</span>",
