    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yosef I, third-generation Amora\" data-authority-id=\"1764\" data-full-name=\"Rav Yosef I\" data-name-he=\"רב יוסף בר חייא\" data-crossline-group=\"name-ref-crossline-16693\">יוֹסֵף</span> נָהֲלָא קִמְחָא אַגַּבָּא דְּמַהוֹלְתָּא. אֲמַר לַהּ:",
      "segment_ids": [
        4
      ]
