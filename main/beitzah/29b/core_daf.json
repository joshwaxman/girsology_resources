    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Ashi, sixth-generation Amora\" data-authority-id=\"571\" data-full-name=\"Rav Ashi\" data-name-he=\"רב אשי\" data-crossline-group=\"name-ref-crossline-16694\">אָשֵׁי</span> נָהֲלָא קִמְחָא אַגַּבָּא דְּפָתוּרָא. אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Ashi, sixth-generation Amora\" data-authority-id=\"571\" data-full-name=\"Rav Ashi\" data-name-he=\"רב אשי\" data-crossline-group=\"name-ref-crossline-16695\">רַב</span>",
