  "tosafot": [
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "שמואל הלכה למעשה אתא לאשמועינן. פי' דאם יבא שום אדם",
      "source_ref": "Tosafot on Beitzah 29b:aligned:1",
