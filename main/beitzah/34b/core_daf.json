        0
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לְמָחָר. וַחֲכָמִים אוֹמְרִים: עַד שֶׁיִּרְשׁוֹם וְיֹאמַר",
      "segment_ids": [
        0
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מִכָּאן וְעַד כָּאן<span class=\"sugya-marker sugya-marker-vilna-piska\" data-sugya-kind=\"vilna-piska\" data-sugya-id=\"195\" data-raw-symbol=\"׃\">׃</span> <span class=\"sugya-marker sugya-marker-steinsaltz\" data-sugya-kind=\"steinsaltz\" data-sugya-id=\"178\" data-sentence-id=\"1\" data-steinsaltz-label=\"א\"></span> <span class=\"sentence\" id=\"1\" type=\"start\">&star;</span><big><strong>גְּמָ׳</strong></big> תְּנַן הָתָם: תִּינוֹקוֹת",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שֶׁטָּמְנוּ תְּאֵנִים מֵעֶרֶב שַׁבָּת וְשָׁכְחוּ וְלֹא עִשְּׂרוּ —",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לְמוֹצָאֵי שַׁבָּת לֹא יֹאכְלוּ אֶלָּא אִם כֵּן",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "עִשְּׂרוּ. וּתְנַן נָמֵי: הַמַּעֲבִיר תְּאֵנִים בַּחֲצֵרוֹ לְקַצּוֹת —",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בָּנָיו וּבְנֵי בֵּיתוֹ אוֹכְלִין מֵהֶן עֲרַאי",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וּפְטוּרִים. <span class=\"sentence\" id=\"2\" type=\"start\">&star;</span>בְּעָא מִנֵּיהּ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rava, fourth-generation Amora\" data-authority-id=\"2582\" data-full-name=\"Rava\" data-name-he=\"רָבָא\">רָבָא</span> <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Naḥman bar Ya’akov, third-generation Amora\" data-authority-id=\"2285\" data-full-name=\"Rav Naḥman bar Ya’akov\" data-name-he=\"רב נחמן בר יעקב\">מֵרַב נַחְמָן</span>: שַׁבָּת, מַהוּ",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שֶׁתִּקְבַּע מוּקְצֶה לְמַעֲשֵׂר בְּדָבָר שֶׁלֹּא נִגְמְרָה",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מְלַאכְתּוֹ? מִי אָמְרִינַן, כֵּיוָן דִּכְתִיב: ״וְקָרָאתָ",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לַשַּׁבָּת עוֹנֶג״, קָבְעָה וַאֲפִילּוּ בְּדָבָר שֶׁלֹּא נִגְמְרָה",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מְלַאכְתּוֹ, אוֹ דִלְמָא: בְּדָבָר שֶׁנִּגְמְרָה מְלַאכְתּוֹ —",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "קָבְעָה, בְּדָבָר שֶׁלֹּא נִגְמְרָה מְלַאכְתּוֹ — לָא קָבְעָה? <span class=\"sentence\" id=\"3\" type=\"start\">&star;</span>אֲמַר",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לֵיהּ: שַׁבָּת קוֹבַעַת, בֵּין בְּדָבָר שֶׁנִּגְמְרָה מְלַאכְתּוֹ,",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בֵּין בְּדָבָר שֶׁלֹּא נִגְמְרָה מְלַאכְתּוֹ. אֲמַר לֵיהּ: וְאֵימָא",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שַׁבָּת דּוּמְיָא דְחָצֵר, מָה חָצֵר — אֵינָהּ קוֹבַעַת",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אֶלָּא בְּדָבָר שֶׁנִּגְמְרָה מְלַאכְתּוֹ, אַף שַׁבָּת — לֹא",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "תִּקְבַּע אֶלָּא בְּדָבָר שֶׁנִּגְמְרָה מְלַאכְתּוֹ! אֲמַר לֵיהּ:",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "תַּלְמוּד עָרוּךְ הוּא בְּיָדֵינוּ שֶׁהַשַּׁבָּת קוֹבַעַת,",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בֵּין בְּדָבָר שֶׁנִּגְמְרָה מְלַאכְתּוֹ, בֵּין בְּדָבָר",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שֶׁלֹּא נִגְמְרָה מְלַאכְתּוֹ. <span class=\"sentence\" id=\"4\" type=\"start\">&star;</span>אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Zutra, son of Rav Naḥman, fourth-generation Amora\" data-authority-id=\"2165\" data-full-name=\"Zutra, son of Rav Naḥman\" data-name-he=\"מר זוטרא בריה דרב נחמן\" data-crossline-group=\"name-ref-crossline-16856\">מָר זוּטְרָא בְּרֵיהּ</span>",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Zutra, son of Rav Naḥman, fourth-generation Amora\" data-authority-id=\"2165\" data-full-name=\"Zutra, son of Rav Naḥman\" data-name-he=\"מר זוטרא בריה דרב נחמן\" data-crossline-group=\"name-ref-crossline-16856\">דְּרַב נַחְמָן</span>: אַף אֲנַן נָמֵי תְּנֵינָא, וְעוֹד אָמַר <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Eliezer ben Hyrcanus, third-generation Tanna\" data-authority-id=\"417\" data-full-name=\"Rabbi Eliezer ben Hyrcanus\" data-name-he=\"רבי אליעזר בן הורקנוס\" data-crossline-group=\"name-ref-crossline-16857\">רַבִּי</span>",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Eliezer ben Hyrcanus, third-generation Tanna\" data-authority-id=\"417\" data-full-name=\"Rabbi Eliezer ben Hyrcanus\" data-name-he=\"רבי אליעזר בן הורקנוס\" data-crossline-group=\"name-ref-crossline-16857\">אֱלִיעֶזֶר</span>: עוֹמֵד אָדָם עַל הַמּוּקְצֶה עֶרֶב שַׁבָּת",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בַּשְּׁבִיעִית וְכוּ׳. טַעְמָא דִּשְׁבִיעִית — דְּלָאו",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בַּר עַשּׂוֹרֵי הוּא, הָא בִּשְׁאָר שְׁנֵי שָׁבוּעַ — הָכִי",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "נָמֵי דְּאָסוּר, מַאי טַעְמָא — לָאו מִשּׁוּם דְּשַׁבָּת קָבְעָה?",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"5\" type=\"start\">&star;</span>לָא, שָׁאנֵי הָתָם, כֵּיוָן דְּאָמַר: ״מִכָּאן אֲנִי אוֹכֵל לְמָחָר״ —",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "קָבַע לֵיהּ עִלָּוֵיהּ. אִי הָכִי מַאי אִרְיָא",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שַׁבָּת, אֲפִילּוּ בְּחוֹל נָמֵי! הָא קָא מַשְׁמַע לַן דְּטֶבֶל מוּכָן",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הוּא אֵצֶל שַׁבָּת, שֶׁאִם עָבַר וְתִקְּנוֹ — מְתוּקָּן.",
      "segment_ids": [
        5
      ]
    }
