      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "אלא מר אשמעינן חדא ומר אשמעינן חדא ולא פליגי מתניתא קמייתא",
      "source_ref": "Rashi on Beitzah 12a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
