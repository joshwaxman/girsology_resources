    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sugya-marker sugya-marker-steinsaltz\" data-sugya-kind=\"steinsaltz\" data-sugya-id=\"1\" data-sentence-id=\"2\" data-steinsaltz-label=\"ב\"></span> <span class=\"sentence\" id=\"2\" type=\"start\">&star;</span><big><strong>גְּמָ׳</strong></big> בְּמַאי עָסְקִינַן? אִילֵימָא בְּתַרְנְגוֹלֶת הָעוֹמֶדֶת",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לַאֲכִילָה, מַאי טַעְמַיְיהוּ <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Beit Hillel, first and second-generation Tanna\" data-authority-id=\"963\" data-full-name=\"Beit Hillel\" data-name-he=\"בית הלל\">דְּבֵית הִלֵּל</span>? אוּכְלָא",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דְּאִפְּרַת הוּא! <span class=\"sentence\" id=\"3\" type=\"start\">&star;</span>אֶלָּא, בְּתַרְנְגוֹלֶת הָעוֹמֶדֶת לְגַדֵּל",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בֵּיצִים. <span class=\"sentence\" id=\"4\" type=\"start\">&star;</span>מַאי טַעְמַיְיהוּ <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Beit Shammai, first and second-generation Tanna\" data-authority-id=\"2756\" data-full-name=\"Beit Shammai\" data-name-he=\"בית שמאי\">דְּבֵית שַׁמַּאי</span>? מוּקְצֶה",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הִיא! וּמַאי קוּשְׁיָא? דִּלְמָא <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Beit Shammai, first and second-generation Tanna\" data-authority-id=\"2756\" data-full-name=\"Beit Shammai\" data-name-he=\"בית שמאי\">בֵּית שַׁמַּאי</span> לֵית",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לְהוּ מוּקְצֶה! <span class=\"sentence\" id=\"5\" type=\"start\">&star;</span>קָא סָלְקָא דַּעְתִּין: אֲפִלּוּ מַאן",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דְּשָׁרֵי בְּמוּקְצֶה, בְּנוֹלָד אָסַר. מַאי טַעְמַיְיהוּ",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Beit Shammai, first and second-generation Tanna\" data-authority-id=\"2756\" data-full-name=\"Beit Shammai\" data-name-he=\"בית שמאי\">דְּבֵית שַׁמַּאי</span>? <span class=\"sentence\" id=\"6\" type=\"start\">&star;</span>אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Naḥman bar Ya’akov, third-generation Amora\" data-authority-id=\"2285\" data-full-name=\"Rav Naḥman bar Ya’akov\" data-name-he=\"רב נחמן בר יעקב\">רַב נַחְמָן</span>: לְעוֹלָם בְּתַרְנְגוֹלֶת",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הָעוֹמֶדֶת לְגַדֵּל בֵּיצִים, וּדְאִית לֵיהּ מוּקְצֶה —",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אִית לֵיהּ נוֹלָד, וּדְלֵית לֵיהּ מוּקְצֶה — לֵית לֵיהּ",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "נוֹלָד. <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Beit Shammai, first and second-generation Tanna\" data-authority-id=\"2756\" data-full-name=\"Beit Shammai\" data-name-he=\"בית שמאי\">בֵּית שַׁמַּאי</span> <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Shimon ben Yoḥai, fifth-generation Tanna\" data-authority-id=\"2830\" data-full-name=\"Rabbi Shimon ben Yoḥai\" data-name-he=\"רבי שמעון בן יוחאי\">כְּרַבִּי שִׁמְעוֹן</span>, <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Beit Hillel, first and second-generation Tanna\" data-authority-id=\"963\" data-full-name=\"Beit Hillel\" data-name-he=\"בית הלל\">וּבֵית הִלֵּל</span> <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda bar Rabbi Elai, fifth-generation Tanna\" data-authority-id=\"1395\" data-full-name=\"Rabbi Yehuda bar Rabbi Elai\" data-name-he=\"רבי יהודה ברבי אילעאי\" data-crossline-group=\"name-ref-crossline-15457\">כְּרַבִּי</span>",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda bar Rabbi Elai, fifth-generation Tanna\" data-authority-id=\"1395\" data-full-name=\"Rabbi Yehuda bar Rabbi Elai\" data-name-he=\"רבי יהודה ברבי אילעאי\" data-crossline-group=\"name-ref-crossline-15457\">יְהוּדָה</span>. <span class=\"sentence\" id=\"7\" type=\"start\">&star;</span>וּמִי אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Naḥman bar Ya’akov, third-generation Amora\" data-authority-id=\"2285\" data-full-name=\"Rav Naḥman bar Ya’akov\" data-name-he=\"רב נחמן בר יעקב\">רַב נַחְמָן</span> הָכִי? וְהָתְנַן: <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Beit Shammai, first and second-generation Tanna\" data-authority-id=\"2756\" data-full-name=\"Beit Shammai\" data-name-he=\"בית שמאי\">בֵּית שַׁמַּאי</span>",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אוֹמְרִים: מַגְבִּיהִין מֵעַל הַשֻּׁלְחָן עֲצָמוֹת",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וּקְלִיפִּין, <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Beit Hillel, first and second-generation Tanna\" data-authority-id=\"963\" data-full-name=\"Beit Hillel\" data-name-he=\"בית הלל\">וּבֵית הִלֵּל</span> אוֹמְרִים: מְסַלֵּק אֶת הַטַּבְלָא",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "כּוּלָּהּ וּמְנַעֲרָהּ. <span class=\"sentence\" id=\"8\" type=\"start\">&star;</span>וְאָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Naḥman bar Ya’akov, third-generation Amora\" data-authority-id=\"2285\" data-full-name=\"Rav Naḥman bar Ya’akov\" data-name-he=\"רב נחמן בר יעקב\">רַב נַחְמָן</span>: אָנוּ אֵין לָנוּ אֶלָּא",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Beit Shammai, first and second-generation Tanna\" data-authority-id=\"2756\" data-full-name=\"Beit Shammai\" data-name-he=\"בית שמאי\">בֵּית שַׁמַּאי</span> <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda bar Rabbi Elai, fifth-generation Tanna\" data-authority-id=\"1395\" data-full-name=\"Rabbi Yehuda bar Rabbi Elai\" data-name-he=\"רבי יהודה ברבי אילעאי\">כְּרַבִּי יְהוּדָה</span>, <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Beit Hillel, first and second-generation Tanna\" data-authority-id=\"963\" data-full-name=\"Beit Hillel\" data-name-he=\"בית הלל\">וּבֵית הִלֵּל</span> <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Shimon ben Yoḥai, fifth-generation Tanna\" data-authority-id=\"2830\" data-full-name=\"Rabbi Shimon ben Yoḥai\" data-name-he=\"רבי שמעון בן יוחאי\">כְּרַבִּי שִׁמְעוֹן</span>! <span class=\"sentence\" id=\"9\" type=\"start\">&star;</span>אָמַר",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לְךָ <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Naḥman bar Ya’akov, third-generation Amora\" data-authority-id=\"2285\" data-full-name=\"Rav Naḥman bar Ya’akov\" data-name-he=\"רב נחמן בר יעקב\">רַב נַחְמָן</span>: גַּבֵּי שַׁבָּת, דִּסְתַם לַן תְּנָא",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Shimon ben Yoḥai, fifth-generation Tanna\" data-authority-id=\"2830\" data-full-name=\"Rabbi Shimon ben Yoḥai\" data-name-he=\"רבי שמעון בן יוחאי\">כְּרַבִּי שִׁמְעוֹן</span>, דִּתְנַן: מְחַתְּכִין אֶת הַדִּלּוּעִין",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לִפְנֵי הַבְּהֵמָה, וְאֶת הַנְּבֵלָה לִפְנֵי הַכְּלָבִים —",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"10\" type=\"start\">&star;</span>מוֹקֵים לָהּ <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Beit Hillel, first and second-generation Tanna\" data-authority-id=\"963\" data-full-name=\"Beit Hillel\" data-name-he=\"בית הלל\">לְבֵית הִלֵּל</span> <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Shimon ben Yoḥai, fifth-generation Tanna\" data-authority-id=\"2830\" data-full-name=\"Rabbi Shimon ben Yoḥai\" data-name-he=\"רבי שמעון בן יוחאי\">כְּרַבִּי שִׁמְעוֹן</span>. אֲבָל",
      "segment_ids": [
        10
      ]
    }
  ],
  "rashi": [
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "<b><span class=\"dh-divergent\">ביצה</span> לֹא תֵּאָכֵל.</b> בו ביום בגמרא מפרש טעמא: <b>שאור</b> <b>בכזית.</b>",
      "source_ref": "Rashi on Beitzah 2a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "משום דהני תלת מילי הוו מקולי בית שמאי ומחומרי בית",
      "source_ref": "Rashi on Beitzah 2a:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "הלל גבי יו\"ט תנא להו גבי הדדי ובגמרא מפרש טעמייהו: <b>בְּכַכּוֹתֶבֶת</b>",
      "source_ref": "Rashi on Beitzah 2a:1:3",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "תמרה: <b>יַחְפּוֹר בַּדָּקָר.</b> פיל\"א בלע\"ז: <b>ומודים</b> <b>שאם</b> <b>שחט</b> <b>כו'.</b>",
      "source_ref": "Rashi on Beitzah 2a:2:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כדמפרש טעמא בגמ' כשיש לו דקר",
      "source_ref": "Rashi on Beitzah 2a:2:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "נעוץ מבעוד יום: <b>שֶׁאֵפֶר כִּירָה מוּכָן</b>",
      "source_ref": "Rashi on Beitzah 2a:2:3",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>הוּא</b> בגמרא בעי מאי קאמר:",
      "source_ref": "Rashi on Beitzah 2a:2:3",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b><span class=\"dh-divergent\">גמ&#x27;</span> הָעוֹמֶדֶת לַאֲכִילָה</b> שאינה",
      "source_ref": "Rashi on Beitzah 2a:3:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מוקצת: <b>אוּכְלָא דְּאִפְּרַת.</b> אוכל",
      "source_ref": "Rashi on Beitzah 2a:3:2",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שנפרד וחבירו במנחות חבורי אוכלין",
      "source_ref": "Rashi on Beitzah 2a:3:2",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כמאן דמפרתי דמו וכן בשחיטת",
      "source_ref": "Rashi on Beitzah 2a:3:2",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "חולין (<a href=\"/chullin/73a\">דף עג.</a>): <b>לֵית לְהוּ מוּקְצֶה.</b>",
      "source_ref": "Rashi on Beitzah 2a:5:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דדלמא כר' שמעון סבירא להו דאמר",
      "source_ref": "Rashi on Beitzah 2a:5:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בפרק [כירה] (<a href=\"/shabbat/44a\">שבת דף מד.</a>) מותר השמן",
      "source_ref": "Rashi on Beitzah 2a:5:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שבנר ושבקערה אסור (דברי רבי",
      "source_ref": "Rashi on Beitzah 2a:5:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "יהודה) ור\"ש מתיר: <b>קָא סָלְקָא דַּעְתִּין.</b>",
      "source_ref": "Rashi on Beitzah 2a:6:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "להכי פרכינן מאי טעמייהו דבית",
      "source_ref": "Rashi on Beitzah 2a:6:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שמאי דקא סלקא דעתין דאפי' לר'",
      "source_ref": "Rashi on Beitzah 2a:6:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שמעון דשרי במוקצה בנולד אסיר",
      "source_ref": "Rashi on Beitzah 2a:6:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דאילו במוקצה סבירא ליה לא מקצי",
      "source_ref": "Rashi on Beitzah 2a:6:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "איניש מדעתיה מידי דחזי ליה אבל",
      "source_ref": "Rashi on Beitzah 2a:6:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "נולד לא הוה ידע דנהוי דעתיה",
      "source_ref": "Rashi on Beitzah 2a:6:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "עלויה: <b>וּמִי אָמַר רַב נַחְמָן הָכִי</b>",
      "source_ref": "Rashi on Beitzah 2a:8:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דבית הלל כר' יהודה: <b>מַגְבִּיהִין.</b>",
      "source_ref": "Rashi on Beitzah 2a:8:2",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בשבת מעל השלחן עצמות שאינן",
      "source_ref": "Rashi on Beitzah 2a:8:2",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ראוין לאכילה וקליפי אגוזים ולא",
      "source_ref": "Rashi on Beitzah 2a:8:2",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "חיישינן למוקצה: <b>וּבֵית הִלֵּל אוֹמְרִים.</b>",
      "source_ref": "Rashi on Beitzah 2a:8:3",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אין מטלטלין אותן בידים שמוקצה",
      "source_ref": "Rashi on Beitzah 2a:8:3",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הן: <b><span class=\"dh-divergent\">אלא</span> מְסַלֵּק הַטַּבְלָא</b> שיש תורת",
      "source_ref": "Rashi on Beitzah 2a:8:4",
      "gemara_segment_ids": [
        8
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כלי עליה ומנערה: <b>וְאָמַר רַב נַחְמָן</b>",
      "source_ref": "Rashi on Beitzah 2a:9:1",
      "gemara_segment_ids": [
        8
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>אָנוּ אֵין לָנוּ.</b> בשיטת משנה זו לפי",
      "source_ref": "Rashi on Beitzah 2a:9:1",
      "gemara_segment_ids": [
        8
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שמוחלפת שיטתה אלא כך שמעתי",
      "source_ref": "Rashi on Beitzah 2a:9:1",
      "gemara_segment_ids": [
        8
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מרבותינו דבית שמאי כרבי יהודה",
      "source_ref": "Rashi on Beitzah 2a:9:1",
      "gemara_segment_ids": [
        8
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ומחמרי ובית הלל כרבי שמעון:",
      "source_ref": "Rashi on Beitzah 2a:9:1",
      "gemara_segment_ids": [
        8
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>מְחַתְּכִין <span class=\"dh-divergent\">דלועין</span>.</b> תלושין לפני הבהמה",
      "source_ref": "Rashi on Beitzah 2a:10:1",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ולא אמרינן טרחא דלאו צורך הוא:",
      "source_ref": "Rashi on Beitzah 2a:10:1",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>וְאֶת <span class=\"dh-divergent\">הנבילה</span> לִפְנֵי הַכְּלָבִים.</b> ואע\"פ",
      "source_ref": "Rashi on Beitzah 2a:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שנתנבלה בשבת דבין השמשות לא",
      "source_ref": "Rashi on Beitzah 2a:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "היתה עומדת לאכילת כלבים אפילו",
      "source_ref": "Rashi on Beitzah 2a:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הכי שרי דלית לן מוקצה בשבת הלכך",
      "source_ref": "Rashi on Beitzah 2a:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מגביהין מעל השלחן דמיירי בשבת",
      "source_ref": "Rashi on Beitzah 2a:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מוקים לבית הלל דנימרו כר' שמעון",
      "source_ref": "Rashi on Beitzah 2a:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כי היכי דלא תקשי הלכתא",
      "source_ref": "Rashi on Beitzah 2a:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אהלכתא דקיימא לן הלכה כסתם",
      "source_ref": "Rashi on Beitzah 2a:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "משנה וקיימא הלכה כבית",
      "source_ref": "Rashi on Beitzah 2a:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הלל אבל גבי יום טוב דאשכחן",
      "source_ref": "Rashi on Beitzah 2a:10:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דסתם רבי כרבי יהודה:",
      "source_ref": "Rashi on Beitzah 2a:10:2",
      "gemara_segment_ids": [
        9
      ]
    }
  ],
  "vilna_piskaot": [
    {
      "id": 0,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 10,
      "mishnah_ref": "Beitzah 2a",
      "mishnah_href": "/beitzah/2a#gemara-line-5",
      "mishnah_line_number": 5,
      "quote_text": "הַשּׁוֹחֵט חַיָּה וָעוֹף בְּיוֹם טוֹב, בֵּית שַׁמַּאי אוֹמְרִים: יַחְפּוֹר בַּדָּקָר וִיכַסֶּה, וּבֵית הִלֵּל אוֹמְרִים: לֹא יִשְׁחוֹט אֶלָּא אִם כֵּן הָיָה לוֹ עָפָר מוּכָן מִבְּעוֹד יוֹם. וּמוֹדִים שֶׁאִם שָׁחַט, שֶׁיַּחְפּוֹר בַּדָּקָר וִיכַסֶּה — שֶׁאֵפֶר כִּירָה מוּכָן הוּא"
    }
  ],
