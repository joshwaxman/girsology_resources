    },
    {
      "id": 120,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 5
    },
    {
      "id": 121,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 9,
      "mishnah_ref": "Beitzah 23b",
      "mishnah_href": "/beitzah/23b#gemara-line-8",
      "mishnah_line_number": 8,
      "quote_text": "רַבִּי יְהוּדָה אוֹמֵר: כׇּל הַכֵּלִים אֵין נִגְרָרִין, חוּץ מִן הָעֲגָלָה, מִפְּנֵי שֶׁהִיא כּוֹבֶשֶׁת"
    },
    {
      "id": 122,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 22
    }
  ],
  "steinsaltz_sugyot": [
    {
      "id": 106,
