  "tosafot": [
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": ""
    },
    {
      "width": "420px",
      "right": "",
      "left": "0px",
      "text": ""
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "<big><b><span class=\"dh-divergent\">איבעיא</span> לְהוּ.</b></big>",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "אבל לא גרס ר'",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "יוסי לקולא או לחומרא דא\"כ משמע",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דמספקא ליה דרבי יוסי שמא הוא",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מחמיר יותר מת\"ק ולא היא דהא",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "במלתיה דרבי יהודה נמי מספקא",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ליה היכי אתמר אלא ה\"ג היכי קאמר",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "וכו' והכי פי' כל שסמוך לעיר וגם",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אית ליה פותחת ובעי רבי יהודה",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "תרתי לחומרא דאע\"ג דסמוך בעי",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "פותחת והא דלא פי' בדבריו פותחת",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "משום דקסבר סתם קרפיפות יש להן",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "פותחת ואתא רבי יוסי למימר הואיל",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ואית להו פותחת ואפילו רחוק מן",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "העיר נמי וא\"כ שמעינן מדתלי טעמא",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דאינו סמוך שרי בפותחת מכלל",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דסמוך שרי אפילו בלא פותחת ותרתי",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לקולא קאמר רבי יוסי בסמוך בלא",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "פותחת או באינו סמוך בפותחת או",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דלמא ר' יהודה סבר כל שסמוך בין",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אית ליה פותחת בין לית ליה פותחת",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שרי דקס\"ד השתא דסתם קרפיפות",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לית להו פותחת ואתא ר' יוסי למימר",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דבעי פותחת אפילו בסמוך כ\"ש",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ברחוק אבל סמוכה בלא פותחת",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אינה מועלת כלום ע\"כ פרש\"י והקשה",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "השר מקוצי נהי דר' יהודה תלי טעמא",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בסמוכה דוקא אבל פותחת אינה",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מועלת כלום מ\"מ לרבי יוסי אמאי",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לא דייק כדפי' לעיל ללישנא קמא",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דמדתלי רבי יוסי טעמיה דשרי",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בפותחת באינו סמוך מכלל דבסמוך",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מועיל בלא פותחת דהשתא ללישנא",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "קמא דרבי יהודה דבעי תרתי קאמר",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דלרבי יוסי סגי בחדא כ\"ש להאי",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לישנא דקאמר השתא דלרבי יהודה",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "סגי בחדא בסמוך בלא פותחת ותירץ",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דע\"כ לא מצינן למימר דרבי יוסי",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "תרתי לקולא אית ליה בהאי לישנא",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "כדאמר ללישנא קמא דהואיל ולהאי",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לישנא צ\"ל דרבי יהודה לא קפיד",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אפותחת ולא ס\"ל דסתם קרפיפות",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אית להן פותחת אלא כל שסמוך בין",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "אית ליה פותחת בין לית ליה פותחת אם כן לא היה לרבי יוסי",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "למתני כל שנכנסים וכו' אלא הכי הוה ליה למתני רבי יוסי אומר",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "אם יש לו פותחת אפילו אם היה בסוף התחום שרי הא אם",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "סמוך שרי בלא פותחת ומדנקט כל משמע דיש קרפיפות דאין",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "להן פותחת רבי יוסי ודאי תלי טעמיה בפותחת דוקא בין סמוך",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "בין רחוק אבל ללישנא קמא ניחא דמצינא לפרושי דרבי יוסי",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "תרתי לקולא אמר וניחא לשון כל שנכנסין דמאי אמרת הוה ליה",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "למתני אם יש לו פותחת אדרבה אי הוה קאמר הכי הוה",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "משמע דרבי יהודה לא קמיירי בפותחת וליתא דעל כרחך רבי",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "יהודה בפותחת איירי אבל ללישנא דכל שנכנסין לו בפותחת",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "משמע דמיירי בפותחת שאם תמצי לומר דלא מיירי רבי",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "יהודה בפותחת אם כן רבי יוסי אי אמר תרתי לקולא קשיא",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "ליה דמאי כל דמשמע דאיירי רבי יהודה בפותחת אדרבה",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "רבי יהודה לא מיירי בפותחת אלא הוה ליה למתני אם יש לו",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "פותחת ולא משמע הכי לקמן מתוך פירוש רש\"י תא שמע מדקתני",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "רבי יוסי וכו' דהכי משמע מדנקט רבי יוסי לישנא דכל הנכנסין",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "ובסיפא דמלתיה אצטריך לסיים ואפילו בתוך תחום שבת ש\"מ",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "דרבי יוסי תרתי לקולא קאמר דאי רבי יוסי בפותחת תלי טעמיה",
      "source_ref": "Tosafot on Beitzah 31a:1:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
