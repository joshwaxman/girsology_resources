  "segments": [
    {
      "segment_id": 15,
      "original_text": "חַיָּיב, שֶׁהֲרֵי פָּטַר עַצְמוֹ מִכְּלוּם. אָמַר רָבָא: קַפַּחְתִּינְהוּ לְסָבֵי דְּבֵי רַב. דְּהָא רַבָּן גַּמְלִיאֵל פּוֹטֵר עַצְמוֹ מִכְּלוּם הֲוָה, וְקָאָמַר לֵיהּ רַב חִסְדָּא לְרַב הוּנָא – וְלָא קָא מְשַׁנֵּי",
      "reconstructed_text": "חַיָּיב, שֶׁהֲרֵי פָּטַר עַצְמוֹ מִכְּלוּם. ליה רב דְּהָא רַבָּן גַּמְלִיאֵל פּוֹטֵר עַצְמוֹ מִכְּלוּם הֲוָה, וְקָאָמַר לֵיהּ רַב חִסְדָּא לְרַב הוּנָא – וְלָא קָא מְשַׁנֵּי",
