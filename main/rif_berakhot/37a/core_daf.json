  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>גמ'</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "למה לי תנינא חדא זימנא שלשה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שאכלו כאחת חייבין לזמן אמר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ר' אבא אמר שמואל הכי קתני",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שלשה שישבו לאכול אע\"פ שכל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אחד ואחד אוכל מככרו לעצמו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אין רשאין ליחלק אי נמי כדרב",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הונא דאמר שלשה בני <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>אדם שבאו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "משלש חבורות אינן רשאין ליחלק",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואמר רב חסדא והוא שבאו משלש",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חבורות של שלשה שלשה בני אדם",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר רבא (דף נ:) לא אמרן אלא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דלא קדימו הנך ואזמינו עלייהו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אבל קדימו הנך ואזמינו עלייהו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פרח זימון מהני: <b><big>מתני'</big></b> (דף",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נ.) <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Blessings\" data-label=\"⚬\"></i>שתי חבורות שהיו אוכלות",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בבית אחד בזמן שמקצתן רואין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלו את אלו הרי אלו מצטרפין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לזימון ואם לאו אלו מזמנין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לעצמן ואלו מזמנין לעצמן: <b><big>גמ'",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "</big></b> (דף נ:) תנא אם היה שמש",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>ביניהם שמש מצרפן:",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>גמ'</b> הכי קתני שלשה שישבו לאכול אינן רשאין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "לחלק זהו לשון הגמרא ור\"ח והרי\"ף ז\"ל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "פירשו דה\"ק שלשה שישבו לאכול אע\"פ שכל אחד",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ואחד אוכל מככרו אינן רשאים ליחלק ומתני'",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "דשלשה חייבין השמיענו דין הזימון ומשנה זו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "באה להשמיענו שמאחר שאכלו ביחד אע\"פ שכל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אחד ואחד אוכל מככרו אינם רשאין ליחלק",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ולברך כל א' וא' בפני עצמו אלא <i data-commentator=\"Hagahot HaBach\" data-label=\"ג\" data-order=\"3\"></i>ששלשתם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מזמנין ביחד ויש להקשות על זה הפי' מדאמר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בירושלמי בתחלת זה הפרק הכא איתמר אין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רשאים ליחלק והכא איתמר חייבים לזמן שמואל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אמר כאן בתחלה כאן בסוף ואיזהו בתחלה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואיזהו בסוף תרין אמוראים חד אמר נתנו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דעתם לאכול זהו בתחלה אכלו כזית זהו סוף",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כלומר כי קתני חייבין לזמן מיירי בשאכלו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כזית והכי דקתני אינם רשאין ליחלק מיירי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בתחלה ואתא לאשמועינן אע\"פ שלא אכלו כלל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ביחד אלא שנתנו דעתם מתחלה לאכול ביחד",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אע\"פ שאח\"כ כל אחד ואחד אוכל בפני עצמו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אינם רשאין ליחלק וחד אמר אכלו כזית זהו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בתחלה גמרו אכילתן זהו סוף הנה שאין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הירושלמי כדברי הרי\"ף ז\"ל כלל שהוא אומר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דמאי דקתני אינם רשאין ליחלק לא בא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "להשמיענו אלא שאף על פי שכל אחד ואחד אוכל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מככרו כיון שישבו מתחלה ביחד אינם רשאין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ליחלק ואינו מעמיד המשנה בתחלה אלא אפי'",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בשגמרו אכילתם מפרש דמיירי מתני' דקתני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אינן רשאין ליחלק ואילו בירושלמי משמע",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לדעת שני האמוראים שמעמידים החילוק בין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בתחלה ובין בסוף ומעמידין מתני' דקתני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אינם רשאים ליחלק בתחלה אלא שכל אחד ואחד",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מפרש מהו בתחלה לפי סברתו. ולפיכך נראה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יותר למורי הרב נר\"ו כמו שמפרשים רבני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "צרפת ז\"ל דמאי דקתני שלשה שישבו לאכול",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אינן רשאין ליחלק ר\"ל שישבו לאכול וברכו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברכת המוציא ולא אכלו עדיין כזית כל אחד",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואחד ואתא לאשמועינן שאע\"פ שלא אכלו עדיין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כזית כל אחד ואחד כיון שהתחילו לעשות דרך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קביעות וברכו המוציא אינן רשאין ליחלק",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שבשעה שברכו המוציא ביחד חל עליהם תורת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "זימון ויש להקשות על זה דלפי דבריהם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמעמידין המשנה בתחלה וכגון שברכו ברכת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המוציא ולא אכלו כזית נמצא שאינה כפי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הלשון שאומר נתנו דעתם לאכול זהו בתחלה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהרי בכאן אנו מצריכין שיברכו המוציא וזהו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יותר מנתינת דעת ואינה כמו הלשון האחר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמפרש בתחלה <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"א\" data-order=\"1\"></i>ר\"ל שאכלו כזית שהרי אנו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אומרים שאפי' לא אכלו כזית כיון שברכו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברכת המוציא אינם רשאים ליחלק ונראה למורי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הרב נר\"ו לתרץ לפי דבריהם ולומר דמתני'",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אתיא כלישנא דאמר אכלו כזית זהו בתחלה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומאי דאמר כזית לאו דוקא אלא ר\"ל כיון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שברכו המוציא והתחילו לאכול ואפי' לא אכלו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כזית אלא לאפוקי ממה שאמר האמורא הראשון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נתנו דעתן לאכול זהו בתחלה ואכלו כזית זהו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "סוף אמר האחר אכלו כזית זהו בתחלה למעט",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאינו נקרא תחלה בנתינת דעת בלבד אלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שצריך שיתחילו לאכול ומכיון שברכו המוציא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "והתחילו לאכול כבר נתחייבו בזימון ואינם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רשאים ליחלק אפי' לא אכלו כזית כל זה נוכל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לדחוק ולומר להעמיד סברת רבני צרפת ז\"ל.",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אבל נראה למורי הרב נר\"ו לפרש בענין אחר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דמאי דקתני שלשה שישבו לאכול אינן רשאין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ליחלק ר\"ל שישבו מתחלה בהזמנה אחת וגמרו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בדעתן לאכול ביחד אבל לא ברכו המוציא",
      "segment_ids": [
        0
      ],
