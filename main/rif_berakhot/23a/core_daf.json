      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והא דלא אפשר <i data-commentator=\"Shiltei HaGiborim\" data-label=\"י\" data-order=\"10\"></i>לקצר אפשר לקצר",
      "segment_ids": [
