        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שאלת מעמו (שם) אני האשה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הנצבת עמכה בזה א\"ר יהושע בן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לוי <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ו\" data-order=\"6\"></i>מכאן שאסור לישב <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ז\" data-order=\"7\"></i>בד' אמות",
      "segment_ids": [
        0,
