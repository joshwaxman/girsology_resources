  "rashi": [
    {
      "width": "1010px",
      "text": "<b>כל</b> האומר תהלה לדוד שלש פעמים בכל יום",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "מובטח לו שהוא בן העוה\"ב ובגמ' אמרי' מ\"ט",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "אילימא דאתי באלפא ביתא לימא אשרי תמימי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "דרך דאתי בתמניא אפי אלא משום דאית ביה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "פותח את ידך לימא הלל הגדול דאית ביה נותן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לחם לכל בשר אלא משום דאית ביה תרוייהו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וכיון שעיקר אמירתו הוא מפני זה הפסוק",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "להודיע גבורותיו של הקב\"ה שהוא זן מקרני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ראמים ועד ביצי כנים אומרים הגאונים שצריך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לכוין באמירתו ואם לא כוון צריך לחזור",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ולאמרו פעם אחרת ונראה שאע\"פ שלא כוון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בכולו כיון שכיון בפסוק של פותח את ידך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "סגי ליה בהכי כיון שעיקר האמירה היא בעבור",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "זה הפסוק. מפי מורי הרב נר\"ו: <b>והאמר</b> מר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הקורא הלל בכל יום הרי זה מחרף ומגדף",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וקס\"ד דמהלל דהללויה הללו עבדי ה' קאמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומהדרינן לא אמרינן מזה ההלל אלא מהלל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דפסוקי דזמרה דהיינו תהלה לדוד וכו' ויש",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לשאול מ\"ט אמרו שמחרף ומגדף מפני שאומר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הלל של הללו עבדי ה' וי\"א מפני שחותם בו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יהללוך ונמצא שאומר ברכה לבטלה ואינו נראה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כלל דמה טעם לומר שמפני שאומר ברכה לבטלה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יהא מחרף ומגדף ועוד הכא הקורא הלל סתם",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אמרו דמשמע אפי' בלא ברכה הוא מחרף ומגדף",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומשום הכי נראה למורי הרב נר\"ו שטעם הדבר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הוא מפני שעיקר קריאת ההלל הוא על כל צרה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וצרה שלא תבא על הצבור ואנו אומרים אותו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "באותה שעה כמו שאמרו דוד על הצרות שעברו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עליו וכשאומר אותו בכל יום נראה כמי שאומר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאין הקב\"ה עושה נפלאות בכל יום ולפיכך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קורא הנסים שעברו כבר ונמצא שמחרף ומגדף",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כלפי מעלה אבל תהלה לדוד שיש בו ג\"כ",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מהעתיד וממה שעושה בכל יום אמרו שיאמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אותו בכל יום ומובטח לו שהוא בן העוה\"ב",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ובירושל' נותן טעם אחר משום דכתיב ביה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עצביהם כסף וזהב וכשאומר אותו בכל יום",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נראה כמתכוין לחרף ולגדף כלפי מעלה ולומר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאינו יכול לבטלם מן העולם: <b>ותקינו</b> רבנן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "למימר ברכה מקמייהו וברכה מבתרייהו וכתב",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רב עמרם גאון ז\"ל שאם נכנס אדם לבית הכנסת",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ורואה שאם יתחיל לומר כל הפסוקים שלא יוכל",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "להשלים ולהתפלל עם הצבור שיאמר ברוך שאמר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומזמורים של תהלה לדוד בלבד וחותם בו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בברכת ישתבח <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"א\" data-order=\"1\"></i>שאע\"פ שהגאונים תקנו לומר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מתהלה לדוד עד כל הנשמה כיון שעיקר התקנה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נראה שלא היתה אלא מפני המזמור של תהלה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לדוד בלבד שהרי אנו רואין שעל קריאת אותו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המזמור בלבד אמרו שמובטח לו שהוא בן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "העוה\"ב די לו בזה המזמור כדי שיאמר ק\"ש",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "והתפלה עם הצבור ועוד אמר הרב נר\"ו בשם",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רבותיו ז\"ל שאם נכנס בשעה שמתחיל החזן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יוצר ולא היה יכול לומר אפילו זה המזמור",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בלבד שיתחיל ק\"ש וברכותיה ויתפלל עם הצבור",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואח\"כ יקרא פסוקי דזמרה עם הברכות שלפניהם",
      "segment_ids": [
        0,
        1,
        2
      ],
