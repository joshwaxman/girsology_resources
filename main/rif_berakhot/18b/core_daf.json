  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>שהרי</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "תמיד של בין הערבים היה קרב",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והולך עד הערב ר' יהודה אומר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עד פלג המנחה שהרי תמיד של",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בין הערבים היה קרב והולך עד",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פלג המנחה ומפני מה אמרו תפלת",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הערב אין לה קבע שהרי איברים",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ופדרים שלא נתעכלו מבעוד יום",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היו קריבים והולכין כל הלילה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ומפני מה אמרו ושל מוספין כל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היום שהרי קרבן מוסף היה קרב",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והולך כל היום כולו רבי יהודה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אומר עד שבע שעות שהרי מוספין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קרבין והולכין עד שבע שעות אי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "זו היא מנחה גדולה משש שעות",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ומחצה ולמעלה ואי זו היא מנחה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קטנה מתשע שעות ומחצה ולמעלה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פלג מנחה אחרונה אחת עשרה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שעות פחות רביע איבעיא להו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לרבי יהודה עד ועד בכלל או",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דלמא עד ולא עד בכלל ומסקנא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "(דף כז.) דעד ועד בכלל ודיקא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נמי דקתני העיד רבי יהודה בן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בבא על תמיד של שחר שקרב",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בארבע שעות שמע מינה עד ועד",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בכלל שמע מינה אמר רב כהנא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הלכה כרבי יהודה הואיל ותנן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בבחירתא כוותיה: תפלת המנחה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עד הערב רבי יהודה אומר עד",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פלג המנחה: אמר ליה רב חסדא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לרבי יצחק התם קאמר רב כהנא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הלכה כרבי יהודה הואיל ותנן",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בבחירתא כותיה הכא מאי אישתיק",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ולא אמר ליה ולא מידי ואסיקנא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "השתא דלא איתמר הלכתא לא כמר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ולא כמר <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>מאן דעבד כמר עבד",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>ומאן דעבד כמר עבד אמר ר'",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהושע בן לוי אסור <i data-commentator=\"Mishneh Torah, Prayer and the Priestly Blessing\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>לעבור <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>כנגד",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "המתפללין איני והא רב אמי ורב",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אסי עברי רב אמי ורב אסי חוץ",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לארבע אמות הוא דעברי אמר רב",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהודה אמר רב לעולם <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Torah Study\" data-label=\"⚬\"></i>אל יתפלל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תלמיד לא לפני רבו ולא אחורי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רבו ולא כנגד רבו (דף כז:)",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תניא רבי אלעזר בן חסמא אומר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "המתפלל כנגד רבו והמתפלל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אחורי רבו <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ד\" data-order=\"4\"></i>והנותן שלום לרבו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והחולק על ישיבתו של רבו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והאומר דבר שלא שמע מפי רבו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "גורם לשכינה שתסתלק",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מישראל אמר רב חייא בר אבין",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ה\" data-order=\"5\"></i>צלי <i data-commentator=\"Mishneh Torah, Prayer and the Priestly Blessing\" data-label=\"⚬\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Sabbath\" data-label=\"⚬\"></i>של שבת <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ו\" data-order=\"6\"></i>בערב שבת ורבי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יאשיה צלי של מוצאי שבת בשבת",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "איבעיא להו רב צלי של שבת",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בערב שבת אומר קדושה על הכוס",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "או אינו אומר קדושה על הכוס",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ת\"ש דאמר רב יהודה אמר שמואל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתפלל אדם של שבת בע\"ש ואומר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קדושה על הכוס ורבי יאשיה צלי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "של מוצאי שבת בשבת אומר הבדלה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "על הכוס או אינו אומר הבדלה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "על הכוס ת\"ש דאמר ר' תחליפא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בר אבימי אמר שמואל מתפלל אדם",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "של מוצאי שבת בשבת ואומר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הבדלה על הכוס: תפלת הערב אין",
      "segment_ids": [
