  "rashi": [
    {
      "width": "1010px",
      "text": "<b>העיד</b> רבי יהודה בן בבא על תמיד של שחר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "שקרב בד' שעות <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"א\" data-order=\"1\"></i>ואומר במדרש שהמלך שלמה היה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ישן עד ג' שעות כמו שדרך בני מלכים לעמוד",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "בג' שעות ופעם אחת הטעתו בת פרעה וישן עד",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "ד' שעות והקריבו תמיד של שחר בד' שעות",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומזה היתה קבלה ביד ר' יהודה בן בבא והעיד",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שתמיד של שחר קרב בארבע שעות: <b>דעבד</b> כמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עבד ודעבד כמר עבד אע\"פ שנראה מכאן שאם",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ירצה יכול להתפלל ערבית מפלג המנחה ואילך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דלר' יהודה משם ואילך אינו זמן תפלת מנחה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ולדברי רבנן יכול להתפלל מנחה עד הערב",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אפ\"ה אין לו לאדם לעשות בענין שיהו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מנהגותיו סותרין זה את זה שאם יתפלל מנחה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לפעמים מפלג המנחה ואילך כרבנן ולפעמים",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
