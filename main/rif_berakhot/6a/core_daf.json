  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>לחתום</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "אינו רשאי שלא לחתום: <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>פשיטא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היכא דנקיט כסא דחמרא בידיה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וקסבר דשכרא הוא פתח ובירך",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בדשכרא וסיים בדחמרא יצא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>ואפילו סיים בדשיכרא יצא דתנן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ועל כלם אם אמר שהכל נהיה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בדברו יצא אלא היכא דנקיט כסא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דשכרא בידיה וקסבר דחמרא הוא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פתח בדחמרא וסיים בדשכרא מאי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בתר פתיחה אזלינן או בתר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חתימה אזלינן ולא איפשיטא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>ולקולא עבדינן ולא מהדרינן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ליה דספיקא דרבנן לקולא תניא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Tur\" data-label=\"⚬\"></i>בשחרית פתח ביוצר אור וסיים",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "במעריב ערבים לא יצא פתח",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "במעריב ערבים יסיים ביוצר אור",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יצא בערבית פתח במעריב ערבים",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וסיים ביוצר המאורות לא יצא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פתח ביוצר אור וסיים במעריב",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ערבים יצא כללו של דבר הכל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הולך אחר חיתום ברכות: הכל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לאיתויי מאי לאיתויי היכא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Tur\" data-label=\"⚬\"></i>דאכל תמרי וסבר דנהמא אכל פתח",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ובריך בדנהמא וסיים <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>בדתמרי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יצא אי נמי סיים בדנהמא <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ד\" data-order=\"4\"></i>יצא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מאי טעמא תמרי נמי מיזן זייני",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר רבה בר <i data-commentator=\"Hagahot HaBach\" data-label=\"ב\" data-order=\"2\"></i>חנינא סבא משמיה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דרב כל <i data-commentator=\"Tur\" data-label=\"⚬\"></i>שאינו אומר אמת",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ויציב",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>ואמר</b> מורנו הרב נר\"ו דאכתי איכא למידק דהא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "חזינן בציצית ותפילין שמצותן כל היום",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ואפ\"ה אם חלץ אותן וחזר ומניחן פעם אחרת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "צריך לברך ובציצית נמי אע\"פ שמצותו כל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "היום אם מתעטף בו הרבה פעמים ביום צריך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לברך על כל פעם ופעם וקבלה בידו מרבותיו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאפי' נפל מעליו ולקחו מיד ונתעטף בו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמברך עליו ואע\"פ שלא נתכוין להסירו מעליו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "והכא נמי אע\"פ שמצות הקריאה כל היום היה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לו לומר שיברך ברכת התורה בכל פעם ופעם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ונראה לו לתרץ שאינו דומה זה לזה מפני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהתפילין כשחולצן או הציצית כשמפשיטן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מעליו נגמרה מצותן ולפיכך כשחוזר ומניחן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "פעם אחרת מצוה אחרת היא וצריך לחזור ולברך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אבל בקריאה כשקרא פעם אחת עדיין לא נגמרה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מצותה שהיא כל היום ולפיכך כשקורא וחוזר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "למצותו הוא חוזר ואין צריך לחזור ולברך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואפילו כשקורא בלילה לא נאמר שהלילה מהיום",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "האחר הוא שיצטרך לחזור ולברך שאף על פי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שבשאר הדברים אנו אומרים היום הולך אחר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הלילה גבי הקריאה הלילה הולך אחר היום",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וכדאמרינן בירושלמי אמר ר' יוחנן אנן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אגירי דיממא אנן יזפינן ביממא ופרעינן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בליליא כלומר מי שהוא שכיר אין לו להתבטל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ממלאכתו כל היום וכיון שכן ואנחנו מצוה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עלינו לקרוא כל היום אם כן אנו כמו פועלים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאין לנו להתבטל מהקריאה ומה שאנחנו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מתבטלין ממנה ביום הוא כמו הלואה אצלינו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואנחנו פורעין אותה בלילה הנה שקריאת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הלילה היא מהיום ההוא ולפיכך בברכה שבירך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בבקר להפטר ממה שלומד ביום באותה ברכה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נפטר גם כן במה שלומד בלילה: <b>וכיוצא</b> בזה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הורה רבי יעקב ז\"ל לענין סוכה שאמר שאינו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מברך כשנכנס לישן בה מפני שמא לא יוכל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לישן והויא ברכה לבטלה וכ\"ת יברך בשעה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמתחיל להתנמנם שמא באותה שעה אין ידיו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נקיות דידים עסקניות הן ושאלו לו א\"כ היאך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ישן בה בלא ברכה והשיב שהברכה שמברך בשעת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אכילה פוטרת הכל עד אכילה אחרת שהאכילה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "היא יותר עיקר מכל שאר הדברים ועל כן עשו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עיקר ממנה לחייבו שיברך בשעת אכילה כדי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שיפטור השינה והטיול וכל מה שמשתמש בה עד",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אכילה אחרת הכא נמי בברכה שבירך בבקר נפטר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עד יום אחר: <b>פתח ובירך בדשכרא וסיים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בדחמרא יצא וכו'.</b> פירש רש\"י ז\"ל שבשעה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהתחיל הברכה טעה במחשבה שהיה סבור שהוא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שכר ופתח ואמר בא\"י אמ\"ה על דעת שיסיים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בשהכל נהיה בדברו ובינתים הכיר שהוא יין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וגמר הברכה כראוי וסיים בפה\"ג יצא כיון",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שחתם כראוי וכו' וכן מפרש באידך ברייתא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בשחרית פתח ביוצר אור וכו' <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"א\" data-order=\"1\"></i>ר\"ל שהיה מכיר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהוא יום והתחיל בא\"י יוצר אור <i data-commentator=\"Hagahot HaBach\" data-label=\"ה\" data-order=\"5\"></i>ואחר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהתחיל נתבלבלה דעתו וחתם בא\"י המעריב",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ערבים פתח במעריב ערבים וכו' פירש דמתחלה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הכיר שהיא לילה והתחיל לומר מעריב ערבים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
