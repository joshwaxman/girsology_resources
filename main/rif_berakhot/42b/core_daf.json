{
  "metadata": {
    "masechet_en": "Berakhot",
    "masechet_he": "ברכות",
    "daf": "42B",
    "type": "rif",
    "ry_on_right": true,
    "ry_header_lines": 4
  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>בין</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "שהכוס בידו בין שהכוס בידו של",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בעל הבית שמא יארע דבר קלקלה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בסעודה והשמש שלא נטל ידיו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אסור ליתן פרוסה לתוך",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פיו: גרסינן בסוטה בפרק קמא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "(דף ד:) אמר רבי זריקא אמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רבי אלעזר כל המזלזל בנטילת",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ידים נעקר מן העולם (שם) אמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ר' חייא בר אשי אמר רב <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>מים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ראשונים צריך <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>שיגביה ידיו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "למעלה אחרונים צריך שישפיל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ידיו למטה תניא נמי הכי הנוטל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ידיו צריך שיגביה ידיו למעלה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כדי שלא יצאו מים חוץ לפרק",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ויחזרו ויטמאו את הידים (שם)",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר רבי אבהו כל האוכל בלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ניגוב ידים כאוכל לחם <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>טמא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שנאמר (יחזקאל ד׳:י״ג) ויאמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ה' אלי ככה יאכלו בני ישראל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "את לחמם טמא בגוים גרסינן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ביומא בפרק אמר להם הממונה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "(דף ל.) תנו רבנן <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>הלכה בסעודה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אדם יוצא להשתין מים נוטל ידו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אחת ונכנס דבר עם חבירו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והפליג נוטל שתי <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>ידיו ונכנס",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וכשהוא נוטל אל יטול מבחוץ",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלא מבפנים נכנס ויושב במקומו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ונוטל ומחזיר פניו לאורחין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר רב חסדא לא אמרן אלא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לשתות אבל לאכול נוטל מבחוץ",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ונכנס מידע ידעי דאנינא דעתיה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר רב נחמן בר יצחק אנא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אפילו לשתות מידע ידעי דאנינא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דעתאי: <b>הדרן עלך אלו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דברים</b> (דף נד.) <b><big>הרואה</big></b> <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Blessings\" data-label=\"⚬\"></i>מקום",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שנעשו בו נסים לישראל אומר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ברוך שעשה <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ד\" data-order=\"4\"></i>נסים לאבותינו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "במקום הזה מקום שנעקרה ממנו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עכו\"ם אומר ברוך שעקר עכו\"ם",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מארצנו על הזיקים ועל הזועות",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ועל הברקים ועל הרעמים ועל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הרוחות אומר ברוך שכחו מלא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עולם על ההרים ועל הגבעות ועל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הימים ועל הנהרות ועל המדברות",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אומר ברוך עושה בראשית רבי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהודה אומר הרואה את הים",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הגדול אומר ברוך שעשה את הים",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הגדול אימתי בזמן שרואהו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לפרקים על הגשמים ועל בשורות",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "טובות אומר ברוך הטוב והמטיב",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ועל שמועות רעות",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>בין שהכוס בידו בין שהכוס ביד בעל הבית",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "שמא יארע דבר קלקלה בסעודה.</b> פי' שמא משום",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "שיתן דעתו על הפרוסה לא ישמור היין שבכוס",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "וישפוך היין וכן כשהכוס ביד בעל הבית",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "ויראה שנותנין מהפרוסה לשמש מקפיד בדבר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וישפך היין ויארע דבר קלקלה בסעודה ודוקא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לשמש אבל שאר בני הסעודה יכולין לתת זה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לזה כשהכוס ביד בעל הבית שמאחר שהוא זימן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אותם אינו מקפיד במה שהם נותנין אלו לאלו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ולא חיישינן לקלקלה: <b>שלא יצאו מים חוץ",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לפרק ויחזרו ויטמאו את הידים.</b> פירוש שיעור",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הנטילה הוא עד הפרק שבין חיבור יד והזרוע",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדכתבינן לעיל ועכשו <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"ב\" data-order=\"2\"></i>בא להשמיענו שבשעת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הנטילה צריך שיזהר שלא <i data-commentator=\"Hagahot HaBach\" data-label=\"ד\" data-order=\"4\"></i>יגביה ידיו למעלה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עד שינגבם מפני <i data-commentator=\"Hagahot HaBach\" data-label=\"ה\" data-order=\"5\"></i>שאם [לא] יגביהם יקבלו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המים ששופך באחרונה לטהר המים שעל הידים",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "טומאה מהזרוע ויחזרו ויטמאו את הידים ולא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עלתה לו נטילה: <b>את לחמם טמא.</b> כלומר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כשאוכלין בלא ניגוב ידים לחות המים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מטמא: <b>דיבר עם חברו והפליג נוטל שתי ידיו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ונכנס.</b> פירוש כשיוצא להשתין די בנטילת היד",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "האחת שמשפשף בה הניצוצות בלבד אבל כשמדבר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עם חבירו והאריך הרבה בדיבור שהסיח דעתו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "צריך שיטול את שתיהן ולא יטול אלא בפנים",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ושיחזיר פניו לאורחים שיראו שנוטל ודוקא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לשתות אמרו שצריך ליטול בפנים כי שמא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יחשדו אותו שאינו חושש ליטול ידיו לשתיה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אבל לאכול אין צריך ליטול בפניהם דודאי לא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יחשדו אותו בזה שיודעים שאיסטניסות הוא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לכל אדם שבעולם לאכול בלא נטילת ידים",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ובכאן י\"ל היכי קאמר לא אמרו אלא לשתות",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
