  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>מברך</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "עליה המוציא לחם ושלש ברכות",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואי לית ביה פירורין כזית",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בתחלה מברך עליה בורא מיני",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מזונות ולבסוף ברכה אחת מעין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שלש ורב ששת אמר אפי' פירורין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שאין בהן כזית מברכין עליה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "המוציא אמר רבא והוא דאיכא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עליה <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>תוריתא דנהמא וכן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הלכתא: אמר אביי <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>טריתא פטורה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מן החלה מאי טריתא איכא דאמרי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מרתח גביל ואיכא דאמרי נהמא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דהנדקא ואיכא דאמרי לחם העשוי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לכותח דתני ר' חייא לחם העשוי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לכותח פטור מן החלה (דף לח.)",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואם עשאה כעבין חייבת כלמודים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פטורה והא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>ולפיכך</b> נראה שהפי' הנכון הוא כמו שפירשו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "רבינו האי גאון ורב נתן בעל הערוך ז\"ל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "דחביצא הוא שלוקחים הפירורי' ומחברין אותן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "יחד עם הדבש או עם המרק בלי שום בישול כלל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "ורב יוסף ס\"ל שאם אין בפירורין כזית אע\"פ",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שלא נתבשלו אינו מברך עליהם המוציא והקשה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לו אביי והא תניא ליקט מכולן כזית אם חמץ",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הוא ענוש כרת אם מצה הוא אדם יוצא יד\"ח",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בפסח הנה שאין כאן כזית אלא בחמשה פירורין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואפי' הכי נראה שמברך עליו ברכת המוציא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואכילת מצה והשתא פריך שפיר שכמו שזה בלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בישול ואנו מברכין עליו הוא הדין נמי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בחביצא כיון שאין שם בישול אלא חיבור",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בעלמא שמחברין אותו בקערה עם הדבש או עם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המרק אית לן למימר שאע\"פ שאין בפירורין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כזית שמברך עליהם המוציא ומורי הרב נר\"ו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מביא ראיה עוד לזה הפירוש שפירש הגאון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ובעל הערוך ז\"ל שאם כדברי רש\"י שמפרש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בבישול על כרחין נצטרך לומר דרב ששת מפרש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הברייתא דהכוסס את החטה דקתני ואם אין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הפרוסות קיימות בתחלה מברך עליו במ\"מ",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דמיירי בשאין פרוסות קיימות בכזית ושאין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בהם תואר לחם דאי כשיש בהם תואר לחם הא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמעינן ליה לרב ששת דאמר שאע\"פ שאין בהם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כזית מברך עליהם המוציא והיאך יאמר בכאן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שיברך במ\"מ אלא ודאי נצטרך לומר לדעתו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דבשאין בפרוסות כזית ואין בהם תואר לחם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מיירי וא\"כ לדעת רב ששת מה חידש לנו רבא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בכאן שאמר והוא דאיכא עליה תוריתא דנהמא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהרי כבר נאמר בברייתא שאם אין הפרוסות",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כזית ואין בהם תואר לחם מברך עליהם במ\"מ",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אבל אי איכא עליה תוריתא דנהמא אע\"פ שאין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בהם כזית מברך עליהם המוציא ולמה הוצרך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רבא לחזור הדבר ללא צורך שאין דרך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "האמוראים לחזור הדברים האמורים במשניות",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ובברייתות אם לא יהיה כדי ללמד שום חידוש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אלא ודאי משום דברייתא איירי בבישול והכא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בלא בישול הוצרך רבא לומר דכי אמרי' דאפי'",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "פירורין שאין בהם כזית שמברך עליהם המוציא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "זהו כשיש בהם תואר לחם דאי מברייתא הייתי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אומר דדוקא בדבר שהוא מבושל צריך שיהא בו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "תואר לחם אבל בחביצא שאינו מבושל אע\"פ שלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יהיה בו תואר לחם ואין בפירורין כזית יברך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עליו קמ\"ל רבא חידוש שאע\"פ שאינם מבושלים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אינו מברך עליהם אלא בשיש בהם תואר לחם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ועכשיו נעמיד הברייתא כדעת הירושלמי בשיש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בפרוסות כזית ואפי' אליבא דרב ששת ור\"ל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "<i data-commentator=\"Hagahot HaBach\" data-label=\"ג\" data-order=\"3\"></i>בזמן שהפרוסות קיימות שיש בהם כזית בתחילה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מברך עליו המוציא ולבסוף שלש ברכות אין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הפרוסות קיימות שאין בהם כזית בתחילה מברך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בורא מיני מזונות מפני שכיון שהוא מבושל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואין בהם כזית אפי' רב ששת מודה שכבר יצא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מתורת לחם ואע\"ג דאיכא עליה תוריתא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דנהמא: <b>על</b> כן נראה למורי הרב נר\"ו שג'",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דינין חלוקים הם היכא שהוא מבושל אם יש בו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בפרוסות כזית [מברך עליהם המוציא וג'",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברכות ואם אין בפרוסות כזית] אע\"ג דמיחזי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דאיכא עליה תוריתא דנהמא אינו מברך עליו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אלא בורא מיני מזונות דכיון שהוא מבושל לא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "תואר לחם לו והיכא שאינו מבושל אלא שהוא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מחובר ע\"י דבש או מרק בלא שום בישול אם יש",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בפרוסות כזית מברך עליו המוציא <i data-commentator=\"Hagahot HaBach\" data-label=\"ד\" data-order=\"4\"></i>אין",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בפרוסות כזית ואין בהם תואר לחם מברך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עליהם במ\"מ אבל אם יש בהם תואר לחם אע\"פ",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאין בהם כזית מברך עליהם המוציא והיכא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאינו לא מבושל ולא מחובר אלא שהוא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "פירורים לבדם אע\"פ שאין בהם כזית ואין בהם",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "תואר לחם שהן דקין ביותר מברך עליו המוציא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וג' ברכות שכיון שהוא פת בפ\"ע אינו יוצא",
      "segment_ids": [
        0,
        1
      ],
