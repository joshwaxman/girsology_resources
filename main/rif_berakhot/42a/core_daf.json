  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>מכח</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>גברא ואי מקרב לגבי <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>דוולא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאתו מכח גברא נוטלין ממנו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לידים ואי בזע דוולא בכונס",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "משקה <i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>(אין נוטלין ממנו לידים",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דלאו כלי הוא <i data-commentator=\"Hagahot HaBach\" data-label=\"ב\" data-order=\"2\"></i>ואמר רבה) כלי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שאין בו רביעית אין נוטלין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ממנו לידים אמר ליה רב אשי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לאמימר קפדיתו אמנא קפדיתו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אחזותא קפדיתו אשיעורא אמר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ליה אין איכא דאמרי אמנא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואחזותא קפדינן אשיעורא לא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קפדינן דתנן מי רביעית נוטלין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לידים לאחד <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>ואפי' לשנים ולא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היא שאני התם דקאתו משירי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "טהרה איתקין רב יעקב מנהר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פקוד נטלא בת רביעתא ואמר רבא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מגופת חבית שתיקנה נוטלין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ממנה לידים חמת וכפישה שתיקנן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נוטלין מהן לידים שק וקופה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אע\"פ שתיקנן אין נוטלין מהן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לידים איבעיא להו <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Blessings\" data-label=\"⚬\"></i>מהו לאכול",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "במפה מי גזרינן דילמא נגע בפת",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "או לא ומסקנא (שם דף קז.) אמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב תחליפא בר אבדימי אמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שמואל התירו במפה לאוכלי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תרומה ולא התירו <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ד\" data-order=\"4\"></i>במפה לאוכלי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "טהרות איבעיא להו אוכל מחמת",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מאכיל צריך נטילת ידים או לא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ומסקנא והלכתא אוכל מחמת",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מאכיל צריך נטילת ידים מאכיל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עצמו אינו צריך נטילת ידים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר רב יהודה אמר רב לא יתן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Blessings\" data-label=\"⚬\"></i>אדם פרוסה לשמש אא\"כ יודע בו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שנטל ידיו והשמש מברך על <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ה\" data-order=\"5\"></i>כל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כוס וכוס ואינו מברך על כל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פרוסה ופרוסה ר' יוחנן אמר אף",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מברך על כל פרוסה ופרוסה ולא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פליגי הא דאיכא אדם חשוב הא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דליכא אדם חשוב ת\"ר לא יתן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אדם פרוסה לשמש",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>וכתב</b> מר רב יהודאי גאון ז\"ל מכניס אדם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ידיו לתוך הכלי ונוטל ומביא ראיה מדאמרינן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "(זבחים כא.) גבי קידוש ידים שבמקדש שאין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "לו ליטול ידיו בתוך הכלי דממנו אמר רחמנא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "ולא בתוכו ומדפסל גבי מקדש מכלל דנטילת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ידים לחולין שרי ונראה שסובר דלא בעינן כח",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "גברא ואע\"פ שהסוגיא מוכחת דבעינן כח גברא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כיון שאנו רואין במשנה שסוברת דלא בעינן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כח גברא דמכשרת הקוף ומכשרת להטות את",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "החבית וליטול ממנה לידים ממילא נדחית",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הסוגיא שבכאן אבל נראה למורי הרב נר\"ו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לומר דכיון שהסוגיא מוכח בכאן דבעינן כח",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "גברא ובמשנה הוא מחלוקת ת\"ק ור' יוסי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נפסוק הלכה כר' יוסי דפוסל בשתיהן ומצריך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כח גברא וגם הראב\"ד ז\"ל כך כתב כיון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דבגמרא אמרו דבעינן כח גברא לא נחוש לסתמא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דמתני' שאפשר לומר שהיו יודעין דיחידאה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הוא ונפסוק הלכה כר' יוסי דמצריך כח",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "גברא: <b>ואי בזע דוולא בכונס משקה וכו'.</b> פי'",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אם ניקב הכלי כל כך שאם ישימו אותו על",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המים נכנסים המים למעלה דרך אותו נקב כיון",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שיש שם חיבור כל שהוא לא הוו שאובין",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומטבילין בו את <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"ב\" data-order=\"2\"></i>הידים כמו במעין עצמו אבל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אין נוטלין בו את הידים שכיון שיש בו נקב",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כ\"כ שהמשקה נכנס דרך אותו הנקב נתבטל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מתורת הכלי: <b>כלי שאין בו רביעית אין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נוטלין בו לידים ולא ממנו.</b> כלומר שאע\"פ",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמשים בו רביעית בב' פעמים אפ\"ה כיון שאין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הכלי מחזיק רביעית אין נוטלין ממנו לידים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דלאו כלי הוא: <b>קפדיתו אמנא.</b> שיהיה הכלי",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מחזיק רביעית: <b>קפדיתו אחזותא.</b> שהמראה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יפסול בנטילה כמו שפוסל במקוה אם נתנו בו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דיו או קנקנתום וכיוצא בהן ונשתנה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מראהו: <b>קפדיתו אשיעורא.</b> <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"ג\" data-order=\"3\"></i>שיהיה במים שיעור",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רביעית א\"ל אין דכולהו בעינן אשיעורא לא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קפדינן דתנן מרביעית נוטלין לידים לאחד",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואפי' לשנים לא קאמר דבפחות מרביעית לא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קפדינן שזה אי אפשר דודאי צריך רביעית שלם",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדאמרי' בעלמא חצי רביעית לטהר את הידים",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וחצי רביעית לטהר המים שעל הידים אלא ה\"ק",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אם לא יהיה בכלי מתחלה שיעור שלם כיון",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמשלים אח\"כ לשיעור לא קפדינן בהכי שהרי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שנינו דמרביעית נוטלין לידים אפי' לשני",
