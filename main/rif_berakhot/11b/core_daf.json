        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הירושלמי נראה דסמוך לק\"ש אינו ר\"ל חצי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שעה דוקא אלא רוצה לומר שאין מוציאין אותו",
