        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "להוציאו ולקברו קודם שיגיע ק\"ש וטעו בזה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "השיעור ולא היה להם שעה גדולה כל כך ולפי",
