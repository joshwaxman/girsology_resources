        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומתרץ תפתר כגון דהוו סבירין דאית בה עונה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ולית בה עונה כלומר שמתחלה שיערו שיוכל",
      "segment_ids": [
