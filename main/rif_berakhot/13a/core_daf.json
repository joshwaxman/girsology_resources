{
  "metadata": {
    "masechet_en": "Berakhot",
    "masechet_he": "ברכות",
    "daf": "13A",
    "type": "rif",
    "ry_on_right": false,
    "ry_header_lines": 4
  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>אדעתא</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "דחובה בין אדעתא דרשות אסור",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דקי\"ל דתפלות כנגד תמידין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תקנום וכשם שאין הצבור מביא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עולת נדבה כך אין הצבור",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתפללין תפלת נדבה אבל היחיד",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתפלל תפלת נדבה שכן היחיד",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מביא עולת נדבה הלכך אין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היחיד מתפלל תפלת המוספין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תפלת נדבה שאין מתנדב בקרבן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מוסף והא דאמר רב יהודה אמר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שמואל היה עומד בתפלה ונזכר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שכבר התפלל פוסק אפילו באמצע",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ברכה מפרשי לה רבנן כגון",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שהתפלל תפלתו אדעתא דחובה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ושכח שכבר התפלל ועמד להתפלל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אדעתא דחובה ונזכר שכבר התפלל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פוסק ואפילו באמצע ברכה שאם",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בא לגומרה נמצא כמי שמקריב",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שני תמידין בשחרית שהוא עובר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "משום בל תוסיף ולפיכך פוסק",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואפילו באמצע ברכה ובהא אפילו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רבי יוחנן מודה דלא קאמר רבי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יוחנן ולואי שיתפלל אדם כל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היום כולו אלא תפלת נדבה כגון",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תחנונים וכיוצא בהן אבל תפלת",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חובה לא קאמר אמר רב יהודה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר שמואל <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>התפלל ונכנס לבית",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הכנסת ומצא צבור שמתפללין אם",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יכול לחדש דבר בתפלתו כדי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שתהא תפלתו תחנונים יתפלל ואם",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לאו אל יתפלל א\"ר נחמן כי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הוינן בי רבה בר אבוה <i data-commentator=\"Mishneh Torah, Prayer and the Priestly Blessing\" data-label=\"⚬\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>איבעיא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לן הני בני (בי) רב דטעו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ומתחילו <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>בתפלת חול בשבת מהו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שיגמורו אמר להו גומר כל אותו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ברכה דבדין הוא דבעי <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>לצלויי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שמונה עשרה ומשום כבוד שבת לא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אטרחוה רבנן (דף כא:) אמר רב",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הונא <i data-commentator=\"Mishneh Torah, Prayer and the Priestly Blessing\" data-label=\"⚬\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>הנכנס לבית הכנסת <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ד\" data-order=\"4\"></i>ומצא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "צבור שמתפללין אם יכול להתחיל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ולגמור <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ה\" data-order=\"5\"></i>עד שלא יגיע שליח צבור",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "למודים יתפלל ואם לאו אל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יתפלל רבי יהושע בן לוי אמר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אם יכול להתחיל ולגמור עד שלא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יגיע שליח צבור לקדושה יתפלל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואם לאו אל יתפלל במאי קא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מיפלגי רב הונא סבר היחיד",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אומר <i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>קדוש ור' יהושע ב\"ל סבר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אין היחיד אומר קדוש וכן אמר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ר' יצחק אין היחיד אומר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קדוש: אמר רב אדא בר אהבה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מנין שאין היחיד אומר קדוש",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שנא' (ויקרא כ״ב:ל״ב) ונקדשתי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בתוך בני ישראל כל דבר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ו\" data-order=\"6\"></i>שבקדושה לא יהא פחות מעשרה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וכולי עלמא מיהת <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ז\" data-order=\"7\"></i>מיפסק לא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פסיק אבעיא להו מהו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שיפסוק",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>ויש</b> בזה דעת אחרת לרבינו האי גאון ז\"ל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "שהוא אומר שמתפלל תפלת נדבה בין תפלת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "שחרית ומנחה בין תפלת מוסף ונראה למורי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "הרב נר\"ו שאפשר לתת טעם לדבריו מפני שאע\"פ",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "שתפלות כנגד תמידין תקנום מאין לנו דבתפלת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "של נדבה ג\"כ [נלך] אחר הקרבנות ואם אמרו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בתפלת חובה [לא] נאמר בתפלת נדבה ועוד",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דכיון שהכל יכול להביא בתורת נדבה אלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "השעיר בלבד מפני המיעוט שאינו יכול להביא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נדבה נאמר שלא יתפלל נדבה אבל נראה למורי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נר\"ו יותר להעמיד דברי הרב אלפס ז\"ל ולאו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מטעמיה אלא הטעם שאין מתפללים תפלת מוסף",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נדבה כמו שאר תפלות של שחרית ומנחה מפני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שתפלת שמנה עשרה הוא רחמים ובתפלה שיש בה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רחמים יכול האדם לאומרה לבקש על עצמו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רחמים כמה פעמים שירצה אבל בשאר תפלות של",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שבעה ברכות שאין בהם אלא שבח אין לו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "להתפלל בברכות של שבח בנדבה אלא מה שהותקן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בלבד ולפ\"ז נראה שאפי' בשבת תפלת שחרית",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אין לו להתפלל אותה נדבה כיון שהיא משבע",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברכות בלבד ואין בה אלא שבח אלא אפשר לומר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שיכול להתפלל אותה נדבה אע\"פ שהוא שבח",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "משום דכיון שהותקנה כנגד תפלה של שמנה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עשרה שהוא רחמים לגבי זה דיינינן ליה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כתפלת רחמים: <b>היה</b> עומד בתפלה ונזכר שכבר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "התפלל פוסק ואפי' באמצע ברכה הרי\"ף ז\"ל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מפרש דמש\"ה פוסק מפני שאם בא לגומרה נמצא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כמי שמקריב שני תמידין כדמפרש ואזיל וא\"ת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
