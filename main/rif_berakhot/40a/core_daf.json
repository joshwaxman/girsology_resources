{
  "metadata": {
    "masechet_en": "Berakhot",
    "masechet_he": "ברכות",
    "daf": "40A",
    "type": "rif",
    "ry_on_right": false,
    "ry_header_lines": 4
  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>מברכין</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "על האור בין במוצאי שבת בין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "במוצאי יום הכיפורים וכן עמא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דבר מיתיבי אין מברכין על",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "האור אלא במוצאי שבתות הואיל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ותחלת ברייתו היא וכשהוא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רואהו מברך מיד רבי יהודה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אומר סודרן על הכוס ואמר רבי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יוחנן הלכה כרבי יהודה לא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קשיא כאן באור ששבת כאן באור",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שיצא מן העצים ומן האבנים",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שאין מברכין במוצאי יום",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הכפורים אלא על אור ששבת אבל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "על האור היוצא מן העצים ומן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "האבנים לא: <b><big>מתני'</big></b> (דף נא:) מי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Mishneh Torah, Sabbath\" data-label=\"⚬\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>שאכל ושכח ולא בירך בית שמאי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אומרים יחזור למקומו ויברך",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ובית הלל אומרים יברך במקום",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שנזכר עד אימתי הוא מברך עד",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כדי שיתעכל המזון שבמעיו: בא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "להם יין <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>בתוך המזון ואין שם",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלא אותו הכוס בית שמאי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אומרים מברך על היין ואחר כך",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "על המזון ובית הלל אומרים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מברך על המזון ואחר כך מברך",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "על היין עונין אמן אחר ישראל",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "המברך ואין עונין אמן אחר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כותי המברך עד שישמע את כל",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הברכה כולה: <b><big>גמ'</big></b> (דף נג:) אמר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב זביד מחלוקת <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>בשוכח אבל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "במזיד דברי הכל יחזור למקומו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ויברך: הנהו תרי תלמידי חד",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עבד בשוגג כבית שמאי ואשכח",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ארנקי <i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>וחד עבד במזיד כבית הלל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>וקטליה אריא: עד כמה הוא מברך",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עד כדי שיתעכל המזון",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שבמעיו: וכמה שיעור עיכול אמר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ר' יוחנן כל זמן שאינו רעב",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מחמת אותה אכילה: <i data-commentator=\"Tur\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Blessings\" data-label=\"⚬\"></i>ועונין אמן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ד\" data-order=\"4\"></i>אחר ישראל המברך תניא אחר הכל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עונין אמן חוץ מתינוקות של",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בית רבן הואיל ולהתלמד עשויין",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והני מילי בעידנא דקא מגמרי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "להו אבל בעידנא <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ה\" data-order=\"5\"></i>דקא מפטרי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"א\" data-order=\"1\"></i>עונין אמר רב יהודה אמר רב",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואמרי לה במתניתא תנא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>והתקדשתם אלו מים ראשונים",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והייתם קדושים אלו מים <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ו\" data-order=\"6\"></i>אחרונם",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כי קדוש זה שמן הטוב",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>לא קשיא כאן באור ששבת כאן <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"ב\" data-order=\"2\"></i>באור שלא שבת.",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "</b> כלומר כי קתני מברכין על האור בין במוצאי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "שבת בין ביום הכפורים זהו באור ששבת שהרי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ביום הכפורים לא היה יכול ליהנות ממנו כמו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "שלא היה יכול ליהנות בשבת ולפיכך מברכין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עליו ומאי דקתני אין מברכין על האור אלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "במוצאי שבת מיירי באור היוצא מן העצים ומן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "האבנים (עכשיו) דמש\"ה <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"ג\" data-order=\"3\"></i>(לא) קאמר אלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "במוצאי שבת בלבד מפני שבמוצאי יום הכפורים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אין מברכין עליו שבמוצאי שבת כיון שלא היה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יכול ליהנות ממנו בשבת שהרי לא היה עדיין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בעולם אין מברכין עליו אלא מפני שתחלת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברייתו היתה במוצאי שבת מברך אבל במוצאי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יום הכפורים שאין לומר זה הטעם אין מברכין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עליו ובגחלים ששבתו והדליקו מהן במוצאי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יום הכפורים נראה שמברכין על הנר שהדליקו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מהם ואית דבעו מימר דכמו אש היוצא מן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "העצים ומן האבנים דיינינן להו ואין זה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נראה דודאי ליכא למיחש למידי שהרי הגחלים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הראשונים הם של היתר שכבר שבתו והנר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהדליקו מהן ג\"כ הוא של היתר ודאי ליכא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "למיחש למידי ומברכין עליו. מפי מורי הרב",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נר\"ו: <b>מתני' מי שאכל ושכח ולא בירך וכו'",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ב\"ש אומרי' מברך על היין ואח\"כ מברך על",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המזון.</b> (גמרא דף נב.) וטעמייהו דב\"ש משום",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דסבירא להו דברכה אינה טעונה כוס ולפיכך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "היו אומרים שאע\"פ שאין שם כוס אחר לא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חיישינן להכי ויברך על זה בורא פרי הגפן",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואח\"כ יאמר בהמ\"ז בלא כוס וב\"ה ס\"ל דברכה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "טעונה כוס כלומר כל שעה שיהיה לו יין",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ויוכל לעשות בכוס יש לו לברך בכוס ולפיכך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "היו אומרים מברך על המזון ואח\"כ מברך על",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
