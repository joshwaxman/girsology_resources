  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>באמן</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "יהא שמו הגדול מבורך ומסקנא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דלא פסיק: גרסינן בפרק כל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כתבי הקדש (שבת דף קיט:) א\"ר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהושע בן לוי כל העונה אמן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהא שמיה רבא מברך בכל כחו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קורעין לו גזר דינו של ע' שנה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שנאמר (שופטים ה׳:ב׳) בפרוע",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פרעות בישראל <i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>מה טעם משום",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דברכו ה': גרסי' בסוטה (סוטה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דף מ.) בזמן ששליח ציבור אומר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מודים העם מה הם אומרים אחריו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Hagahot HaBach\" data-label=\"ב\" data-order=\"2\"></i>מודים אנחנו לך ה' אלהינו על",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שאנו מודים לך ושמואל אמר ה'",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלהינו ואלהי כל בשר על שאנו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מודים לך ר' סימאי אומר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יוצרנו יוצר בראשית על שאנו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מודים לך נהרדעי אמרי משום",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רבי סימאי ברכות והודאות לשמך",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הגדול על שהחייתנו וקיימתנו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"א\" data-order=\"1\"></i>רב אחא בר יעקב מסיים בה הכי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כן תחיינו ותחננו ותקבצנו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ותקבץ גליותינו לחצרות קדשך",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לשמור חקיך ולעבדך ולעשות",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רצונך <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"ב\" data-order=\"2\"></i>על שאנו מודים לך אמר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב פפא הלכך נימרינהו לכולהו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דנימא הכי מודים אנחנו לך ה'",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלהינו ואלהי כל בשר יוצרנו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יוצר בראשית ברכות והודאות",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לשמך הגדול על שהחייתנו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וקיימתנו כן תחיינו ותנחמנו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ותקבצנו ותאסוף גליותינו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לחצרות קדשך לשמור חקיך",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ולעבדך ולעשות רצונך <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"ג\" data-order=\"3\"></i>בלבב שלם",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "על שאנו מודים לך: כתב רבינו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "האי גאון זצ\"ל דמנהגא דרבנן",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כד עייל איניש לבי כנישתא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואשכח צבורא דמצלי בלחש דמעכב",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עד דמסיימי וכד פתח שליחא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דציבורא מתחיל ה' שפתי תפתח",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואומר בהדי שליחא דציבורא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מילתא בלחש ועני קדושה בהדי",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "צבורא ושפיר דמי למעבד הכי",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דלית בה הפסקה והא דאמור רבנן",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אם יכול להתחיל ולגמור היכי",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דמתחיל מקמי שליח צבור אבל כד",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתחיל בהדי שליח צבור שפיר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דמי: <i data-commentator=\"Mishneh Torah, Prayer and the Priestly Blessing\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Tefillin, Mezuzah and the Torah Scroll\" data-label=\"⚬\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Reading the Shema\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Blessings\" data-label=\"⚬\"></i>ר' יהודה אומר מברך",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לפניהם ולאחריהם (דף כב.)",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תניא רבי יהודה בן בתירא אומר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אין דברי תורה מקבלין טומאה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ומעשה בתלמיד אחד שהיה מגמגם",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וקורא למעלה מרבי יהודה בן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בתירא ואמר לו בני פתח פיך",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ויאירו דבריך שאין דברי תורה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מקבלין טומאה שנא' (ירמיהו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כ״ג:כ״ט) הלא כה דברי כאש נאם",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ה' מה אש אינה מקבלת טומאה אף",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דברי תורה אינן מקבלין טומאה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר רב נחמן בר יצחק נהוג",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עלמא כתלתא סבי כרבי יהודה בן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בתירא בדברי תורה כרבי יאשיה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בכלאים כרבי אלעאי בראשית",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הגז כי אתא זעירי אמר בטלוה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לטבילותא ואמרי לה בטלוה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לנטילותא מאן דאמר לטבילותא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כר' יהודה בן בתירא ומ\"ד",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לנטילותא כרב חסדא דרב חסדא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לייט מאן דמהדר אמיא בעידן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "צלותא איכא מאן דאמר האי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאמרי בטלוה לטבילותא בין",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לדברי תורה בין לתפלה ואיכא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מ\"ד הני מילי לדברי תורה אבל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לתפלה צריך טבילה ולאו טבילה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דוקא אלא רחיצה בט' קבין וכתב",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רבינו האי גאון זצ\"ל כיון",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דגמרא ליכא בהא מילתא נקוט",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מנהג כל ישראל שכל בעלי קריין",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אע\"פ שאין להם <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i> מים אין",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתפללין עד שירחצו: <b><big>מתני'</big></b> היה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עומד בתפלה ונזכר שהוא בעל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קרי לא יפסיק אלא יקצר ירד",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לטבול אם יכול לעלות ולהתכסות",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
