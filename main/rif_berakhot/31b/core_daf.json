  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<span class=\"sentence\" id=\"0\" type=\"start\">☆</span><big><strong>אמר</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "רב חסדא אמר רב על כל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "המוגמרות כולן מברכין עליהם",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>בורא עצי בשמים חוץ ממושק\"א",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>שמין חיה הוא שמברכין עליו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בורא מיני בשמים ומשחא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאפרסמא מברכין עליה בורא שמן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ערב <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>וכשרתא <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ד\" data-order=\"4\"></i>ומשחא כבישא ומשחא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "טחינא כולהו מברכינן עלייהו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בורא עצי בשמים (דף מא:)",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וסימל\"ק וחלפי <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ה\" data-order=\"5\"></i>דימא מברכינן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עלייהו בורא עצי בשמים ונרקום",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ו\" data-order=\"6\"></i>דגנוניתא מברכינן עלייהו בורא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עצי בשמים דדברא בורא עשבי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בשמים <sup class=\"footnote-marker\">*</sup><i class=\"footnote\">כ\"ה בספרי הרי\"ף",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הישנים</i>[אמר רב ששת הני סיגלי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מברך עלייהו עשבי בשמים] אמר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מר זוטרא האי <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ז\" data-order=\"7\"></i>מאן דמורח",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "באתרוגא או בחבושא אומר ברוך",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שנתן ריח טוב בפירות: אמר מר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהודה האי מאן דנפיק ביומי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ניסן וחזא אילני דקא מלבלבי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אומר ברוך שלא חיסר בעולמו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כלום וברא בו בריות טובות",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואילנות טובות כדי להתנאות",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בהן בני אדם: אמר <sup class=\"footnote-marker\">*</sup><i class=\"footnote\">באלפסי של",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הב\"ח מר</i>רב זוטרא בר טוביה אמר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב מנין שמברכין על ריח טוב",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שנאמר (תהילים ק״נ:ו׳) כל",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הנשמה תהלל יה איזהו דבר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שהנשמה נהנית ממנו ואין הגוף",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נהנה ממנו הוי אומר זה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הריח: תנו רבנן הביאו לפניהם",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שמן והדס בית שמאי אומרים",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מברך על השמן ופוטר את ההדס",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ובית הלל אומרים מברך על ההדס",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ופוטר את השמן אמר רבן גמליאל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אני אכריע שמן זכינו לריחו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וזכינו לסיכתו הדס לריחו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "זכינו לסיכתו לא זכינו אמר ר'",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יוחנן הלכה כדברי המכריע רבא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר הלכה כבית הלל והלכתא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כרבא <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ח\" data-order=\"8\"></i>דבתרא הוא: תנו רבנן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הביאו לפניו שמן ויין ב\"ש",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אומרים אוחז את השמן בימינו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואת היין בשמאלו ומברך על",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "השמן <sup class=\"footnote-marker\">*</sup><i class=\"footnote\">בס\"י וחוזר ומברך</i>ואחר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כך על היין ובית הלל אומרים",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אוחז את היין בימינו ואת השמן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בשמאלו ומברך על היין <sup class=\"footnote-marker\">*</sup><i class=\"footnote\">בס\"י",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וחוזר ומברך</i>ואחר כך מברך על",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "השמן וטחו בראש השמש ואם שמש",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תלמיד חכם הוא טחו בכותל מפני",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שגנאי הוא לתלמיד חכם שיצא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כשהוא מבושם לשוק תנו רבנן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ששה דברים גנאי הוא לתלמיד",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חכם אל יצא כשהוא מבושם לשוק",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואל יצא יחידי בלילה ואל יצא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "במנעלים מטולאים ואל יספר עם",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אשה בשוק ואל ישב בחבורה של",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עמי הארץ ואל יכנס באחרונה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לבית המדרש ויש אומרים אל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יפסיע פסיעה גסה ואל יהלך",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בקומה זקופה: אל יצא כשהוא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מבושם לשוק <i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>במקום שחשודין",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"א\" data-order=\"1\"></i>אותו על משכב זכור ולא אמרן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלא בבגדו אבל בגופו זיעה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מעברא ליה ואל יצא יחידי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בלילה משום חשדא ולא אמרן אלא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דלא קביע ליה עידנא אבל קביע",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ליה עידנא מידע ידעי דלעידניה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קא אזיל ואל יצא במנעלים",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מטולאים ולא אמרן <i data-commentator=\"Hagahot Chavot Yair\" data-label=\"א\" data-order=\"1\"></i>אלא בטלאי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "על גבי טלאי ובפינתא ובימות",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "החמה אבל בגילדא או בימות",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הגשמים לית לן בה ואל יספר עם",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אשה בשוק ואפילו היא אשתו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואפילו היא בתו או אחותו לפי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שאין הכל בקיאין בקרובותיו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואל ישב בחבורה של עמי הארץ",
