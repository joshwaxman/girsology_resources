  "rashi": [
    {
      "width": "450px",
      "text": "<b>מאימתי קורין את שמע בשחרית.</b> משיכיר בין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "תכלת ללבן היינו משעלה עמוד השחר שיש אור",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קצת שיכול להבחין בין תכלת ללבן. <b>רבי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אליעזר אומר בין תכלת לכרתי.</b> שצריך אור",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יותר להכיר בין תכלת לכרתי שדומים זה לזה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יותר מתכלת ולבן. <b>עד הנץ החמה.</b> ר' אליעזר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "סבר זמנה של קריאת שמע של שחרית עד הנץ",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "החמה. <b>רבי יהושע אומר עד שלש שעות.</b> שכן",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דרך בני מלכים לעמוד משנתם בשלש שעות",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ונמצא שעדיין זמן קימה הוא. <b>הלכה כרבי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יהושע.</b> ועד שלש שעות דוקא ומשלש שעות",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ולהלן יצא ידי חובת קריאה בתורה.",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    }
  ],
  "tosafot": [
