  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>סימן</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "לדבר <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>צאת הכוכבים <i data-commentator=\"Hagahot Chavot Yair\" data-label=\"א\" data-order=\"1\"></i>ואע\"פ שאין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ראיה לדבר זכר לדבר שנאמר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "(נחמיה ד׳:ט״ו) ואנחנו עושים",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "במלאכה וחצים מחזיקין ברמחים",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מעלות השחר עד צאת הכוכבים",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואומר (נחמיה ד׳:ט״ז) והיו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לנו הלילה משמר והיום",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מלאכה שמעינן השתא דבין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "למתניתין ובין לברייתא עונת",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ק\"ש לרבנן משעה שהכהנים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נכנסין לאכול בתרומתן דהיא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שעת צאת הכוכבים והכין <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>הלכתא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דקיימא לן יחיד ורבים הלכה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כרבים והאי דאקשינן דר'",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אליעזר אדר' אליעזר דתניא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מאימתי מתחילין לקרות ק\"ש",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בערבין משעה שקדש היום בערבי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שבתות דברי רבי אליעזר ותנן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נמי במתניתין משעה שהכהנים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נכנסין לאכול בתרומתן דברי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ר\"א לאו למימרא <sup class=\"footnote-marker\">*</sup><i class=\"footnote\">י\"נ",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דההוא</i>דהאי דקתני במתניתין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "משעה שהכהנים נכנסין לאכול",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בתרומתן לר' אליעזר בלחוד היא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלא בין רבי אליעזר בין רבנן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הכי סבירא להו דהא לא אפליגו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רבנן עליה דרבי אליעזר אלא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בעד סוף דרבי אליעזר סבר עד",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "סוף האשמורה הראשונה ורבנן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "סברי עד חצות אבל במשעה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שהכהנים נכנסין לאכול בתרומתן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לא פליגי דאי לא סבירא להו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לרבנן משעה שהכהנים נכנסין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לאכול בתרומתן אלא ר\"א בלחוד",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הוא דסבירא ליה הכי הוה להו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לרבנן לאיפלוגי עליה במשעה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כדאפליגו עליה בעד סוף ומדלא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אפליגו עליה אלא בעד סוף",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שמעינן דבין לר\"א ובין לרבנן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כולהו סבירא להו משעה שהכהנים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נכנסין לאכול בתרומתן וכיון",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דס\"ל לר\"א בהדי רבנן משעה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שהכהנים נכנסין לאכול בתרומתן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואשכחינן ליה בברייתא דס\"ל",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "משעה שקדש היום בערבי שבתות",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אקשינן (דף ג.) דידיה אדידיה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ופרקינן תרי תנאי אליבא דר\"א",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ולהאיך פירוקא בתרא דאמרינן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "איבעית אימא סיפא רבי אליעזר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רישא לאו ר\"א ברירא מילתא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דמשעה שהכהנים נכנסין לאכול",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בתרומתן לרבנן בלחוד היא ולאו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רבי אליעזר הלכך בין לפרוקא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קמא בין לפרוקא בתרא האי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דקתני במתניתין משעה שהכהנים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נכנסין לאכול בתרומתן איתא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לרבנן וכיון דאיתא לרבנן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עבדינן כוותייהו: עד סוף",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "האשמורה הראשונה <i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>: (דף ח:)",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר רב יהודה אמר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>ורבינו</b> האי גאון ז\"ל אומר בדרך אחרת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "שמתפלל עם הצבור בבית הכנסת ויקרא ק\"ש כמו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "שקורא פסוקים כדי להתפלל מתוך דברי תורה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "כמו שאמרו בירושלמי ולא יקרא הברכות גם לא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "יענה אמן בכונה לצאת ידי חובה אלא אם ירצה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לאומרה עם הקהל בלא חתימה ובלא פתיחה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הרשות בידו ולאחר יציאת הכוכבים יקרא ק\"ש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עם ברכותיה לצאת ידי חובתו ואע\"פ שאינו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "סומך גאולה לתפלה שהרי מתפלל תחלה וקורא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ק\"ש אח\"כ עם ברכותיה לכונת חובה אפילו הכי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מותר לעשות כן כיון שמתכוין למצוה להתפלל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עם הצבור שהתפלה נשמעת יותר ומקובלת לפני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המקום וראיה לדבר מדאמרי' לקמן (דף כז.)",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רב צלי של שבת בע\"ש כלומר קודם שקיעת החמה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ובודאי לא היה קורא ק\"ש באותה שעה כיון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שלא יצאו הכוכבים נמצא שלא היה סומך גאולה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לתפלה ואפילו הכי לא היה חושש כיון שהיה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עושה כן למצוה לקבל שבת מבעוד יום ולהוסיף",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מחול על הקודש שהוא מצוה גדולה הכא נמי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אע\"פ שאינו סומך גאולה לתפלה כיון שמתפלל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עם הצבור מותר: <b>ומי</b> שירצה להחמיר על עצמו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יכול לעשות בדרך אחרת יותר נכונה שיקרא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בבית הכנסת ק\"ש והברכות בלא חתימה ופתיחה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ויתפלל עם הצבור ואותה התפלה יתפלל על שם",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נדבה שהרי אברים ופדרים של עולת נדבה נמי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קרבין כל הלילה ואח\"כ בביתו יקרא ק\"ש אחר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יציאת הכוכבים בברכותיה בפתיחות וחתימות",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ויתפלל לשם חובה ובזה יהיה הכל מתוקן",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאותה שבב\"ה תהיה לעמוד בתפלה מתוך ד\"ת",
      "segment_ids": [
