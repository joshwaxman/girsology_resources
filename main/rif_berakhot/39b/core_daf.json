  "rashi": [
    {
      "width": "1010px",
      "text": "<b>לא קשיא הא לכתחלה הא לבסוף.</b> פי' ר\"ח ז\"ל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "דמתחלה אין מברכין עליו מפני שבאותה שעה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "אינו עשוי להאיר אלא לבשל בו הקדרות או",
