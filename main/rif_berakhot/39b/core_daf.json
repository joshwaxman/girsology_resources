        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בשוקי טבריא בערבי שבתות.</b> פי' בטבריא היה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מנהגם לגמר את הכלי בערבי שבתות מפני כבוד",
