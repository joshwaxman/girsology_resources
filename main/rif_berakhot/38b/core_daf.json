  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>על</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "היום ואח\"כ מברך על היין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שהיום גורס ליין שיבא וכבר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קדש היום ועדיין יין לא בא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ובה\"א מברך על היין ואחר כך",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מברך על היום שהיין גורם",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לקדושה שתאמר: דבר אחר ברכת",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היין תדירה וברכת היום אינה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תדירה ותדיר ושאינו תדיר תדיר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קודם: ב\"ש אומרים נוטלין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לידים ואח\"כ מוזגין את הכוס",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וב\"ה אומרים מוזגין את הכוס",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>ואחר כך נוטלין לידים מאי כוס",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כוס של קדוש היום הוא: <b><big>מתני'",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "</big></b> <i data-commentator=\"Tur\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Blessings\" data-label=\"⚬\"></i>בית שמאי אומרים מכבדין את",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הבית ואחר כך נוטלין לידים",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ובית הלל אומרים נוטלין לידים",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואחר כך מכבדין את הבית: <b><big>גמ'",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "</big></b> (דף נב:) מאי טעמא דבית שמאי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "משום פירורין ובית הלל סברי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הכא בשמש תלמיד חכם עסקינן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שמניח פירורין שאין בהן כזית",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ונוטל פירורין שיש בהן כזית",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מסייע ליה לרבי יוחנן דאמר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פירורין שאין בהן כזית מותר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לאבדן ביד במאי קא מיפלגי בית",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שמאי סברי מותר להשתמש בשמש",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עם הארץ ובית הלל סברי אסור",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "להשתמש בשמש עם הארץ אמר רבי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יצחק ברבי חנינא אמר רב הונא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בכוליה פירקין הלכה כבית הלל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בר מהאי דהלכה כבית שמאי:",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<b><big>מתני'</big></b> <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>בית שמאי אומרים נר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ומזון ובשמים והבדלה ובית הלל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>אומרים נר ובשמים ומזון",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והבדלה: <b><big>גמ'</big></b> איכא מרבוואתא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מ\"ד דהאי מזון דקתני במתניתין",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ברכת המוציא היא ושמיעה ליה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מהאי מתניתין דמבדלינן אריפתא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וקא מוקים לה למתניתין במוצאי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שבת ליום טוב דכיון דבעי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "למימר קידושא אריפתא משלשל לה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "להבדלה אבתרה והאי דאיצטריך",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ליה למימר הכי משום דקשיא לי'",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ההיא דאמימר (פסחים קז.)",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאיקלע לבי רב אשי ולא הוה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "להו חמרא לאבדולי ובת טות",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ומשום הכי איצטריך לאוקמא להא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>מתניתא במוצאי שבת ליום טוב",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וקא מוקים להא דאמימר בשאר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ימות השנה כי היכי דלא תיקשי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ליה ההיא דאמימר והא מילתא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ליתא דלא אשכחן הבדלה על הפת",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כל עיקר והא דקתני במתניתין",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נר ומזון ובשמים והבדלה לאו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אברכת המוציא קאי דשמעת מינה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דמבדלינן אריפתא אלא אברכת",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "המזון קאי דהיא שלש ברכות",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ובהדיא קתני בתוספתא אמר ר'",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהודה לא נחלקו בית שמאי וב\"ה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "על ברכת",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>גמ' שהיום גורם ליין שיבא.</b> כלומר שאם לא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "בעבור השבת לא היינו צריכין להביא יין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "לקדש ונמצא שהעיקר תלוי בשבת ועוד שהשבת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "קודם שכבר קידש היום ועדיין יין לא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "בא: <b>שהיין גורם לקידוש שתאמר.</b> והוא הדין",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שיכול לקדש על הפת והכי קאמר שגם היין",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "גורם לקידוש שתאמר כמו הפת וכיון שיש לו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חשיבות כמו הפת מברכין עליו תחלה: <b>ותדיר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ושאינו תדיר תדיר קודם.</b> נפקא לן מקרא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "(זבחים פט.) מלבד עולת הבוקר אשר לעולת",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "התמיד וכו' דמשמע אחר שתעשו עולת התמיד",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "תעשו את אלה: <b>מתני' ב\"ש אומרים מכבדין את",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הבית ואח\"כ נוטלין לידים וכו'.</b> פירוש",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מנהגם היה אחר אכילה קודם ברכת המזון לסלק",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "השולחן ולכבד המקום מן העצמות והפירורין",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שנפלו שם וב\"ש ס\"ל שמתחלה יש לו לכבד הבית",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואח\"כ יטול ידיו מפני שאם נוטל ידיו תחלה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יפלו המים על הפירורים של הלחם שנפלו תחת",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "השולחן בשעת אכילה דס\"ל שמותר להשתמש בשמש",
