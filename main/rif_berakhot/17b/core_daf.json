        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דכתיב (דברים ז) האל הנאמן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ההוא כמה דאת אמר אלהא מהימנא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אבל שם גופיה לא איקרי נאמן",
      "segment_ids": [
