        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תפילין ואצ\"ל שאינו מניח <sup class=\"footnote-marker\">*</sup><i class=\"footnote\">שם",
      "segment_ids": [
