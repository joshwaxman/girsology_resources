        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>הימנותא בבית הכסא ואע\"ג",
      "segment_ids": [
        0,
