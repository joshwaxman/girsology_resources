      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Blessings\" data-label=\"⚬\"></i>המרחץ אומר יהי רצון מלפניך",
      "segment_ids": [
