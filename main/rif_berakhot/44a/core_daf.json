  "rashi": [
    {
      "width": "1010px",
      "text": "<b>גמ'</b> רבי יוחנן אמר אחד זה ואחד זה צריך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "לברך מכלל דכי קנה וחזר וקנה דברי הכל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "שאינו צריך לברך <i data-commentator=\"Hagahot HaBach\" data-label=\"ג\" data-order=\"3\"></i>וכבר קנה כיוצא בהן לישנא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "אחרינא אמר רב הונא לא שנו וכו'. כך היא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "הגרסא במקצת הספרים וה\"פ לא שנו שמברך",
      "segment_ids": [
