      "text": "<big><strong>אומר</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "ברוך דיין האמת: <b><big>גמ'</big></b> <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>על ניסא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דרבים מברכין ועל ניסא דיחיד",
