        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וענה החולה אמן אין צריך לברך ברכה אחרת",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואם אין שם י' צריך לברך ונראה שהם יכולים",
