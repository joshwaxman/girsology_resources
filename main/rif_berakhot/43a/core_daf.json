        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דהוו שם י' וענה איהו אמן ולפיכך נפטר בזה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "למדנו משם שאם יש שם עשרה וברכו ברכה זו",
