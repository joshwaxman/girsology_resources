  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>כל</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "המוקדם בפסוק זה הוא קודם",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לברכה אמר ליה זה שני לארץ",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וזה חמישי לארץ אמר ליה מאן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהיב לן נגרי דפרזלא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ונשמעינן: איתמר הביאו לפניהם",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תאנים וענבים בתוך הסעודה אמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב הונא טעונין ברכה לפניהם",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואין טעונין ברכה לאחריהם וכן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר רב נחמן ורב ששת אמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "טעונין ברכה בין לפניהם בין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לאחריהם שאין לך דבר שטעון",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ברכה לפניו ואין טעון ברכה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לאחריו אלא פת הבאה בכסנין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בלבד ופליגא דרבי חייא דאמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רבי חייא פת <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>פוטרת כל מיני",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מאכל ויין פוטר כל מיני",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "משקין: אמר רב פפא הלכתא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דברים הבאים <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Blessings\" data-label=\"⚬\"></i>מחמת <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>הסעודה בתוך",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הסעודה אין טעונין ברכה לא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לפניהם",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>שאין</b> לך דבר שטעון ברכה לפניו ואין טעון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ברכה לאחריו אלא פת הבאה בכסנין פרש\"י ז\"ל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "דכסנין הוא מיני קליות כדאמרי' (עירובין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "דף כט:) כיסני מעלו ללבא וכדאמרי' בכתובות",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "(דף יז:) ארמלתא לית לה כסני ומנהגם היה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לאכול תחלה הקליות ואחר הקליות היו אוכלין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "פת ידוע שהיו בו מיני תבלים הרבה ומפני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "התבלים אין דרך לאכול ממנו כל כך ומש\"ה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אמרו שזה הפת שאוכלין אחר הקליות שטעון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברכה לפניו במ\"מ ואין טעון ברכה לאחריו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ופי' הרב ז\"ל דה\"ק אין לך דבר שטעון ברכה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לפניו ולא יהיה טעון ברכה לאחריו מעין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הברכה שלפניו אלא זה הפת הבאה בכסנין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שלפניו במ\"מ ולאחריו אינו אומר מעין ג'",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אלא בורא נפשות והוצרך לכתוב כן מפני שלפי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דבריו שאינו מפרש הדבר בתוך הסעודה אלא כל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שעה ושעה שירצה היאך אפשר לומר שלא יברך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אחריו כלל כיון שאין לו לברך ברכת המזון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וזה הפי' אינו נכון דכיון דהוצרך לברך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אחריו בורא נפשות היאך אמר ואין טעון ברכה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "<i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"א\" data-order=\"1\"></i>לאחריו שהרי טעון הוא הברכה הראויה לו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמפני שאין זה דרך אכילה כ\"כ מרוב התבלין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שבו אמרינן שאינו מברך עליו אלא בורא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נפשות וכיון שמברך עליו לאחריו הברכה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הראויה לו הרי טעון ברכה לאחריו כשאר כל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הדברים ועוד הקשו עליו רבני צרפת ז\"ל שאם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדבריו שאומר שטעון ברכת בורא נפשות",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לאחריו היאך אומר אין לך דבר שטעון ברכה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לפניו ואין טעון ברכה לאחריו והא איכא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אורז ודוחן שטעונין לפניהם במ\"מ ואין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "טעונין לאחריהם אלא בורא נפשות וע\"כ נראה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כמו שפי' ר\"ח ז\"ל דפת הבאה בכסנין ר\"ל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הבאה בכיסין שעושין מן העיסה כמו כיס",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומכניסין בפנים שקדים ודבש ומיני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מתיקה: <b>ואומרים</b> רבני צרפת ז\"ל דמיירי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כשמביאין אותו אחר סיום המאכל ומתוך כך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אמרינן שטעון ברכה לפניו מפני שסיים",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מלאכול ואינו מצטרף עם מה שאכל כיון",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמברכין <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"ב\" data-order=\"2\"></i>עליו מתחלה אבל לאחריו אין צריך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שום ברכה כלל שמאחר שעדיין יש לו לברך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברכת המזון על אכילתו מצטרף גם זה עם כל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאר האכילה וברכת המזון פוטרת אותו. עוד",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נראה למורי הרב נר\"ו להעמיד הדבר באמצע",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הסעודה ממש לפי משמעות הלשון שהזכירו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בתלמוד ואמרו בתוך הסעודה וה\"ק אין לך דבר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שבא בתוך הסעודה וטעון ברכה לפניו ואין",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "טעון ברכה לאחריו אלא פת הבאה בכסנין שזה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הפת כיון שאינו מזון אלא מיני מתיקות שיש",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בו אינו מצטרף לענין ברכה ראשונה עם הפת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאכל מתחלה שהוא מזון ואע\"פ שעדיין יש לו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לאכול פת אחרת שזהו בתוך הסעודה ממש אפ\"ה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אינו מצטרף עמו לענין ברכה שלפניו ולפיכך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "צריך לברך עליו מתחלה אבל לאחריו אינו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מברך כלל שכבר נטפל עם שאר הדברים וברכת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שלשה פוטרת אותו ואע\"פ <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"ג\" data-order=\"3\"></i>שפי' המימרא בתוך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הסעודה ממש אפ\"ה מה שאומרים רבני צרפת ז\"ל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאחר הסעודה כיון שסיימו מלאכול צריך לברך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לפניו אמת הוא כמו שיתברר במתני' דבירך על",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "היין שלפני המזון וכו': <b>ופליגא</b> דרבי חייא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דאמר פת פוטרת כל מיני מאכל ויין פוטר כל",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מיני משקין אע\"פ שהאמוראים <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"ד\" data-order=\"4\"></i>אינם חולקין עם",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "התנאים בא להשמיענו כאן שאינם סוברים דברי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רבי חייא בזה והפת אינה פוטרת כל מיני",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
