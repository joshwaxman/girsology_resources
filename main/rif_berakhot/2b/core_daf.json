  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>במזיד</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "או בפשיעה לא יצא ידי חובתו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאמרינן (דף ט.) כי אתא ר'",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יצחק בר' יוסף אמר הא דר\"י בן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לוי לאו בפירוש אתמר אלא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מכללא אתמר דהנהו זוגא דרבנן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאשתכור בהלולא דבריה דר\"י בן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לוי ולא קרו ק\"ש אתו לקמיה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דרבי יהושע בן לוי אמר להו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כדאי הוא ר\"ש בן יוחאי לסמוך",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עליו בשעת הדחק <i data-commentator=\"Hagahot Chavot Yair\" data-label=\"א\" data-order=\"1\"></i><i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>וכן הא דרשב\"י",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאמר פעמים שאדם קורא ק\"ש של",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שחרית לאחר שיעלה עמוד השחר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בדיעבד הוא אי נמי בשעת הדחק",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כגון <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>מי שהיה משכים לצאת לדרך",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וכיוצא בו אבל לכתחלה לא: אמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מר (דף ד:) קורא ק\"ש ומתפלל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Mishneh Torah, Prayer and the Priestly Blessing\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>מסייע ליה לרבי יוחנן דאמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "איזהו בן העוה\"ב זה הסומך",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "גאולה של ערבית לתפלה של",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ערבית <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>ורבי יהושע ב\"ל אומר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תפלות באמצע תקנום שבשחרית",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קורא ק\"ש ומתפלל ובשעת המנחה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתפלל תפלת המנחה ולערב מתפלל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תפלת הערב ואח\"כ קורא ק\"ש",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נמצאת ק\"ש של שחרית בתחלת",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היום וק\"ש של ערבית בתחלת",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הלילה והתפלות כולן באמצע",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וליתא לדר' יהושע בן לוי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וקי\"ל כר' יוחנן דתניא מסייע",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ליה ואע\"ג דצריך לומר <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ד\" data-order=\"4\"></i><i data-commentator=\"Mishneh Torah, Prayer and the Priestly Blessing\" data-label=\"⚬\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>השכיבנו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בין גאולה לתפלה לאו מפסיק",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הוא דכיון דתקנו רבנן השכיבנו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בגאולה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>אי נמי בשעת הדחק כגון מי שהיה משכים לצאת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "לדרך וכו'.</b> יש מדקדקים על זה הלשון שכתב",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "הרי\"ף דהא אמרי' (דף ל.) המשכים לצאת לדרך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "מביאין לו שופר ותוקע לולב ומנענע מגילה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "וקורא בה וכשיגיע זמן ק\"ש קורא ק\"ש אלמא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "משמע שיכול לקרותה בדרך והיאך אמר בכאן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שיקרא אותה קודם הנץ החמה שנראה שהצריכוהו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לאמרה קודם הזמן שיש לה לכתחלה מפני שאינו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יכול לאומרה בדרך ואומר מורי הרב שאין זו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קושיא דודאי דבר פשוט הוא שיכול לקרותה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בדרך ומה שכתב כגון שהיה משכים לצאת לדרך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ר\"ל שמשכים לצאת לדרך ויודע שהשיירה הולכ'",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "במהרה ולא ימתינו לו כלל ולפיכך אמרו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דכיון שהוא שעת הדחק שאינו יכול לעשות",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בענין אחר קורא קודם הנץ: <b>איזהו בן העוה\"ב",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "זה הסומך גאולה של ערבית לתפלה של ערבית.",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "</b> י\"ל וכי מפני שסומך גאולה לתפלה יש לו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שכר כל כך שיהיה בן עוה\"ב ואומר מורי הרב",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהטעם שזוכה לשכר גדול כזה מפני שהקב\"ה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כשגאלנו והוציאנו ממצרים היה להיותנו לו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לעבדים שנא' כי עבדי הם אשר הוצאתי אותם",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מארץ מצרים ובברכת גאל ישראל מזכיר בה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "החסד שעשה עמנו הבורא והתפלה היא עבודה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדאמרינן (בב\"ק דף צב:) ועבדתם את ה'",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אלהיכם זו היא תפלה וכשהוא מזכיר יציאת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מצרים ומתפלל מיד מראה שכמו שהעבד שקונה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אותו רבו חייב לעשות מצות רבו כן הוא מכיר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הטובה והגאולה שגאל אותו הבורא ושהוא עבדו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ועובד אותו וכיון שמכיר שהוא עבדו מפני",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שגאלו ועושה רצונו ומצותיו נמצא שבעבור זה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "זוכה לחיי העולם הבא ועוד אמר מורי נר\"ו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "טעם אחר מפני שכשמזכיר גאולת מצרים ומתפלל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מיד הוא מראה שבוטח בה' בתפלה כיון שמבקש",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ממנו צרכיו שמי שאינו בוטח בו לא יבקש",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ממנו כלום וכן נראה באלה שמות רבה בפרשת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בא אל פרעה שאומר לשם שכשראו ישראל הנסים",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "והנפלאות שהיה עושה עמהם הבורא שלא כטבעו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "של עולם בטחו בו ועל זה נאמר וירא ישראל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "את היד הגדולה אשר עשה ה' במצרים וייראו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "העם את ה' ויאמינו בה' וגו' וכיון שמזכיר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עכשיו אותה הגאולה שבטחו אבותינו בה'",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "והצילם ומתפלל מיד נמצא שגם הוא בוטח בו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שיענה אותו כמו שענה לישראל בעבור שבטחו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בו ומפני זה מזכיר אותה הגאולה ומתפלל מיד",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "והבטחון הוא עיקר היראה והאמונה ולפיכך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "זוכה בסיבתו לחיי עולם הבא: <b>ומאי</b> דאמרינן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "של תפלת ערבית לאו דוקא אלא מפני שתפלת",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ערבית רשות נקט ערבית וכל שכן תפלת",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שחרית: <b>ואע\"ג דצריך לומר השכיבנו בגאולה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כגאולה אריכתא דמיא.</b> והטעם שאינו הפסקה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מפני שהשכיבנו מעין הגאולה הוא שבשעה שעבר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
