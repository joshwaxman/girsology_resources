{
  "metadata": {
    "masechet_en": "Berakhot",
    "masechet_he": "ברכות",
    "daf": "12A",
    "type": "rif",
    "ry_on_right": false,
    "ry_header_lines": 4
  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>שלא</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "הזמן גרמא נשים <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>חייבות ונשים",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חייבות בקידוש היום דבר תורה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאמר קרא (שמות כ) זכור",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "(דברים ה) ושמור כל שישנו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בשמירה ישנו בזכירה והני נשי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הואיל ואיתנהו בשמירה איתנהו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בזכירה: <b><big>מתני'</big></b> <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>בעל קרי מהרהר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בלבו ואינו מברך לא לפניה ולא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לאחריה ועל המזון מברך לאחריו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואינו מברך לפניו רבי יהודה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אומר מברך לפניהם",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ולאחריהם: <b><big>גמ'</big></b> (דף כא.)",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>מתני' בעל קרי מהרהר כו'.</b> כלומר מי שראה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "קרי ולא טבל והגיע זמן ק\"ש כיון שק\"ש מן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "התורה מהרהר אותה בלבו בלא חיתוך שפתים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "כלל. ובגמ' (דף כ:) פליגי רבינא ורב חסדא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "דרבינא אמר דהרהור כדבור דמי ויוצא בהרהור",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ורב חסדא אמר דהרהור לאו כדבור דמי ומקשי'",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "התם לרבינא דאמר דהרהור כדבור דמי א\"כ למה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "התירו ההרהור כמו שהדבור אסור כך היה לנו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לאסור ההרהור כיון שדינן שוה ומתרצין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדאשכחן בסיני כלומר אע\"פ שיוצא מק\"ש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בהרהור כמו בדבור ודיניהן שוה זה כזה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אפילו הכי לענין הטהרה אין דיניהן שוה שלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נחוש אלא לדבור שכן מצינו בסיני שבעל קרי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נאסר שם דכתיב והיו נכונים לשלשת ימים אל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "תגשו אל אשה ולא נאסר שם אלא הדבור",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדילפינן (במכילתין כב.) מדכתיב והודעתם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לבניך ולבני בניך וסמיך ליה יום אשר עמדת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לפני ה' אלהיך בחורב <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"ב\" data-order=\"2\"></i>והידיעה א\"א אלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בדבור וכי היכי דהתם לא הזהיר בטהרה אלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לענין הדבור ה\"נ לא נחוש אלא לדבור אבל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בהרהור מותר תו מקשינן התם לרב חסדא דאמר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דהרהור לאו כדבור דמי למה מהרהר שהרי אין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ההרהור מועיל לו כיון שאינו יוצא כמו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בדבור ומהדרינן כדי שלא יהו כל ישראל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עסוקין והוא יושב בטל ולפיכך אמרו שיהרהר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "במה שהצבור עסוקים ואע\"פ שאינו יוצא ידי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חובה ולענין פסק הלכה נקטינן כרב חסדא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דאמר הרהור לאו כדבור דמי דסוגייא דגמרא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כותיה אזלא וכן פסקו הגאונים ז\"ל והביא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ראיה לדבריהם מדאמרינן במסכת שבת פרק שואל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "(דף קנ.) ודבר דבר דיבור אסור הרהור מותר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומקשי' עלה והאמר רבי יוחנן בכל מקום מותר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "להרהר חוץ מבית המרחץ ומבית הכסא כלומר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "היאך אתה מחלק בין דבור להרהור שהרי אנו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רואין בבית המרחץ ובבית הכסא שניהם שוין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וכמו שהדבור אסור כך ההרהור אסור ג\"כ",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומשני התם משום והיה מחנך קדוש כלומר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כשאסר ר' יוחנן ההרהור כמו הדיבור לא אסר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אלא גבי טינוף בלבד שבפרשת ושבת וכסית את",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "צאתך כתיב והיה מחנך קדוש מש\"ה החמירו בו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואמרו שהרהור אסור והנה נראה מכאן בפירוש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שלא אמר הרהור כדבור אלא גבי ענין זה בלבד",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "משום דכתיב והיה מחנך קדוש אבל בשאר מילי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הרהור לאו כדבור דמי <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"א\" data-order=\"1\"></i>ומהכא שמעינן דמאי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דאמר לעיל (דף טו:) אם בירך ברה\"מ בלבו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יצא אינו ר\"ל בהרהור אלא בחיתוך שפתים אלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שלא היה משמיע לאזנו דאי בהרהור הלב בלחוד",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ודאי לא יצא כדכתבינן התם (סי' מב): <b>ואינו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מברך לא לפניה ולא לאחריה.</b> כלומר אינו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מהרהר בברכות דבק\"ש שהוא מן התורה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הצריכוהו להרהר אבל בברכות שאינן אלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מדרבנן לא ואי אפשר לפרש אינו מברך בפה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאם כן היה נראה שבפה אינו מברך אבל מהרהר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בלבו ונמצא שאין חילוק בין ק\"ש לברכות אלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ודאי רוצה לומר שאע\"פ שמהרהר בק\"ש אינו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מהרהר בברכותיה: <b>ועל המזון מברך לאחריו.",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "</b> כלומר מהרהר אחריו מפני שהוא מן התורה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דכתיב ואכלת ושבעת וגו' אבל אינו מהרהר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לפניו שאותה ברכה אינה אלא מדרבנן כדי שלא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יהנה מן העולם הזה בלא ברכה: <b>רבי יהודה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אומר מברך לפניהם ולאחריהם.</b> כלומר בפה ור'",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יהודה בתרתי פליגי בהדי רבנן חדא בברכות",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דת\"ק אומר שאין ק\"ש והברכות שוות ומהרהר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "על ק\"ש ולא על הברכות ורבי יהודה אומר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דדינם שוה ופליג עליה באידך דתנא קמא היה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אומר מהרהר והוא היה אומר דאפי' הברכות",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מוציא בפה כ\"ש ק\"ש עצמה ואע\"פ שהיה אומר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ר' יהודה שק\"ש וברכותיה מוציא בשפתיו מודה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הוא דבשאר דברי תורה אין לו להוציא בשפתיו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
