  "gemara": [
    {
      "width": "377px",
      "text": "<span class=\"sentence\" id=\"0\" type=\"start\">☆</span>היה קורא בתורה והגיע זמן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "המקרא אם כיון לבו יצא ואם",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לאו לא יצא בפרקים שואל מפני",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הכבוד ומשיב ובאמצע שואל מפני",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היראה ומשיב דברי ר' מאיר רבי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהודה אומר באמצע שואל מפני",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היראה ומשיב מפני הכבוד",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בפרקים שואל מפני הכבוד ומשיב",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<span class=\"sentence\" id=\"1\" type=\"start\">☆</span>שלום לכל אדם אלו הן בין",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הפרקים בין ברכה ראשונה לשניה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בין שניה לשמע בין שמע לוהיה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אם שמוע בין והיה אם שמוע",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לויאמר רבי יהודה אומר בין",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ויאמר לאמת ויציב לא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יפסיק אמר רבי יהודה הלכה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כרבי יהודה באמצע וכן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הלכה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "450px",
      "text": "<b>היה קורא בתורה.</b> כלומר שקרא פרשת שמע",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בתורה כדרך לימודו והגיע זמן קריאת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמע. <b>אם כיון לבו יצא.</b> שמצות צריכות כוונה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וכיון שכיון לבו לצאת ידי חובת קריאת שמע",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יצא. <b>בפרקים שואל.</b> פרקים היינו בין הפרקים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "של קריאת שמע ובין הברכות. <b>שואל מפני",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הכבוד.</b> שואל בשלום אדם מכובד כגון אביו או",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רבו. <b>ומשיב מפני היראה.</b> משיב שלום לאדם",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמתיירא ממנו כגון אדם חשוב שאם לא ישיבנו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יקפיד עליו.",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    }
  ],
  "tosafot": [
    {
      "width": "450px",
      "text": "<b>היה קורא בתורה.</b> פירוש שהיה קורא פרשת שמע",
      "segment_ids": [
        0
      ],
      "right": "",
      "left": "0px"
    },
    {
      "width": "450px",
      "text": "מתוך התורה בשעת לימודו ולא נתכוון לצאת",
      "segment_ids": [
        0
      ],
      "right": "",
      "left": "0px"
    },
    {
      "width": "450px",
      "text": "ידי חובה. <b>אם כיון לבו יצא.</b> כתב הרמב\"ם",
      "segment_ids": [
        0,
        1
      ],
      "right": "",
      "left": "0px"
    },
    {
      "width": "450px",
      "text": "ז\"ל שמצות צריכות כוונה ואם לא כיון לבו",
      "segment_ids": [
        0,
        1
      ],
      "right": "",
      "left": "0px"
    },
    {
      "width": "450px",
      "text": "אף על פי שקרא לא יצא. <b>בפרקים שואל מפני",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "",
      "left": "0px"
    },
    {
      "width": "450px",
      "text": "הכבוד.</b> מי ששואל בפרקים שואל שלום לאדם",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "",
      "left": "0px"
    },
    {
      "width": "450px",
      "text": "מכובד ומשיב שלום מפני היראה.",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "",
      "left": "0px"
    }
  ],
  "english": [
    "If one was reading the Torah and the time for reciting Shema arrived, if he directed his heart, he has fulfilled his obligation.",
    "Between the sections one may greet out of respect and respond. In the middle of a section one may greet out of fear and respond."
  ]
}