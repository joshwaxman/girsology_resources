  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>בית</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "המדרש ולא שמת חלקי מיושבי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קרנות שאני משכים והם משכימין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אני משכים לדברי תורה והם",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "משכימין לדברים בטלים אני עמל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והם עמלים אני עמל ומקבל שכר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והם עמלים ואינם מקבלים שכר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אני רץ והם רצים אני רץ לחיי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "העולם הבא והם רצים לבאר שחת",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שנאמר (תהילים נ״ה:כ״ד) ואתה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלהים תורידם לבאר שחת",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וגו': <b><big>מתני'</big></b> רבן גמליאל אומר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בכל יום <i data-commentator=\"Mishneh Torah, Prayer and the Priestly Blessing\" data-label=\"⚬\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>מתפלל אדם שמונה עשרה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רבי יהושע אומר מעין שמונה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עשרה ר' עקיבא אומר אם שגורה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תפלתו בפיו מתפלל שמונה עשרה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואם לאו מעין שמונה עשרה: <b><big>גמ'",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "</big></b> הני תמני סרי תשסרי הויין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר ר' לוי ברכת המינין ביבנה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תקנוה ת\"ר שמעון הפקולי הסדיר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שמונה עשרה ברכות לפני ר'",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "גמליאל על הסדר ביבנה אמר להם",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רבן גמליאל לחכמים כלום יש",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אדם בכאן שיודע לתקן ברכה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "למינין ירד שמואל הקטן ותקנה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לשנה אחרת שכחה (דף כט.)",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והשקיף בה שתים ושלש שעות ולא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "העלוהו אמאי לא העלוהו והאמר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב יהודה אמר רב טעה בכל",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הברכות כולן אין <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>מעלין אותו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "טעה בברכת המינין מעלין אותו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חיישינן שמא מין הוא שאני",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שמואל הקטן דהוא תקנה ודלמא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הדר ביה אלא שאני שמואל הקטן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאתחיל בה דאמר רב יהודה אמר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב ואיתימא ר' יהושע בן לוי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לא שנו אלא שלא התחיל בה אבל",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "התחיל בה גומרה: ר' יהושע",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אומר מעין שמונה עשרה: מאי",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מעין שמונה עשרה רב אמר מעין",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כל ברכה וברכה ושמואל אמר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הביננו לדעת את דרכיך ומול את",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לבבנו ליראתך לסלוח היה לנו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לחיות גאולים רחקנו ממכאוב",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ודשננו בנאות ארצך והנפוצים",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מארבע כנפות הארץ תקבץ",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והתועים בדעתך ישפטו ועל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הרשעים תניף ידיך וישמחו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "צדיקים בבנין עירך ובתיקון",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היכלך ובהצמחת קרן לדוד עבדך",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ועריכת נר לבן ישי משיחך טרם",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נקרא אתה תענה טרם נדבר אתה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תשמע כי אתה עונה בכל עת צרה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וצוקה ופודה ומציל ברוך אתה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ה' שומע תפלה אמר רב נחמן אמר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שמואל כל השנה כולה מתפלל אדם",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>הביננו חוץ ממוצאי שבתות",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ומוצאי ימים טובים מפני שצריך",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לומר הבדלה בחונן הדעת: אמר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב ביבי בר אבין כל השנה כולה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתפלל אדם הביננו חוץ מימות",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הגשמים מפני שצריך לומר שאלה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בברכת השנים וקאמרי רבנן <i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>הני",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מילי בשעת הדחק אבל שלא בשעת",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הדחק אין מתפלל הביננו אמר ר'",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תנחום אמר רבי אסי <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i><i data-commentator=\"Mishneh Torah, Prayer and the Priestly Blessing\" data-label=\"⚬\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>טעה ולא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הזכיר גבורות גשמים <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ד\" data-order=\"4\"></i>בתחיית",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "המתים מחזירין אותו שאלה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בברכת השנים אין מחזירין אותו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מפני שיכול",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>גמ'</b> אני רץ לחיי העוה\"ב והם רצים לבאר שחת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "וא\"ת ולמה הוצרך לחזור זה והלא הוא בכלל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "מה שאמר תחלה אני עמל ומקבל שכר והם עמלים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ואינם מקבלים שכר י\"ל שהוא דבר בפני עצמו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "ור\"ל כשאני רואה שעוברים הימים והזמנים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אני מרגיש בעצמי שאני רץ בכל יום ומתקרב",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "למיתה ומפני זה אני מכין צדה לדרך כדי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאזכה לחיי העולם הבא אבל הם אינם מרגישין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "במיתתם כלל עד שעת המיתה ואינם מכינין צדה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לדרכם. מפי מורי הרב נר\"ו: <b>מתני' ר\"ג אומר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בכל יום מתפלל אדם י\"ח וכו'.</b>: <b>גמ'</b> הסדיר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "י\"ח ברכות על הסדר ביבנה שמתחלה לא היו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מתפללים אותה על הסדר אלא כל אחד ואחד",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הברכה שהיתה צריכה לו ובא שמעון הפקולי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לסדור אותם אחר כך על הסדר ולמד הסדר מכח",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הפסוקים כדאי' בגמ' דמגלה (דף יז:): <b>טעה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
