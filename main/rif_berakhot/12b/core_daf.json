  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>רב</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "יהודה אמר שמואל ספק קרא ק\"ש",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ספק לא קרא אינו חוזר <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>וקורא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ספק אמר אמת ויציב ספק לא אמר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חוזר ואומר אלמא קסבר ק\"ש",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דרבנן אמת ויציב דאורייתא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ורבי אלעזר אמר ספק קרא ק\"ש",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ספק לא קרא חוזר וקורא ספק",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "התפלל ספק לא התפלל אינו חוזר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ומתפלל ר' יוחנן אמר ולואי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שיתפלל אדם כל היום כולו ולית",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הלכתא כשמואל דאמר ק\"ש דרבנן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דקי\"ל ק\"ש דאורייתא והלכתא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כר' יוחנן דאמר הלואי שיתפלל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אדם כל היום כולו ומפרשי <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>רבנן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דהני מילי ביחיד ואדעתא דרשות",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אבל <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>אדעתא דחובה אסור וצבור",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>גמ'</b> אמר רב יהודה אמר שמואל ספק קרא ק\"ש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ספק לא קרא אינו חוזר וקורא דס\"ל לשמואל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "דק\"ש דרבנן ואע\"פ שכתוב בתורה ובשכבך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ובקומך ס\"ל לשמואל שלא אמרה תורה דוקא ק\"ש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "אלא שיקרא בתורה בכ\"מ שירצה ומה שאנו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קורין זאת הפרשה דוקא אינו אלא מדרבנן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ולפיכך ס\"ל אינו חוזר וקורא: <b>ספק</b> אמר אמת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ויציב ספק לא אמר אמת ויציב חוזר ואומר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דאמת ויציב דאורייתא כלומר זכירת יציאת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מצרים ויש ששואלין כיון שאמר יציאת מצרים",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בפרשה אחרונה של ק\"ש כבר יצא ידי קריאת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יצ\"מ מן התורה ולמה חוזר ואומר אמת ויציב",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ויש להשיב דשמעתא אהדדי אתמר והכי קאמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ספק קרא ספק לא קרא אינו חוזר ואומר אבל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ספק קרא ק\"ש וספק אמר אמת ויציב ספק לא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קרא ק\"ש וספק לא אמר אמת ויציב חוזר ואומר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אמת ויציב אבל אם ברי לו שכבר קרא ק\"ש",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואמר פרשה אחרונה אין צריך לומר אמת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ויציב: <b>והיכא</b> שצריך לחזור ולומר אמת ויציב",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נחלקו המפרשים בענין הברכה אם חותם בא\"י",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "גאל ישראל אם לא יש אומרים דכיון שכבר יצא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מספק של תורה בקריאת יציאת מצרים אינו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חותם בברכה על ספק דברכות מדרבנן נינהו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומספיקא אינו מוציא שם שמים לבטלה ומשום",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "סמיכת גאולה לתפלה אין צריך לאומרה דכיון",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמזכיר יציאת מצרים ומתפלל מיד זהו סמיכת",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "גאולה לתפלה שלא אמרו לסמוך גאולה לתפלה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אלא מפני יציאת מצרים ואינו תלוי בשיזכיר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לשון גאולה ממש וי\"א שצריך לחתום בברכה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ולזה נוטה דעת מורי הרב נר\"ו מפני שכיון",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהוא מסופק בדבר של תורה אם אמר אם לא אמר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מחוייב הוא עכשיו לומר הדבר כתקנו ואומר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אותו בברכה כאלו לא קרא כלל דכל דבר שהוא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ספק של תורה מברכין עליו ומביא ראיה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מדאמרינן בשבת בפ' במה מדליקין (דף כג.)",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דאין מברכין על הדמאי בשעה שמפרישין ממנו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המעשר ואמרינן התם טעמא מפני שהוא ספק של",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דבריהם <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"א\" data-order=\"1\"></i>דמשמע דדוקא מפני ספק של דבריהם",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אין מברכין עליו הא אם היה ספק של תורה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "צריך לברך עליו: <b>ספק</b> התפלל ספק לא התפלל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אינו חוזר ומתפלל אינו ר\"ל שאסור לחזור",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ולהתפלל דמה טעם יש שאם ירצה אדם להתפלל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דרך רשות שלא יתפלל אלא ר\"ל אינה חובה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עליו לחזור ולהתפלל דיקא נמי מדאמר רבי",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יוחנן הלואי שיתפלל אדם כל היום כולו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ובודאי <i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>דברי ר' יוחנן לא נאמרו לחובה שלא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אמר שיתפלל אדם כל היום כולו לחובה אלא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לרשות ומדחזינא דר' יוחנן איירי ברשות",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמעינן דר' אלעזר נמי ברשות מיירי: <b>והאי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "</b> דאמרינן הלואי שיתפלל אדם כל היום כולו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אומר רבינו האי גאון ז\"ל דדוקא על ידי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חידוש אבל בלא חידוש אסור ומביא ראיה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מדאמרי' לקמן אמר רב יהודה אמר שמואל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "התפלל ונכנס לב\"ה ומצא צבור שמתפללין אם",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יכול לחדש דבר אחד בתפלתו כדי שתהא תפלתו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "תחנונים יתפלל ואם לאו אל יתפלל הנה <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"ב\" data-order=\"2\"></i>שלא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "התירו אלא בחידוש ומאי דנקט צבור לא מפני",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהצבור צריך חידוש והיחיד לא דה\"ה דביחיד",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נמי צריך חידוש אבל רבותא קמ\"ל שאע\"פ",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהתפלל מתחלה לא אמרי' יחיד לגבי צבור",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כמאן דלא צלי דמי ואין צריך חידוש אלא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אפילו בצבור צריך חידוש: <b>ונראין דבריו",
