{
  "metadata": {
    "masechet_en": "Berakhot",
    "masechet_he": "ברכות",
    "daf": "15A",
    "type": "rif",
    "ry_on_right": false,
    "ry_header_lines": 4
  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>א\"ר</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "נחמן בר יצחק עד זמן ברכה וכן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הלכה אמר רב חסדא האי סודרא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאזמניה למיצר ביה תפילין וצר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ביה תפילין אסור למיצר ביה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "זוזי אזמניה ולא צר ביה צר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ביה ולא אזמניה שרי למיצר ביה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "זוזי מ\"ט הזמנה לאו מילתא היא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וכן הלכתא וליתא לדאביי דאמר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>הזמנה מילתא היא דגרסינן בפ'",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נגמר הדין (דף מז:) איתמר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "האורג בגד למת אביי אמר אסור",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ורבא אמר מותר אביי אמר אסור",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הזמנה מילתא היא ורבא אמר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מותר הזמנה לאו מילתא היא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וקיימא לן דאביי ורבא הלכה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כרבא בר מיע\"ל קג\"ם בעא מיניה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב יוסף בריה דרב נחוניא מרב",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהודה מהו שיניח אדם תפיליו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תחת מראשותיו תחת מרגלותיו לא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קא מיבעיא לי דכיון דבזיון",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הוא אסור כי קא מיבעיא לי תחת",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מראשותיו מאי <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"א\" data-order=\"1\"></i>(א\"ל הכי אמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שמואל מותר) ואפילו <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>אשתו עמו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והלכתא כשמואל ואע\"ג דאיתותב",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מאי טעמא <i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>נטורינהו טפי עדיף",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והיכן מניחן (דף כד.) אמר רב",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ירמיה מניחן בין כר לכסת שלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כנגד ראשו אמר רב המנונא בריה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דרב יוסף יומא חד הוה קאימנא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קמיה דרבא ואמר זיל אייתי לי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תפילי ואתאי ואשכחתינהו בין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כר לכסת שלא כנגד ראשו והוה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ידענא דההוא יומא יום טבילה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הואי ולאגמורן הלכה למעשה הוא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דבעא <i data-commentator=\"Mishneh Torah, Reading the Shema\" data-label=\"⚬\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>שנים שהיו ישנים <i data-commentator=\"Hagahot HaBach\" data-label=\"ב\" data-order=\"2\"></i>בטלית",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אחת <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>קיי\"ל כרב יוסף דאמר אשתו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כיון דכגופו היא <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ד\" data-order=\"4\"></i>מותר להחזיר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פניו ולקרות אבל אחר כגון",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בניו ובני ביתו כיון דלאו כי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "גופיה הוא אסור לקרות ק\"ש עד",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שתהא טלית מפסקת ביניהם ואם",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היו בניו ובני ביתו קטנים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מותר ועד כמה תינוקת בת אחת",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עשרה שנה ויום אחד ותינוק בן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "י\"ב שנה ויום אחד ואידי ואידי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ה\" data-order=\"5\"></i>עד שיהו שדים נכונו ושערך",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "צמח (שם) ת\"ר היה ישן בטליתו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואינו יכול להוציא ראשו מפני",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הצנה חוצץ בטליתו עד צוארו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וקורא ק\"ש ויש אומרים עד לבו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ות\"ק הרי לבו רואה את הערוה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קסבר לבו רואה את הערוה מותר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והלכתא לבו <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ו\" data-order=\"6\"></i>רואה את הערוה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אסור (שם) א\"ר חנינא אני",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ראיתי רבי <i data-commentator=\"Tur\" data-label=\"⚬\"></i>שתלה תפיליו מיתיבי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "התולה תפיליו יתלו חייו דורשי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חמורות אמרו (דברים כ״ח:ס״ו)",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והיו חייך תלואים לך מנגד זה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "התולה תפיליו ואסיקנא דרבי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בכיסיה תלה אבל תפילין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "גופייהו אסור לתלותן בין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ברצועה בין בקציצה <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>המשמיע",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ז\" data-order=\"7\"></i>קולו בתפלתו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>אביי אמר אסור דהזמנה מילתא היא.</b> פירוש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "תכריכי המת אסור בהנאה כדילפינן מגזירה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "שוה מדכתיב ותמת שם מרים וכתיב בעגלה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ערופה וערפו שם את העגלה מה להלן אסורה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "בהנאה דכפרה כתיב בה כקדשים אף כאן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "תכריכין אסורים בהנאה וסבירא ליה לאביי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דאפילו בהזמנה לתכריכין אסור דהזמנה מילתא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "היא ולית הלכתא כוותיה: <b>תחת מראשותיו מאי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אמר ליה הכי אמר שמואל מותר ואפי' אשתו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עמו.</b> ופוסקים הגאונים הלכה כשמואל ואע\"פ",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שחולק עם הברייתא ואין דרך האמוראים לחלוק",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "על הברייתא אפילו הכי בדבר שהוא בדקדוק",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המצות כגון זה שהוא משום שמירה <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"א\" data-order=\"1\"></i>נוכל לפסוק",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כמו האמורא: <b>ולהניחן</b> במטה כנגד צדו נראה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דאזלינן לחומרא ודיינין ליה כתחת מרגלותיו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מפני שפעמים מתהפך במטה וישכב עליהן ונראה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "למורי הרב נר\"ו דתחת מראשותיו יש בו שלשה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דינין ואלו הן תחת מראשותיו כנגד ראשו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אסור בכל ענין ואפי' כלי בתוך כלי ואפי'",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בלא אשתו עמו ושלא כנגד ראשו אם אשתו עמו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "צריך כלי בתוך כלי דהיינו כלי אחד והכר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהוא כלי שני ואם אין אשתו עמו אפי' בכלי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אחד דהיינו בין הכר והכסת סגי ודייק הכי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
