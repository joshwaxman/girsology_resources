        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עשרה ועשרה אינן נחלקין עד",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שיהיו עשרים:",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>ברכת המזון דמצי פטר נפשיה דאי בעי אכיל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ואי <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"א\" data-order=\"1\"></i>(לא) בעי לא אכיל לא מהדרינן ליה.</b> ויש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "לשאול והיכי קאמר דאי בעי אכיל ואי <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"ב\" data-order=\"2\"></i>לא בעי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "לא אכיל בר\"ח והלא אין לו להתענות בר\"ח",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "י\"ל דה\"ק אי בעי לא אכיל דבר שיתחייב לברך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עליו בהמ\"ז אלא אוכל פירות ודברים אחרים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדי שלא יתענה בר\"ח ויפטור עצמו מבהמ\"ז",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואומרי' רבני צרפת ז\"ל שאע\"פ שחייב אדם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לאכול ג' סעודות בשבת סעודה שלישית אי בעי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אכיל פת ואי בעי אכיל פירי ונפטר באכילת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הפירות ראיה לדבר שהרי גבי סוכה אמרינן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חייב אדם לאכול י\"ד סעודות בסוכה ופי' לשם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שפוטר עצמו בשיאכל מיני תרגימא ה\"נ בשני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הפעמים שחייב לקדש אחת ביום ואחת בלילה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "צריך שיאכל פת כדי שיהיה הקידוש במקום",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "סעודה אבל בפעם השלישית שאינו צריך לקדש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אם ירצה לפטור עצמו בפירות הרשות בידו.",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומה שכתב ר\"מ ז\"ל שחייב לקדש <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"א\" data-order=\"1\"></i>בסעודה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שלישית כמו שחייב בג' סעודות אינו נראה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שלא מצינו שיהיה חייב לקדש אלא פעם אחת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ביום ופעם אחת בלילה דהכי אמרינן זכור את",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יום השבת לקדשו אין לי אלא ביום בלילה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מנין ת\"ל זכור זכרהו בכניסתו וכיון שקדש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ביום <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"ב\" data-order=\"2\"></i>כבר יצא ידי הקידוש מכל היום ומה טעם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הוא לתלות הקידוש בשלש סעודות הלכך ודאי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אין צריך לקדש. מפי מורי הרב נר\"ו: <b>מתני'",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כיצד מזמנין כו' בעשרה אומר נברך אלהינו.",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "</b> זהו הנוסח הנכון יותר ואין ראוי לומר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לאלהינו שלא מצינו השם סמוך לברכה בלמ\"ד",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דכתיב במקהלות ברכו אלהים ברכו עמים",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אלהינו. אחד עשרה ואחד עשרה רבוא. ומתני'",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "(גמ' דף נ.) אתיא אליבא דרבי עקיבא שסובר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאין לחלק בין מרובין למועטין כמו שמצינו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בבהכ\"נ שהעולה לספר תורה בין שיהיו שם",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מרובין בין מועטין אומר לעולם בענין",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אחד: <b>במאה <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"ג\" data-order=\"3\"></i>(הוא) אומר נברך ה' אלהינו.</b> האי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "סיפא דלא כר' עקיבא דאילו ר\"ע ס\"ל שאין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לחלק בין מרובין למועטין כדכתבי' והאי תנא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ס\"ל שיש חילוק ולפי רוב הקהל מברכין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדמפרש ואזיל: <b>מטובו חיינו ה\"ז בור.</b> <i data-commentator=\"Hagahot HaBach\" data-label=\"ב\" data-order=\"2\"></i>מפני",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאומר כמי שדומה מקצת טובו ובגמ' פריך והא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כתיב ומברכתך יבורך בית עבדך ומתרץ שאלה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאני כלומר כששואל יכול לשאול קצת אבל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כשנותן הודאה צריך לתת הודאה על הכל <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"ד\" data-order=\"4\"></i>:",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "<b>מכיון שהוא אומר המבורך אף הוא אינו מוציא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עצמו מן הכלל.</b> כלומר לפיכך אומר ברכו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואינו אומר נברך מפני שאומר לבסוף המבורך",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ונמצא שאינו מוציא את עצמו מן הכלל אבל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בבהמ\"ז שאינו אומר המבורך הוא אומר נברך",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדי שלא להוציא את עצמו מן הכלל וכתב הרב",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רבי יהודה ברצלוני בשם רב סעדיה גאון",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהעולה לספר תורה אחר שיאמר ברכו את ה'",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המבורך ועונין השומעין ברוך ה' המבורך",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לעולם ועד יש לו ג\"כ לחזור ולומר ברוך ה'",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המבורך דכי היכי דאמרן לעיל (סי' קע)",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהמברך בהמ\"ז חוזר למקום שפסק ואומר ברוך",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאכלנו משלו ובטובו חיינו כמו שאמרו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "האחרים ה\"ה נמי הכא חוזר ואומר ברוך ה'",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המבורך לעולם ועד. ואע\"פ שאומר המבורך",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אפ\"ה צריך לחזור ולומר ברוך ה' המבורך",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לעולם ועד שכשאומר נברך מברך עמהם בכלל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואפ\"ה חוזר ואומר ברוך שאכלנו משלו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדכתבינן: <b>נברך שאכלנו משלו הרי זה ת\"ח.",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "</b> כלומר כיון שאומר הדבר סתם ודאי מוכחא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מילתא דלקודשא בריך הוא קא בריך אבל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כשאומר למי שאכלנו הואיל ואומר שם פרטי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נראה שעל אדם ידוע אומר: <b>מתני' א\"ר עקיבא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מה מצינו בבהכ\"נ וכו'.</b> ואע\"פ שהיה נראה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דהלכה כר' עקיבא שהיה אומר די לו כשיאמר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברכו את ה' בלבד אפ\"ה נהגו עלמא כרבי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ישמעאל לומר ברכו את ה' המבורך: <b>מתני'",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שלשה שאכלו כאחת אינן רשאין ליחלק.</b> דכיון",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שנתחייבו בזימון אין להם לפטור עצמן ממנו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
