{
  "metadata": {
    "masechet_en": "Berakhot",
    "masechet_he": "ברכות",
    "daf": "22A",
    "type": "rif",
    "ry_on_right": false,
    "ry_header_lines": 4
  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>שבעת</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "ימים נקיים רבא אמר כי הא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאמר רבי אושעיא מערים אדם על",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תבואתו ומכניסה במוץ שלה כדי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שתהא בהמתו אוכלת ופטורה מן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "המעשר אי נמי כי הא דרב הונא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאמר רב הונא אמר זעירי המקיז",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דם לבהמת קדשים אסור בהנאה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ומועלים בו <i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>(מדרבנן) רבנן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עבדי כמתניתין ורב שימי בר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אשי עביד כברייתא דתניא אין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עומדין להתפלל לא מתוך שיחה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ולא מתוך שחוק ולא מתוך קלות",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ראש ולא מתוך דברים בטלים ולא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתוך עצלות ולא מתוך עצבות",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלא <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>מתוך שמחה של מצוה וכן אל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יפטר אדם מחבירו לא מתוך שיחה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ולא מתוך קלות ראש ולא מתוך",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דברים בטלים אלא מתוך דבר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הלכה שכן מצינו בנביאים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הראשונים שסיימו את דבריהם",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בדברי שבח ותנחומין וכן תאני",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מארי בריה דרב הונא בריה דר'",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ירמיה בר אבא לא יפטר אדם",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מחבירו לא מתוך שיחה ולא מתוך",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שחוק ולא מתוך קלות ראש ולא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתוך דברים בטלים אלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתוך",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>ואיכא</b> למידק בזאת התקנה שתקן ר' כשראתה ב'",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ימים שתשב ששה והם והלא די בה' והם שאפילו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "היא נדה סגי לה בשתשב שבעה עם ימי הראיה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "והתשובה בזה מפני שחשש כי פעמים תראה יום",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "הראשון בימי זיבתה ויום השני בימי נדותה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ונמצא שהיום הראשון שהיה בימי הזיבה אינו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בכלל שבעה ימי נדותה שצריך שבעה מיום",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שראתה דם בימי הנדות ואם לא היתה מונה אלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ה' בלבד נמצא שלא ספרה לימי הנדות אלא ששה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בלבד עם יום הראיה שיום ראיה ראשונה אינו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בכלל המנין כמו שאמרנו ולפי' התקין ו' והם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדי לצאת מזה הספק שאמרנו: <b>שאפילו רואות",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "טפת דם כחרדל וכו'.</b> י\"מ שהחומרא היתה מפני",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהיתה מראה הדם כעין החרדל ואין זה נראה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דמה חומרא היתה זו שזה מן הדין הוא דהא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בהדיא קי\"ל במס' נדה שדם כמראה החרדל מטמא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "והחומרא ג\"כ אינה מפני שהיה מועט כחרדל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שזה אף הוא מן הדין כדתנן (ד' מ.) ומטמאה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בכל שהוא אלא פשר הדבר הוא כך שאם היה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אומר דם סתם היינו אומרים שאין בזה חומרא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כל כך מפני ששלשה בתים הם באשה חדר עליה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ופרוזדור וכשהדם מרובה אפשר שמהיום שלשה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ימים נעקר ויצא ביום הראשון מעט בבית",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הפנימי וביום השני נעקר <i data-commentator=\"Hagahot HaBach\" data-label=\"ב\" data-order=\"2\"></i>מעט ויצא בבית",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "האמצעי ועכשיו ביום השלישי נתקבץ הכל בבית",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "החיצון ואע\"פ שאינו מן הדין שיחוש האדם",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לדם שבפנים אלא כשבודקת ורואה בבית החיצון",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אפילו הכי כיון שאפשר שיהיה בזה הענין",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "היינו אומרים שראוי לחוש וא\"כ אין בזה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חומרא גדולה שהרי אפשר נעקר הדם מהיום ג'",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ימים ודין הוא שנדון אותה כמו זבה גדולה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ותשב ז' ימים נקיים אבל כשהדם הוא מועט",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "רחוק הדבר לומר ששלשה משהויין היו ובכל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יום ויום נעקר משהו אחד וקא משמע לן שאע\"פ",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהוא דבר רחוק שדבר מועט <i data-commentator=\"Hagahot HaBach\" data-label=\"ג\" data-order=\"3\"></i>כל כך שיהיה נעקר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מהיום שלשה ימים אפ\"ה החמירו על עצמן ודנו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אותו כאילו נעקר לגמרי ויושבת עליו ז'",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נקיים ואומר רבינו יצחק ז\"ל שהאשה שלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ראתה דם אלא יום א' או ב' ימים בלבד ושמשה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הלילה הסמוכה ליום שראתה צריכה שתשב ג'",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ימים תחלה ושתמנה ז' ימים נקיים אח\"כ מפני",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שבודאי פולטת שכבת זרע אחר התשמיש וש\"ז",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "סמוך לג' ימים של תשמיש מטמא מפני שמסריח",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אבל מג' ימים ואילך אינו מסריח (אם לא)",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שנקלט ונעשה עובר ובמס' נדה (דף כב.) מפרש",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דבעיא ז' ימים נקיים לגמרי בלא שכבת זרע",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואם לא תשב תחילה ג' ימים סמוך לתשמיש",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נמצא שפולטת בתוך הז' ימים ואינם נקיים",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לגמרי ואית דבעי מימר שטומאת שכבת זרע",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אינה אלא לענין אכילת תרומה בלבד שהיא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חמורה יותר ואין זה נכון שהענין הזה כתוב",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "במסכת נדה ומה טעם נקל ונאמר שלא נאמר גבי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נדה אלא גבי תרומה אלא ודאי הדין הוא כמו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שכתבתי. מפי מורי הרב נר\"ו: <b>מערים</b> אדם על",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "תבואתו ומכניסה במוץ שלה כדי שתהא בהמתו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אוכלת ופטורה מן המעשר פי' מן התורה אינו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חייב לא בתרומה ולא במעשר אלא היכא דהיא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "<i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"א\" data-order=\"1\"></i>דגן דכתיב ראשית דגנך וכל זמן שאינה דגן",
