  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>אני</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "ה' אלהיכם זו ברכה: גרסינן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בפרק כל הבשר (חולין דף קה.)",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר רב אידי בר אבין אמר ר'",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יצחק בר אשיאן מים ראשונים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מצוה <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>מים אחרונים חובה מיתיבי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מים ראשונים ואחרונים חובה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואמצעיים רשות מצוה לגבי רשות",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חובה קרי ליה גופא מים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ראשונים ואחרונים חובה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואמצעיים רשות מים ראשונים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ניטלין בין בכלי בין על גבי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קרקע אחרונים אין ניטלין אלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בכלי ואמרי לה אין ניטלין על",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "גבי קרקע איכא בינייהו קינסא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פירוש עצים דקים מים <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>ראשונים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ניטלין בין בחמין בין בצונן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אחרונים אין ניטלין אלא בצונן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אבל בחמין לא מפני שהמים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "החמין מפעפעין את הידים ואין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מעבירין את הזוהמא ודוקא במים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חמין שהיד סולדת בהן אבל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פושרין לית לן בה אמצעיים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>רשות אמר רב נחמן לא שנו אלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בין תבשיל לתבשיל אבל בין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תבשיל לגבינה חובה: אמר ר'",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהודה בר ר' חייא מפני מה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמרו <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ד\" data-order=\"4\"></i>מים אחרונים חובה מפני",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שאדם אוכל אחר סעודתו מלח ויש",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בה מלח סדומית שמסמא את",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "העינים אמר אביי ומשתכחא כי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קורטא בכורא ואי כייל מלחא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>בעי נטילת ידים: (חולין קו.)",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אתמר <i data-commentator=\"Hagahot HaBach\" data-label=\"ב\" data-order=\"2\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>חמי האור חזקיה אמר אין",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נוטלין מהן לידים ורבי יוחנן",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר נוטלין מהם לידים ואמר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רבי יוחנן שאלתי את רבן",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "גמליאל ברבי אוכל טהרות ואמר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לי כל גדולי גליל עושין כן",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וקיימא לן כרבי יוחנן בהא חמי",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "טבריה חזקיה אמר אין נוטלין",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מהן לידים ורבי יוחנן אמר כל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "גופו טובל בהן ידיו (ורגליו)",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לא כל שכן אמר רב פפא במקומן",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כולי עלמא לא פליגי דשרי",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "למשקל מינייהו במנא (שלא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "במקומן) כולי עלמא לא פליגי",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאסור כי פליגי דפסק מיניה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בבת בירתא חזקיה סבר גזרינן",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בת בירתא אטו מנא ורבי יוחנן",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "סבר לא גזרינן והלכתא כחזקיה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דרביה דרבי יוחנן הוא ואי",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "קשיא לך הא הלכתא דלעיל התם",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היתה להם",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>ולענין</b> לברך על מים אחרונים היה נראה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "שהמברך ברכת המזון כיון שיש בדבר מצוה שיש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "לו לברך אבל כבר נהגו העולם שלא לברך רבני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "צרפת ז\"ל נותנין טעם בדבר מפני שבימיהם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "שהיה מנהגם להביא שמן ערב אחר הנטילה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "להעביר הזוהמא מהידים היו מברכין אבל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עכשיו כיון שאין אנו עושין המצוה כתקנה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאין לנו שמן ערב נהגו העם שאפי' המברך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברכת המזון אינו מברך על מים אחרונים ורב",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עמרם גאון ז\"ל כתב שאין מברכין עליהם לא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בלשון נטילה ולא בלשון רחיצה ולא בלשון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שטיפה ונתן סימן לדבר בשמתא נר\"ש: <b>אני ה'",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אלהיכם זו ברכה.</b> כלומר זו ברכה שמברכין על",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מים ראשונים: <b>מצוה לגבי רשות חובה קרי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ליה.</b> כלומר לעולם מים ראשונים מצוה ומה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ששנה בזה הברייתא מים ראשונים ואחרונים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חובה מפני שהזכיר רשות לגבי אמצעי' אמר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לשון חובה בראשונים: <b>איכא בינייהו קינסא.",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "</b> למאן דאמר אין ניטלים על גבי קרקע ניטלים",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "על גבי עצים וללישנא דאמר בכלי דוקא אין",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ניטלים על גבי עצים ודוקא חמין שהיד סולדת",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בהן וכו' דמתוך שהיד נכוית בהן אין",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מעבירין את הזוהמא ולפיכך אסור אבל במים",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ראשונים אפי' חמין שהיד סולדת בהן",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מותר: <b>לא שנו אלא בין תבשיל לתבשיל אבל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בין תבשיל לגבינה חובה.</b> הרי\"ף ז\"ל פסק",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הלכה במסכת חולין (דף קה.) שאחר שאכל בשר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אינו אוכל גבינה אפי' בקינוח הפה והדחה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אלא צריך לשהות שש שעות ומקשים עליו מהא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דאמרי' הכא דבין תבשיל לגבינה חובה ליטול",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ידיו דמשמע שאחר שאכל תבשיל של בשר יכול",
      "segment_ids": [
