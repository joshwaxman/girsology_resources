        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לומר גבורת גשמים בברכה של תחיית המתים",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מפני שכמו שתחיית המתים חיים לעולם כך",
