  "rashi": [
    {
      "width": "1010px",
      "text": "<b>מרחיקין</b> משור תם חמשים אמה כל זמן שלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "הועד נקרא תם ואפי' לא היה בא כנגדו פוסק",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ומרחיק בענין שלא יפחד ממנו ואפשר שזה היה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "בשורים שלהם שהיו מזיקים אבל בשורים שלנו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "המסורסין אין צריך לפסוק: <b>מתני'</b> מזכירין",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "גבורות גשמים בתחיית המתים הטעם שתקנו",
      "segment_ids": [
