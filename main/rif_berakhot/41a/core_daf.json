  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>שעת</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "הכושר: מים שנפסלו משתיית",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הבהמה בכלים פסולים בקרקע",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כשרים פירוש יש אומרים מים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מלוחין שאין הכלב יכול ללקק",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מהם ויש אומרים <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>מים עכורין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שקרובין להיות כטיט הנדוק אמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב אידי בר אבין א\"ר יצחק בר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אשיאן אין נט\"י לחולין אלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "משום סרך תרומה ועוד משום",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מצוה מאי מצוה אמר אביי מצוה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לשמוע דברי חכמים ורבא אמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מצוה לשמוע דברי ר' אלעזר בן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ערך דכתיב (ויקרא ט״ו:י״א)",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וכל אשר יגע בו הזב וידיו לא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שטף במים אמר ר' אלעזר בן ערך",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>[<sup class=\"footnote-marker\">*</sup><i class=\"footnote\">גי' ד\"ת</i>מכאן אמרו חכמים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לנטילת ידים מן התורה] אמר ר'",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אושעיא כל שטיבולו במשקין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "צריך לנטילת ידים אמר ר'",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלעזר ואמר ר' אושעיא לא אמרו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נטילת ידים לפירות אלא משום",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נקיות בלבד ופליגא דרב נחמן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דאמר רב נחמן הנוטל ידיו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לפירות אינו אלא מגסי הרוח",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר רבה בר בר חנא זימנא חדא",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הוה קאימנא קמיה דרבי אמי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ורבי אסי ואייתי לקמייהו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כלכלה דפירי אכלו ולא משו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ידייהו ולא ספו לי מיניה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ובריכו כל חד וחד לחודיה שמע",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מינה תלת ש\"מ אין נטילת ידים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לפירות וש\"מ שנים שאכלו מצוה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ליחלק וש\"מ אין זימון לפירות",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ת\"ר (שם דף קו:) <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>קידוש ידים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "במקדש עד לפרק בחולין עד <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>לפרק",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לתרומה עד לפרק",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>ונראה</b> למורי הרב נר\"ו לפרש מחלוקת חזקיה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ורבי יוחנן בשאין שום עירוב מהמעין לבת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "בירתא ואין בבת בירתא ארבעים סאה ודייק",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "הכי מלישנא דאמר דפסק מינייהו דלשון פסק",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "משמע דפסק אותה לגמרי ואין בניהם חיבור",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כלל דמן התורה אין שום טבילה צריכה מ' סאה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אלא טבילת כל גופו בלבד אבל טבילת כלים די",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברביעית בלבד והוא שיהיו מתכסים הכלים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בתוך המים כגון מחטות וצנורות שהם כלים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קטנים ויכולין להתכסות ברביעית או אם הם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כלים גדולי' שיוסיף על הרביעי' כדי שיתכסו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בתוכן הנה שאע\"פ שלא יהיו בו ארבעים סאה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "די לטבילת כלים ברביעית מן התורה אלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שחכמים אמרו שלא יהיה חילוק בין טבילת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "גופו לטבילת כלים והצריכו הכל במ' סאה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדאמרינן (נזיר לח.) רביעי' של תורה בטולי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בטלוה ור\"ל אע\"פ שטבילת כלים די ברביעית",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מן התורה כיון שהכלים מתכסים במים אפ\"ה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בטלו חכמים זה השיעור והעמידו הכל בשיעור",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מ' סאה ומדחזינן דטבילת כלים שהיא מן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "התורה אינה צריכה מ' סאה כ\"ש טבילת הידים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאינו אלא מדרבנן שדי בשיטבול ידיו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברביעית כיון שמתכסין שם אלא שבמים אלו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מפני שהם מרים ונפסלים בכלי ע\"י מרירותם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נחלקו חזקיה ורבי יוחנן חזקיה אמר כיון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאין בהם ארבעים סאה ואין בהם עירוב",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "גזרינן שמא יבוא ליטול מהם בכלי שיאמר כמו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שבכאן ראוין בלא עירוב ובלא ארבעים סאה כך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הם ראוין בכלי ולא ישית אל לבו שפסלותן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מחמת המרירות ורבי יוחנן סבר לא גזרינן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מפני המרירות דכל גופו טובל בהם כשיש בהם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ארבעים סאה ואין אנו חוששים למרירותם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לענין טבילת הגוף ידיו לא כל שכן ולא קאמר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שכל גופו טובל באלו דודאי כיון שאין בהם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ארבעים סאה ולא עירוב מקואות אינו טובל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בהן <i data-commentator=\"Hagahot HaBach\" data-label=\"ו\" data-order=\"6\"></i>גופו אלא הכי קאמר אמאי גזרינן מפני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מרירותן כל גופו טובל בהן כשיש בהן ארבעים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "סאה ואין אנו חוששין למרירותן לענין טבילת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הגוף ידיו לא כל שכן שאין לחוש ולגזור",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מפני המרירות וכמו שמותר לטבול ידיו במים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מתוקים בלא עירוב ולא ארבעים סאה כיון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהידים מתכסים במים הה\"נ באלו המרים שטובל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בהם ידיו ואע\"פ שאין שם שום עירוב כיון",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שיש בחריץ שיעור להטביל ידיו והלכתא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כוותיה ומביא ראיה לסברא זו מדאמרינן בפרק",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כל הבשר (דף קו.) ואי בזע דוולא בכונס",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "משקה כיון דלייפי מטבילין את הידים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומדאמרינן התם טעמא כיון דלייפי משמע",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דחיבור כל שהוא סגי לטבילת ידים ואפילו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חיבור כל שהוא לא היה צריך אלא כדי שלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יהיו שאובין על ידי הכלי ואילו לטבילת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הגוף לא סגי בעירוב כל שהוא אלא צריך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חיבור בשפופרת הנוד וכמו שאנו רואין בזה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שיש הפרש בין טבילת הגוף לטבילת הידים ה\"ה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בבת בירתא אע\"ג דאין שם ארבעים סאה ולא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עירוב כלל ואינו ראוי לטבילת הגוף אפילו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הכי טובלין את הידים ומביא עוד ראיה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מדאמרינן התם (דף קז.) האי אריתא דדלאי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אין מטבילין בה את הידים ואמרינן התם טעמא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "משום דהוו להו שאובין ולמה הוצרך לומר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הטעם מפני שהם שאובין תיפוק ליה מפני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאינן מחוברין דהא קיימא לן דהנצוק",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "והקטפרס אינן חיבור דלעולם אם המים באין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "במורד ממעלה למטה או שבאין בקילוח אפי' לא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "יבואו במדרון לא הוו חיבור שאינו נקרא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עירוב מקואות אלא כשהמים מתערבין בנחת מזה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לזה והכא גבי אריתא דדלאי כיון שבאין המים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לצינור מכח הדוולא נמצא שבאין במדרון ולא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הוי חבור ולמה הוצרך לפסלם מטעם שהיו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאובין תיפוק ליה משום דליכא חבור אלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ודאי מפני שלטבילת ידים נצוק וקטפרס הוו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חבור מה שאין כן בטבילת הגוף לפיכך הוצרך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לפסלם מטעם שאובין ולמדנו מזה שיש הפרש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בין טבילת הגוף לטבילת הידים דבטבילת הגוף",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לא הוי חבור נצוק וקטפרס <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"א\" data-order=\"1\"></i>ולנטילת ידים הוי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חבור והכא נמי יש ביניהם הפרש שאע\"פ",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שלטבילת הגוף צריך עירוב כל זמן שאין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "(באין) במים ארבעים סאה לענין טבילת הידים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "א\"צ עירוב ואפילו פסק המים לגמרי מהמעין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואין בהם אלא רביעית או שנתקבצו מאליהן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מהגשמים יכול לטבול בו ידיו כיון שאינן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאובין: <b>ולענין</b> ברכה שמברך בשעה שטובל את",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ידיו י\"מ שמברך להטביל את הידים מפני שאי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אפשר לומר על נטילת ידים כיון דלא אתי מכח",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מנא ומכח גברא. ונראה למורי הרב נר\"ו שיש",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לו לומר על נטילת ידים ואע\"פ שאומר וצונו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "על נטילה והוא אינו נוטל אין להקפיד על זה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמאחר שזו הטבילה אינו עושה אותה אלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מחיוב הנטילה יכול לברך בשעה שטובל הידים",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וצונו על הנטילה ואע\"פ שאומר לשון נטילה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואינו נוטל אין בכך כלום דיש נטילה בכלל",
