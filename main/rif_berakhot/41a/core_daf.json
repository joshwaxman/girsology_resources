        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאכלו פירות אינן חייבין <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"ב\" data-order=\"2\"></i>אפ\"ה אם היינו",
