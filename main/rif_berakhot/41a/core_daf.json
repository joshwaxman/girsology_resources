        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וידיו לא שטף במים קא דריש דהכי דייקינן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בגמרא הא שטף טהור כלומר היאך אפשר לומר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שבשטיפת הידים יהיה הזב טהור שהרי צריך",
