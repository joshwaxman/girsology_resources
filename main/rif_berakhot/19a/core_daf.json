  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>תפלת</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "ערבית רשות אמר רב יהודה אמר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שמואל תפלת ערבית רבן גמליאל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אומר חובה ורבי יהושע אומר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רשות אביי אומר הלכה כדברי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "האומר חובה ורבא אמר הלכה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כדברי האומר <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>רשות וקיימא לן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דהלכה כרבא מיהו הני מילי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היכי דלא צלי ליה כלל אבל",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היכא דצלי ליה לתפלת ערבית",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כבר שוייה עליה חובה ואי טעי",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הדר לרישא כדאמרינן (דף",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ל:): אמר רבא <sup class=\"footnote-marker\">*</sup><i class=\"footnote\">בגמ' הגי' אמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב ענן אמר רב</i>טעה ולא <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>הזכיר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "של ראש חודש בערבית אין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מחזירין אותו שאין מקדשין את",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "החדש אלא ביום ושמעינן מינה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שאם טעה בערבית בשבת או בימים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "טובים שמחזירין אותו ואמרינן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נמי טעה ולא התפלל ערבית",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתפלל שחרית שתים והא דברי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הכל היא דהא ליכא מאן דפליג",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואפילו למאן דאמר רשות חובה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היא דליתא אבל מצוה איתא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והאידנא נהוג עלמא לשוייה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כחובה (דף כח.) תנו רבנן היו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לפניו <i data-commentator=\"Mishneh Torah, Prayer and the Priestly Blessing\" data-label=\"⚬\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>שתי תפלות אחת <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>של מנחה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואחת של מוספין מתפלל של מנחה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואחר כך מתפלל של מוספין ר'",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהודה אומר מתפלל של מוספין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואחר כך של מנחה שזו מצוה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עוברת וזו מצוה אינה עוברת",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר רבי יוחנן הלכה מתפלל של",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מנחה <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ד\" data-order=\"4\"></i>ואח\"כ של מוספין א\"ר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלעזר כל המתפלל תפלה של",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שחרית אחר ארבע שעות <i data-commentator=\"Hagahot HaBach\" data-label=\"א\" data-order=\"1\"></i>דרבי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יהודה עליו הכתוב אומר (צפניה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ג׳:י״ח) נוגי ממועד אספתי ממך",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "היו: א\"ר יהושע בן לוי המתפלל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תפלה של מוספים לאחר שבע שעות",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דר' יהודה עליו הכתוב אומר",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נוגי ממועד אספתי מאי משמע",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דהאי נוגי ממועד לישנא דתברא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הוא כדמתרגם רב יוסף תברא על",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תברא ייתי על שנאיהון דבית",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ישראל על דאחרו זמני מועדיא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דבירושלים רב נחמן בר יצחק",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אמר מהכא (איכה א) בתולותיה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "נוגות: (דף כח:) אמר ר' יוחנן",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אסור לאדם <i data-commentator=\"Mishneh Torah, Prayer and the Priestly Blessing\" data-label=\"⚬\"></i><i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>שיקדים תפלתו לתפלת",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הצבור אמר רב ובצבור שנו: אמר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רב חונא אסור לאדם <i data-commentator=\"Mishneh Torah, Prayer and the Priestly Blessing\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>שיטעום",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כלום קודם שיתפלל תפלת",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "המוספין ולית הלכתא כוותיה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ולא כרבי יהושע בן לוי דאמר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "כיון שהגיע זמן תפלת המנחה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Shiltei HaGiborim\" data-label=\"ה\" data-order=\"5\"></i>אסור לאדם שיטעום כלום קודם",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שיתפלל תפלת המנחה: <b><big>מתני'</big></b> רבי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>נחוניא בן הקנה היה מתפלל",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בכניסתו לבית המדרש וביציאתו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "תפלה קצרה אמרו לו מה מקום",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לתפלה זו אמר להם בכניסתי אני",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתפלל שלא תארע תקלה על ידי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וביציאתי אני נותן הודאה על",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חלקי: <b><big>גמ'</big></b> תנו רבנן בכניסתו",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מהו אומר יהי רצון מלפניך ה'",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלהי שלא אכשל בדבר הלכה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וישמחו כי חבירי שלא אומר על",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "טהור טמא ועל טמא טהור ולא על",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מותר אסור ולא על אסור מותר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ולא יכשלו חבירי בדבר הלכה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואשמח בהם וביציאתו מהו אומר",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מודה אני לפניך ה' אלהי ששמת",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חלקי מיושבי",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>שאין מקדשין את החדש אלא ביום דכתיב תקעו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "בחדש שופר וכתיב בתריה כי חק לישראל הוא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "משפט וכו'.</b> וכתיב דינו לבקר משפט מה להלן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "אין דנין דיני ממונות אלא ביום אף הכא נמי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "אין מקדשין את החדש אלא ביום ומדחזינן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שמפני שאין קדוש החדש בלילה אין מחזירין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אותו כשלא הזכיר של ר\"ח שמעינן דשבתות",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וי\"ט שקדושתן ג\"כ בלילה אם טעה ולא הזכיר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
