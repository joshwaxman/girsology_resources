        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "המתפלל צריך שיכוין את לבו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אבא שאול אומר סימן לדבר",
      "segment_ids": [
        0,
        1
