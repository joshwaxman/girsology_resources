      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בשעת תפלה ונראה שצריך ג\"כ שלא תהיה חמורה",
      "segment_ids": [
        0,
        1,
        2,
        3,
