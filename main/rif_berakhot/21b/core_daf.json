        3,
        4,
        5,
        6
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>נסתלקה המצנפת מראש כ\"ג וכו'.</b> המצנפת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "והמגבעת הן כעין כובע והמצנפת היתה בראש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "כ\"ג כדכתיב ובמצנפת בד יצנוף שהיתה קטנה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "יותר מפני שלא היתה מכסה הציץ שהיה בראש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "כ\"ג בגובה של ראש כדאמרי' (במנחות) מקום",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "היה נראה בין ציץ למצנפת ששם מניח תפילין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אבל האחרת שהיתה בראש כהן הדיוט שלא היה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לו ציץ והיתה מכסה כל הראש קרוייה מגבעת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כך פי' רבינו יצחק בר אשר ז\"ל: <b>למאי נפקא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מינה לבטולי הא מקמי הא.</b> כלומר לבטל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כשמנגנים האנשים בפיהם או בכלי ניגון",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ועונות הנשים כדי שלא יבאו לעשות בענין",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אחר שהוא כאש בנעורת והוא יותר קשה שבשעה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהן מנגנות האנשים עונים מתוך שמאריכות",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בדבור ומביטין בהם האנשים באים יותר בנקל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לידי עבירה: <b>מפני שהתורה חוגרת שק וכו'.",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "</b> דרך משל הוא מה שהתורה יכולה לומר ומה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שיש לו להקב\"ה להשיב: <b>הקורא</b> פסוק בזמנו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מביא טובה לעולם שנא' ודבר בעתו מה טוב",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ראש הפסוק הוא שמחה לאיש במענה פיו וזהו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "פירושו כשהדברים טובים בעיני האדם יש לו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חשק לאמרם ומתוך שרואה אותם נאותים איננו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מבקש עת ראוי שיצא מפיו כל דבר ודבר דבור",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "על אפניו ואומר אותם לפעמים בלא עתם ואין",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מעלתם ניכרת והוא טעות אלא לבקש עת לכל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דבר ודבר כי הדבר האמור בעתו כמה הוא טוב",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מפני שבני אדם מכירים ומרגישי' במעלתו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וכמו כן אף על פי שקריאת הפסוקים טובה לכל",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "העולם בכל זמן כשקורא כל פסוק ופסוק בזמנו",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הוא יותר טוב מפני שמועילין בני אדם באותה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קריאה כיון שהיא בשעת הצורך ונמצא שמביא",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "טובה לעולם. מפי מורי הרב נר\"ו: <b>אין",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "</b> עומדין להתפלל מתוך דין הלכה אלא מתוך",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דבר הלכה פסוקה כלומר הלכה שאין בה מחלוקת",
