  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>למקום</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "שפסק שאומר ברוך שאכלנו משלו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ובטובו חיינו וכן הלכתא תניא",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i><i data-commentator=\"Mishneh Torah, Blessings\" data-label=\"⚬\"></i>מהו אומר בבית האבל ברוך הטוב",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והמטיב ר' עקיבא אומר דיין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "האמת ותנא קמא הטוב והמטיב",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אין דיין האמת לא אלא אימא אף",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הטוב והמטיב מר זוטרא איקלע",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לבי רב אשי איתרע מילתא בבריה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "פתח ואמר ברוך המלך <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>החי הטוב",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "והמטיב אל אמת דיין האמת שופט",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בצדק ושליט בעולמו שאנחנו עמו",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ועבדיו ובכל אנו חייבין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "להודות לו ולברכו וכן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הלכתא תנו רבנן <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>אין מכבדין לא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בדרכים ולא בגשרים (דף מז.)",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ולא בידים מזוהמות אלא בפתח",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שראוי למזוזה תנו רבנן שנים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ממתינין זה לזה בקערה שלשה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אין ממתינין והבוצע הוא פושט",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ידו תחלה ואם בא לחלוק כבוד",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "לרבו או למי שהוא גדול ממנו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הרשות בידו וכד מבצע <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>מיבעי",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ליה למבצע (סנהדרין קב:)",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מהיכא דבשיל שפיר רבה בר רב",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "הונא עסיק ליה לבריה כי רב",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "דניאל בר רב קטינא קדים וקא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מתני ליה לבריה אין המסובין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רשאין לטעום עד שיטעום המברך",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואין הבוצע רשאי לטעום עד",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שיכלה אמן מפי העונין ורב",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חסדא אמר מפי רוב העונין שכל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "העונה אמן יותר מדאי אינו אלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "טועה: ת\"ר <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>אין עונין לא אמן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חטופה ולא אמן קטופה ולא אמן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יתומה ולא אמן קצרה ולא יזרוק",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ברכה מפיו בן עזאי אומר כל",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "העונה אמן יתומה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>מהו אומר בבית האבל הטוב והמטיב וכו'.</b> פי'",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ת\"ק סבר שצריך לתת שבח לבורא על הצרה הבאה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "עליו <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"א\" data-order=\"1\"></i>וכשיזכיר הטוב והמטיב מלבד מה שאומר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "בכל יום שאם נפרש שהטוב והמטיב שמזכיר בכל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "יום [לא] היה אומר ת\"ק דא\"כ מה חדוש בא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "להשמיענו שזה פשוט הוא שצריך לאומרו שכן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אומר בהגדה שצריך לומר שלש הטבות ושלשה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "גמולות והוא הטוב והמטיב והוא ייטיב עמנו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הוא גמלנו הוא גומלנו הוא יגמלנו ור\"ע",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "היאך יכול לומר שלא יאמר אותו כלל אלא",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ודאי בא להשמיענו ת\"ק שאפי' בלא זה שאומר",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בכל יום שצריך שיאמר פעם אחרת הטוב והמטיב",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ודיין האמת ור\"ע ס\"ל דכיון שאמר הטוב פעם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אחת א\"צ לחזור ולאומרו פעם שנית ודי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בשיאמר דיין האמת: <b>פתח ואמר ברוך המלך החי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הטוב והמטיב.</b> ובגמ' אמר לוקח נפשות במשפט",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "וכתב בה\"ג ז\"ל דלא אמרי' ליה וגם הרי\"ף",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ז\"ל לא כתבו בהלכותיו והטעם שלהם משום",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דאמרי' במסכת שבת (דף נה:) יש מיתה בלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חטא ויש יסורין בלא עון וא\"כ היאך נאמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לוקח נפשות במשפט ותימה גדול הוא זה שמאחר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאומר אותו בגמ' היאך לא נאמר אותו שאע\"פ",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שיש מיתה בלא חטא כל דרכיו משפט והוא יודע",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "למה עושה כן <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"א\" data-order=\"1\"></i>: <b>אין מכבדין לא בדרכים.</b> י\"מ",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שבדרכים שבעיר קאמר כשהולכין שנים אין להם",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לכבד זה את זה מפני שלא יפסיקו העוברים",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "והשבים וי\"מ שלא נאמר אלא על ההולכין מעיר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לעיר שבזה אין בו דרך ארץ שיתאחרו בכל שעה",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ושעה לכבד זה לזה שיעבור לפניו ומקשינן",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ע\"ז מדאמרי' במסכת שבת (דף נא) לוי ורב",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הונא הוו אזלין באורחא קדים חמריה דלוי",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לחמריה דרב הונא ולוי כדי שלא יחשוב רב",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הונא כי בכוונה היה עושה כן ולא היה מכבדו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "א\"ל חמור שעסקיו רעים כגון זה מהו לצאת",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בפרומביא בשבת והיה שואל לו זה כדי שיכיר",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שהחמור מעצמו היה עושה ואם איתא שאין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מכבדין כשהולך ממקום למקום למה היה צריך",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לוי להנצל מרב הונא ומתרצינן שאע\"פ שאמרו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אין מכבדים בדרכים כשהולכין מעיר לעיר זהו",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כשלא נועדו מתחלה ללכת ביחד שאינם חוששין",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לכבד זה לזה: <b>ולא בגשרים ולא בידים",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מזוהמות.</b> מפני שסכנה הוא להם אם מתאחרים",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לעבור בגשר או אם מתאחרים מליטול ידיהם",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כשהם מזוהמות וי\"ל דהכא משמע שאחר האכילה",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שידיהם מזוהמות אין מכבדין זה לזה ולקמן",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אמרי' שאם היו הרבה ב\"א שנוטלים ידיהם",
      "segment_ids": [
        0,
        1,
        2,
        3
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
