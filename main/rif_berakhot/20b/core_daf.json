        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ר' ירמיה לרבי זירא ודילמא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מעיקרא לא מכוין דעתיה והשתא",
      "segment_ids": [
