      "text": "גברא רבא דקמסהיד <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ה\" data-order=\"5\"></i>עליה כמה",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ישהה <i data-commentator=\"Sefer Mitzvot Gadol\" data-label=\"⚬\"></i><i data-commentator=\"Tur\" data-label=\"⚬\"></i>בין תפלה לתפלה רב הונא",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ורב חסדא חד",
      "segment_ids": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>רב</b> חסדא אמר מעומד פסק הרב אלפסי ז\"ל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "כותיה משום דרב ששת קאי כותיה ורבני צרפת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "ז\"ל אומרים דהלכה כרב ששת דלא עבד רב ששת",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "כוותי' משום דסבר דהלכתא הכי אלא משום",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
