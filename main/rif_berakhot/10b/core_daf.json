  },
  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>נושאי</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "המטה וחלופיהן וחלופי חלופיהן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "את שלפני המטה ואת שלאחר המטה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "את שלמטה צורך בהן פטורין ואת",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שאין למטה צורך בהן חייבין",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אלו ואלו פטורין מן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "התפלה: <b><big>גמ'</big></b> מוטל לפניו אין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "שאין מוטל לפניו לא ורמינהו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מי שמתו מוטל לפניו <i data-commentator=\"Shiltei HaGiborim\" data-label=\"א\" data-order=\"1\"></i>אוכל בבית",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אחר אין לו בית אחר אוכל בבית",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "חבירו אין לו בית לחבירו עושה",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מחיצה ואוכל אין לו דבר לעשות",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מחיצה מחזיר פניו ואוכל ואינו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מיסב ואוכל ואינו <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ב\" data-order=\"2\"></i>אוכל בשר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ואינו שותה יין <i data-commentator=\"Shiltei HaGiborim\" data-label=\"ג\" data-order=\"3\"></i>ואין מברך (דף",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יח.) ואין מזמן ואין מברכין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "עליו ואין מזמנין עליו ופטור",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מק\"ש ומן התפלה ומן התפילין",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "<i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"א\" data-order=\"1\"></i>(ומכל מצות האמורות בתורה)",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ובשבת מיסב ואוכל ואוכל בשר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ושותה יין ומברך ומזמן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ומברכין עליו ומזמנין עליו",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "וחייב בקריאת שמע ובתפלה ובכל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "מצות האמורות בתורה רבן",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "גמליאל אומר מתוך שנתחייב",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "באלו נתחייב בכולן ואמר ר'",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יוחנן תשמיש המטה איכא",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "בינייהו קתני מיהת אוכל",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    }
  ],
  "rashi": [
    {
      "width": "1010px",
      "text": "<b>פטור מן ק\"ש ומן התפלה ומן התפלין נושאי",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "המטה וכו'.</b> כך היא הגרסא בכל הספרים",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "המדוייקים ויש מפרשים דכיון שלא שנינו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "במשנה בפירוש שפטור מכל המצות האמורות",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "בתורה אינו פטור אלא מאילו השלשה בלבד אבל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בכל השאר חייב ומביאין ראייה מדאמרינן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בפרק הישן חתן פטור מכל המצות האמורות",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בתורה ותנא שילא חייב ואומרים דהתם משמע",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דהלכתא כשילא וכי היכי דחתן חייב בכל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המצות האמורות בתורה ה\"נ שאבל חייב בכולן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אלא באילו השלשה בלבד שאסור מפני ששלשתן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "צריכות כוונה יותר משאר מצות ק\"ש מפני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קבלת עול מלכות שמים וצריך שיהיה בכוונה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ותפילין ג\"כ צריך שלא יסיח דעתו מהם ותפלה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ג\"כ צריך כוונה שאם לא כוון באבות צריך",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לחזור ולהתפלל פעם אחרת ומתוך שהוא בהול",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "על מתו וטרוד בעסקיו לא יוכל לכוין בהם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ולפיכך פטור אבל בשאר מצות שאינן צריכות",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כוונה כל כך חייב ואין זה נראה למורי הרב",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "נר\"ו שאותה הברייתא דסוכה דמביאין ראיה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ממנה שחייב בכל שאר המצות כבר תירצה רש\"י",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ז\"ל ואמר דלא סבירא ליה העוסק במצוה פטור",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מן המצוה אבל אנן דקיימא לן דהעוסק במצוה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "פטור מן המצוה ודאי פטור: <b>ועל</b> כן נראה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לפרש שאע\"פ שלא שנה במשנה אלא אלו השלשה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בלבד הוא הדין דפטור מכל שאר המצות אלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דתנא אלו שהם חמורות שיש בהם קבלת עול",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מלכות שמים וכל שכן בכל שאר המצות שאינן",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "חמורות כל כך לפיכך אמר תפלה ותפילין עם",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קריאת שמע מפני שקבלת עול מלכות שמים",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שלימה היא עם התפילין כדכתבינן לעיל וגם",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "צריך להתפלל עמהם ומביא ראיה מהירושלמי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "דגרסינן התם אם רצה להחמיר על עצמו אין",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שומעין לו למה מפני כבודו של מת או מפני",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאין לו מי שישא משאו מה נפיק מביניהון יש",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לו מי שישא משאו כלומר דכיון שיש לו מי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שישתדל בדבר אין לו טרדא ויכול לקרוא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "קריאת שמע ולעשות המצוה כתקונה ומקשה עלה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "התם והתניא פטור מלולב כלומר היאך נחייב",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אותו אפילו בשיש לו מי שישא משאו מאחר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שאין לו טרדא והרי ביום טוב אע\"פ שהמת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מוטל לפניו אין טרדא לו שאינו יכול לעשות",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לו ארון ותכריכין ולהוליכו וכמי שיש לו מי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "שישא משאו דמי ואפילו הכי פטור מלולב",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ומתרצינן בחול כלומר כשאמרו דפטור לא אמרו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ביום טוב עצמו אלא בחולו של מועד דחג",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הסוכות ולפיכך פטור מפני שהוא טרוד בעסקי",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "מתו ומקשינן והא תניא פטור מתקיעת שופר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אית לך למימר בחול ומתרצינן כאותה ששנינו",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "(שבת דף קנא) מחשיכין על התחום לפקח על",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עסקי כלה ועל עסקי המת להביא לו ארון",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ותכריכין ונמצא שאפילו במועד הוא טרוד שיש",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לו לפעמים ללכת במועד עצמו עד אלפים אמה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "כדי <i data-commentator=\"Hagahot MeAlfas Yashan\" data-label=\"ב\" data-order=\"2\"></i>שיצא מזומן לדרכו כשיצא המועד ולפיכך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אמרו שפטור מתקיעת שופר אלמא משמע הכא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בהדיא דכי היכי דפטור מן התפלה ומן",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "התפילין ה\"נ פטור מכל שאר המצות כגון לולב",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ושופר וכיוצא בהן תדע <i data-commentator=\"Chiddushei Anshei Shem\" data-label=\"א\" data-order=\"1\"></i>שבספרים המדויקים",
      "segment_ids": [
        0,
        1
