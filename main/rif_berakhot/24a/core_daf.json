  "rashi": [
    {
      "width": "1010px",
      "text": "<b>טעה</b> בג' ראשונות חוזר לראש אומרים רבני",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "צרפת ז\"ל שאם טעה בר\"ה ולא הזכיר זכרנו",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "באבות או מי כמוך בתחיית המתים שחוזר לראש",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "1010px",
      "text": "התפלה וזה תימה דכיון שאינו מעיקר התפלה",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": "0px",
      "_ry_header": true
    },
    {
      "width": "450px",
      "text": "למה חוזר הברכה בעבור זה ואפי' לדבריהם",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אינו חוזר הברכה אלא בר\"ה ויוה\"כ בלבד שהן",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "עיקר הדין והחתימה ויש בהם קרבן מוסף אבל",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בימים שבנתים נראה דדברי הכל אין מחזירין",
      "segment_ids": [
        0
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אותו. מפי מורי הרב נר\"ו: <b>ורב</b> אסי אמר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אמצעיות אין להם סדר רבינו האי גאון ורש\"י",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ז\"ל פירשו שאין להם סדר כלל ואם טעה ושכח",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברכה אחת ואחר שאמר ב' ברכות או ג' נזכר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ששכח אותה א\"צ לחזור לתחלת הברכה שטעה בה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אלא אומרה במקום שזוכרה ולדבריהם אם שכח",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ג\"כ בהשיבה שופטינו ולא אמר המלך המשפט",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אין צריך לחזור להשיבה שופטינו אלא אומר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ברכת השיבה שופטינו אחר הברכה שנזכר בה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "והרי\"ף ז\"ל הקשה על זה דא\"כ הוה ליה קורא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הברכות למפרע ובהדיא אמרי' הקורא את",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המגילה למפרע לא יצא וכן בק\"ש וכן בתפלה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ולא מצית לדחות ולומר דה\"מ לכתחלה אבל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בדיעבד כגון זה ששכח ונזכר אח\"כ יצא דהא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אמרינן בתוספתא בהדיא הקורא את המגילה",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "והשמיט בה פסוק א' צריך לחזור מאותו פסוק",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואמרינן התם וכן בתפלה דמשמע דאפי' בדיעבד",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אם טעה ושכח הברכה או שטעה ולא אמר המלך",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "המשפט בברכת השיבה שופטינו חוזר לתחלת",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "הברכה שטעה בה ומאי דאמרינן אין להם סדר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ר\"ל שאין להם סדר כמו שלש ראשונות ושלש",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "אחרונות דאילו בראשונו' ובאחרונות חוזר",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לראש ובאמצעיות אינו חוזר לאתה חונן אלא",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "לתחלת ברכה שטעה בה כדמפרש ואזיל",
      "segment_ids": [
        0,
        1
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "בהלכות: <b>אלו</b> ברכות שאדם שוחה בהם באבות",
