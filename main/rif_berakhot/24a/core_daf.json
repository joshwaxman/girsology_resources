      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "תחלה וסוף יש נותנים סמך לדבר מדכתיב",
      "segment_ids": [
        0,
        1,
        2
      ],
      "right": "0px",
      "left": ""
    },
    {
      "width": "450px",
      "text": "ואקוד ואשתחוה לה' ואברך את ה' אלהי אדוני",
