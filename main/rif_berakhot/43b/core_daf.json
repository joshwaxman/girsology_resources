        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ליראיו חכמי עובדי כוכבים",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אומר ברוך שנתן מחכמתו לבשר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ודם הרואה מלכי ישראל אומר",
      "segment_ids": [
        0,
        1
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ברוך שחלק מכבודו ליראיו מלכי",
