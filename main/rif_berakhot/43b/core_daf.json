  "gemara": [
    {
      "width": "377px",
      "right": "275px",
      "text": "<big><strong>(ירמיהו</strong></big>",
      "segment_ids": [
        0
      ]
    },
    {
      "width": "377px",
      "text": "נ׳:י״ב) בושה אמכם מאד חפרה",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "יולדתכם הנה אחרית גוים מדבר",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "ציה וערבה אמר עולא נקיטינן",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "אין אוכלוסא פחותה מששים",
      "segment_ids": [
        0
      ],
      "right": "275px"
    },
    {
      "width": "377px",
      "text": "רבוא: תנו רבנן הרואה חכמי",
