      "width": "380px",
      "text": "חֲדָשִׁים נוֹתֵן לְתוֹכָן יַיִן, יְשָׁנִים — נוֹתֵן לְתוֹכָן צִיר",
      "segment_ids": [
        0
      ]
    },
    {
      "right": "275px",
      "width": "380px",
