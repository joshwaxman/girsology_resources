    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שהיה"
    },
    {
      "width": "180px",
      "right": "70px",
      "left": "",
      "text": "בידו"
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ואם היו"
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שני עדים"
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": ""
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": ""
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": ""
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לא הוה",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מהימן למימר דידי חטפי",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "השתא נמי",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כיון",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דמודה",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הוה",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "ליה כגזלן וא\"ת וניהמניה בשבועה דדידיה",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "חטף מיגו דאי בעי אמר לא חטפי",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "והוה מהימן בשבועה דכה\"ג",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "אמר בסוף המוכר",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "את הבית (<a href=\"/bava_batra/70b\">ב&quot;ב דף ע:</a>)",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "גבי מפקיד אצל חבירו בשטר דנאמן לומר בשבועה החזרתי לך",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "ולא",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "מ\"ל ליה היאך שטרך בידי",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "870px",
      "right": "60px",
      "left": "",
      "text": "מאי בעי",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "במיגו דאי בעי אמר",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "נאנסו נאמן בשבועה",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "ויש לומר",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "דירא לשקר בדבר",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "שהעד מכחישו כדאשכחן",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "בחזקת הבתים (שם דף לב: ושם)",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "גבי רבא בר שרשום דקאמר לקוח",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "בידי לא מצית אמרת דהא",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "נפק עלה קלא דארעא דיתמי היא ואין",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "אדם טוען ברצון",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "דבר שהקול מכחישו",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "מיהו צריכא לטעמא דמחויב שבועה ואינו יכול לישבע",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "דמשלם דבלא שבועה",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "לא היה חושש להכחיש",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "את העד ואיכא מיגו אבל לישבע בדבר",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "שהעד מכחישו זה ודאי קשה",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "לו כמו בדבר שהקול",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "מכחישו <big><b>מכחישו ואמר. תימה דהוה ליה למימר ואמר יחלוקו דהכי הלכתא דאמר לקמן.</b></big> תימה דהוה ליה למימר ואמר יחלוקו דהכי הלכתא דאמר לקמן פרק",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "כל הנשבעין (דף מז. ושם) עבד רב נחמן עובדא יחלוקו ועוד תימה",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "דר' אבא",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "הוא דאומר",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "חזרה שבועה",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "למחויב לה כדמוכח התם מנסכא דהכא וא\"כ הוה ליה למימר הכל מודים בעד",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "אחד וכשנגדו חשוד דחייב כר' אבא <big><b>אחד וכשנגדו חשוד דחייב כר&#x27; אבא שמע מינה. קאי.</b></big> קאי",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "נמי אהכל מודים בעד סוטה <big><b>נמי אהכל מודים בעד סוטה אבל.</b></big>",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "קצת תימה להר\"ר יעקב דאורלינ\"ש דכפירה והודאה שמעינן",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "נמי מרישא דטעמא כשכפר תוך כדי דיבור אף שני",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "חייב משום",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "דראשון",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "נמי",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "יכול לחזור עדיין ולהודות דאי",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "לאו דיכול",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "לחזור ולהודות שני אמאי חייב",
      "source_ref": "Tosafot on Avodah Zarah 32b:4:1",
      "gemara_segment_ids": [
        2
      ]
    }
  ]
}