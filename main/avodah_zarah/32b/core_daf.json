      "left": "",
      "text": "דכל"
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דבר מחזיקין"
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ליה בחזקת"
    },
    {
      "width": "250px",
