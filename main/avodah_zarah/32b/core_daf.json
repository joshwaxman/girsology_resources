      "mishnah_ref": "Avodah Zarah 29b",
      "mishnah_href": "/avodah_zarah/29b#gemara-line-4",
      "mishnah_line_number": 4,
      "quote_text": "רַבָּן שִׁמְעוֹן בֶּן גַּמְלִיאֵל אוֹמֵר: בִּזְמַן שֶׁהַקֶּרַע שֶׁלּוֹ עָגוֹל — אָסוּר, מָשׁוּךְ — מוּתָּר"
    },
    {
      "id": 121,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 7
    },
    {
      "id": 122,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 8,
      "mishnah_ref": "Avodah Zarah 29b",
      "mishnah_href": "/avodah_zarah/29b#gemara-line-6",
      "mishnah_line_number": 6,
      "quote_text": "בָּשָׂר הַנִּכְנָס לַעֲבוֹדָה זָרָה מוּתָּר"
    },
    {
      "id": 123,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 12,
      "mishnah_ref": "Avodah Zarah 29b",
      "mishnah_href": "/avodah_zarah/29b#gemara-line-6",
      "mishnah_line_number": 6,
      "quote_text": "בָּשָׂר הַנִּכְנָס לַעֲבוֹדָה זָרָה מוּתָּר׃ מַאן תַּנָּא? אָמַר רַבִּי חִיָּיא בַּר אַבָּא אָמַר רַבִּי יוֹחָנָן: דְּלָא כְּרַבִּי אֶלְעָזָר, דְּאִי כְּרַבִּי אֶלְעָזָר, הָאָמַר: סְתָם מַחְשֶׁבֶת גּוֹי לַעֲבוֹדָה זָרָה"
    },
    {
      "id": 124,
      "symbol": "׃",
      "raw_symbol": "׃",
      "line_number": 13,
      "mishnah_ref": "Avodah Zarah 29b",
      "mishnah_href": "/avodah_zarah/29b#gemara-line-6",
      "mishnah_line_number": 6,
      "quote_text": "וְהַיּוֹצֵא אָסוּר, מִפְּנֵי שֶׁהוּא כְּזִבְחֵי מֵתִים"
    },
