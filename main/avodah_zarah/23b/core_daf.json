        0
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "קׇרְבְּנוֹת מוֹדוּ לֵיהּ! <span class=\"sentence\" id=\"1\" type=\"start\">&star;</span>וְאֶלָּא הָא דְּתַנְיָא: לוֹקְחִין",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מֵהֶן בְּהֵמָה לְקׇרְבָּן, מַנִּי? לָא <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Eliezer ben Hyrcanus, third-generation Tanna\" data-authority-id=\"417\" data-full-name=\"Rabbi Eliezer ben Hyrcanus\" data-name-he=\"רבי אליעזר בן הורקנוס\">רַבִּי אֱלִיעֶזֶר</span> וְלָא",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "רַבָּנַן! <span class=\"sentence\" id=\"2\" type=\"start\">&star;</span>וְעוֹד, תַּנְיָא בְּהֶדְיָא: מַאי אוֹתִיבוּ לֵיהּ",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "חַבְרוֹהִי <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Eliezer ben Hyrcanus, third-generation Tanna\" data-authority-id=\"417\" data-full-name=\"Rabbi Eliezer ben Hyrcanus\" data-name-he=\"רבי אליעזר בן הורקנוס\">לְרַבִּי אֱלִיעֶזֶר</span>? ״כׇּל צֹאן קֵדָר יִקָּבְצוּ לָךְ...",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "יַעֲלוּ לְרָצוֹן עַל מִזְבְּחִי״. <span class=\"sugya-marker sugya-marker-steinsaltz\" data-sugya-kind=\"steinsaltz\" data-sugya-id=\"89\" data-sentence-id=\"3\" data-steinsaltz-label=\"א\">§</span> <span class=\"sentence\" id=\"3\" type=\"start\">&star;</span>עַד כָּאן לָא פְּלִיגִי אֶלָּא",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בַּחֲשָׁשָׁא, אֲבָל הֵיכָא דְּוַדַּאי רַבְעַהּ — פַּסְלַהּ; שְׁמַע",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מִינַּהּ דְּפָרָה קׇדְשֵׁי מִזְבֵּחַ הִיא, דְּאִי קׇדְשֵׁי",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בֶּדֶק הַבַּיִת — מִי מַיפְסְלָא בַּהּ רְבִיעָה?! <span class=\"sentence\" id=\"4\" type=\"start\">&star;</span>שָׁאנֵי",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "פָּרָה, דְּחַטָּאת קַרְיַיהּ רַחֲמָנָא. <span class=\"sentence\" id=\"5\" type=\"start\">&star;</span>אֶלָּא מֵעַתָּה,",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "תִּיפָּסֵל בְּיוֹצֵא דּוֹפֶן! וְכִי תֵּימָא הָכִי נָמֵי, אַלְּמָה",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "תַּנְיָא: הִקְדִּישָׁהּ בְּיוֹצֵא דּוֹפֶן — פְּסוּלָה, <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Shimon ben Yoḥai, fifth-generation Tanna\" data-authority-id=\"2830\" data-full-name=\"Rabbi Shimon ben Yoḥai\" data-name-he=\"רבי שמעון בן יוחאי\">וְרַבִּי שִׁמְעוֹן</span>",
      "segment_ids": [
        5
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מַכְשִׁיר? <span class=\"sentence\" id=\"6\" type=\"start\">&star;</span>וְכִי תֵּימָא, <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Shimon ben Yoḥai, fifth-generation Tanna\" data-authority-id=\"2830\" data-full-name=\"Rabbi Shimon ben Yoḥai\" data-name-he=\"רבי שמעון בן יוחאי\">רַבִּי שִׁמְעוֹן</span> לְטַעְמֵיהּ, דְּאָמַר: יוֹצֵא",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דּוֹפֶן וָלָד מְעַלְּיָא הוּא, וְהָאָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabbi Yoḥanan II, second-generation Amora\" data-authority-id=\"1570\" data-full-name=\"Rabbi Yoḥanan II\" data-name-he=\"רבי יוחנן\">רַבִּי יוֹחָנָן</span>: מוֹדֶה",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הָיָה <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Shimon ben Yoḥai, fifth-generation Tanna\" data-authority-id=\"2830\" data-full-name=\"Rabbi Shimon ben Yoḥai\" data-name-he=\"רבי שמעון בן יוחאי\">רַבִּי שִׁמְעוֹן</span> לְעִנְיַן קָדָשִׁים שֶׁאֵינוֹ קָדוֹשׁ! <span class=\"sentence\" id=\"7\" type=\"start\">&star;</span>אֶלָּא",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שָׁאנֵי פָּרָה, הוֹאִיל וּמוּם פּוֹסֵל בָּהּ — דְּבַר עֶרְוָה וַעֲבוֹדָה",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "זָרָה נָמֵי פּוֹסֵל בָּהּ, דִּכְתִיב: ״כִּי מׇשְׁחָתָם בָּהֶם",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מוּם בָּם״, וְתָנָא דְּבֵי <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yishmael ben Elisha II, fourth-generation Tanna\" data-authority-id=\"1979\" data-full-name=\"Rabbi Yishmael ben Elisha II\" data-name-he=\"רבי ישמעאל בן אלישע\">רַבִּי יִשְׁמָעֵאל</span>: כָּל מָקוֹם שֶׁנֶּאֱמַר הַשְׁחָתָה —",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אֵינוֹ אֶלָּא דְּבַר עֶרְוָה וַעֲבוֹדָה זָרָה. <span class=\"sentence\" id=\"8\" type=\"start\">&star;</span>דְּבַר עֶרְוָה,",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "דִּכְתִיב: ״כִּי הִשְׁחִית כׇּל בָּשָׂר אֶת דַּרְכּוֹ עַל",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הָאָרֶץ״, וַעֲבוֹדָה זָרָה, דִּכְתִיב: ״פֶּן תַּשְׁחִתוּן וַעֲשִׂיתֶם",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לָכֶם פֶּסֶל״; וְהָא פָּרָה נָמֵי, הוֹאִיל וּמוּם פּוֹסֵל",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בָּהּ, דְּבַר עֶרְוָה וַעֲבוֹדָה זָרָה פָּסְלִי בַּהּ.",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sugya-marker sugya-marker-steinsaltz\" data-sugya-kind=\"steinsaltz\" data-sugya-id=\"90\" data-sentence-id=\"9\" data-steinsaltz-label=\"ב\">§</span> <span class=\"sentence\" id=\"9\" type=\"start\">&star;</span>גּוּפָא, תָּנֵי שֵׁילָא: מַאי טַעְמָא <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Eliezer ben Hyrcanus, third-generation Tanna\" data-authority-id=\"417\" data-full-name=\"Rabbi Eliezer ben Hyrcanus\" data-name-he=\"רבי אליעזר בן הורקנוס\">דְּרַבִּי אֱלִיעֶזֶר</span>? דִּכְתִיב:",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "״דַּבֵּר אֶל בְּנֵי יִשְׂרָאֵל וְיִקְחוּ״, בְּנֵי יִשְׂרָאֵל יִקְחוּ,",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וְאֵין הַגּוֹיִם יִקְחוּ. אֶלָּא מֵעַתָּה: ״דַּבֵּר",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אֶל בְּנֵי יִשְׂרָאֵל וְיִקְחוּ לִי תְּרוּמָה״, הָכִי נָמֵי דִּבְנֵי",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "יִשְׂרָאֵל יִקְחוּ, וְאֵין הַגּוֹיִם יִקְחוּ?",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"10\" type=\"start\">&star;</span>וְכִי תֵּימָא: הָכִי נָמֵי, וְהָאָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yehuda bar Yeḥezkel, second-generation Amora\" data-authority-id=\"1394\" data-full-name=\"Rav Yehuda bar Yeḥezkel\" data-name-he=\"רב יהודה בר יחזקאל\">רַב יְהוּדָה</span> אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Shmuel II, first-generation Amora\" data-authority-id=\"2763\" data-full-name=\"Shmuel II\" data-name-he=\"שמואל\">שְׁמוּאֵל</span>:",
      "segment_ids": [
        10
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "שָׁאֲלוּ אֶת <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Eliezer ben Hyrcanus, third-generation Tanna\" data-authority-id=\"417\" data-full-name=\"Rabbi Eliezer ben Hyrcanus\" data-name-he=\"רבי אליעזר בן הורקנוס\">רַבִּי אֱלִיעֶזֶר</span>: עַד הֵיכָן כִּיבּוּד אָב וָאֵם? אָמַר",
      "segment_ids": [
        10
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לָהֶם: צְאוּ וּרְאוּ מָה עָשָׂה גּוֹי",
      "segment_ids": [
        10
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אֶחָד לְאָבִיו בְּאַשְׁקְלוֹן, <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Dama ben Netina, first-generation Tanna\" data-authority-id=\"884\" data-full-name=\"Dama ben Netina\" data-name-he=\"דמא בן נתינה\">וְדָמָא בֶּן נְתִינָה</span> שְׁמוֹ.",
      "segment_ids": [
        10
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "פַּעַם אַחַת בִּקְּשׁוּ מִמֶּנּוּ אֲבָנִים לָאֵפוֹד",
      "segment_ids": [
        10
      ]
    }
  ],
  "rashi": [
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "<b>אֶלָּא בְּפָרָה, <span class=\"dh-divergent\">אדומה</span> דְּדָמֶיהָ <span class=\"dh-divergent\">יקרים</span></b> דחייש עובד כוכבים להפסד",
      "source_ref": "Rashi on Avodah Zarah 23b:1:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "מרובה וכייף ליצריה: <b>אֲבָל בִּשְׁאָר קׇרְבְּנוֹת מוֹדוּ.</b> והא דתניא",
      "source_ref": "Rashi on Avodah Zarah 23b:1:2",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "לעיל לוקחין מהן בהמה אמאן תרמייה לא רבי אליעזר ולא רבנן:",
      "source_ref": "Rashi on Avodah Zarah 23b:1:2",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "<b>״כׇּל צֹאן קֵדָר.</b> קדר ישמעאל. וכתיב יעלו (לרצון על) מזבחי אלמא",
      "source_ref": "Rashi on Avodah Zarah 23b:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "בשאר קרבנות נמי שרי ושפיר",
      "source_ref": "Rashi on Avodah Zarah 23b:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "איתרצן רומיין דלעיל: <b>עַד כָּאן לָא</b>",
      "source_ref": "Rashi on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "<b>פְּלִיגִי <span class=\"dh-divergent\">כו&#x27;</span></b> מלתא באפי נפשיה",
      "source_ref": "Rashi on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "קאמר ואזיל: <b>אֶלָּא בַּחֲשָׁשָׁא.</b> היכא",
      "source_ref": "Rashi on Avodah Zarah 23b:4:2",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "דלא חזינן דרבעה פליגי דמר חייש",
      "source_ref": "Rashi on Avodah Zarah 23b:4:2",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "ומר לא חייש: <b>קׇדְשֵׁי מִזְבֵּחַ הִיא.</b>",
      "source_ref": "Rashi on Avodah Zarah 23b:4:3",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "דין קדושת מזבח יש לה ליפסל",
      "source_ref": "Rashi on Avodah Zarah 23b:4:3",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "ברביעה ולענין פדייה דלא נפקא",
      "source_ref": "Rashi on Avodah Zarah 23b:4:3",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "לחול בלא מום ואף ע\"ג דלאו למזבח",
      "source_ref": "Rashi on Avodah Zarah 23b:4:3",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "קרבה: <b>דְּאִי <span class=\"dh-divergent\">ס&quot;ד</span>.</b> לא אלימא",
      "source_ref": "Rashi on Avodah Zarah 23b:4:4",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "קדושתיה מקדושת בדק הבית ועל",
      "source_ref": "Rashi on Avodah Zarah 23b:4:4",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "כל דבר חל קדושת בדק הבית",
      "source_ref": "Rashi on Avodah Zarah 23b:4:4",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "אפי' על אבנים: <b><span class=\"dh-divergent\">אמאי</span></b> פסלה בה",
      "source_ref": "Rashi on Avodah Zarah 23b:4:5",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "רביעה: <b>שָׁאנֵי פָּרָה, דְּחַטָּאת קַרְיַיהּ</b>",
      "source_ref": "Rashi on Avodah Zarah 23b:5:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "<b>רַחֲמָנָא.</b> לעולם גבי פדייה והעמדה",
      "source_ref": "Rashi on Avodah Zarah 23b:5:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "והערכה דין קדשי בדק הבית עליה",
      "source_ref": "Rashi on Avodah Zarah 23b:5:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "ומיהו לענין פסולין סגיא מילתא",
      "source_ref": "Rashi on Avodah Zarah 23b:5:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "לאתויי בפסול דחטאת קרייה",
      "source_ref": "Rashi on Avodah Zarah 23b:5:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "רחמנא למי נדה חטאת היא:",
      "source_ref": "Rashi on Avodah Zarah 23b:5:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "<b><span class=\"dh-divergent\">תפסל</span> בְּיוֹצֵא דּוֹפֶן.</b> דפסול הוא",
      "source_ref": "Rashi on Avodah Zarah 23b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "לשאר קרבנות דתניא (בכורות דף",
      "source_ref": "Rashi on Avodah Zarah 23b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "נז.) שור או כשב פרט לכלאים או",
      "source_ref": "Rashi on Avodah Zarah 23b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "עז פרט לנדמה כי יולד פרט ליוצא",
      "source_ref": "Rashi on Avodah Zarah 23b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "דופן והאי קרא בקרבנות כתיב:",
      "source_ref": "Rashi on Avodah Zarah 23b:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "<b><span class=\"dh-divergent\">הקדיש</span> בְּיוֹצֵא דּוֹפֶן.</b> הקדיש לפרה",
      "source_ref": "Rashi on Avodah Zarah 23b:6:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "אדומה יוצא דופן פסולה כו':",
      "source_ref": "Rashi on Avodah Zarah 23b:6:2",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "<b>וָלָד מְעַלְּיָא הוּא.</b> במסכת נדה",
      "source_ref": "Rashi on Avodah Zarah 23b:7:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "(<a href=\"/avodah_zarah/40a\">דף מ.</a>) יוצא דופן אין יושבין עליו",
      "source_ref": "Rashi on Avodah Zarah 23b:7:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "ימי טומאה וימי טהרה ואין חייבין",
      "source_ref": "Rashi on Avodah Zarah 23b:7:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "עליו קרבן לידה ר\"ש אומר הרי",
      "source_ref": "Rashi on Avodah Zarah 23b:7:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "הוא כילוד ויש לו טומאת שבעה",
      "source_ref": "Rashi on Avodah Zarah 23b:7:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "לזכר ושבועיים לנקבה וכן ימי טוהר",
      "source_ref": "Rashi on Avodah Zarah 23b:7:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "וקרבן: <b>מוֹדֶה <span class=\"dh-divergent\">ר&quot;ש</span>.</b> לענין קדשים",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "דבהמה שיצאה דרך דופן פסולה",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "לקרבן דגבי טומאה וטהרה דאמו",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "הוא דקאמר ליה ר\"ש מריבוי",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "הכתוב אם נקבה תלד הוסיף",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "לידה אחרת לרבות יוצא דופן אבל",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "בקדשים מודי והא דר' יוחנן במסכת",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "נדה: <b>ה&quot;ג אלא שאני פרה הואיל.</b>",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "<b>ומום</b> <b>פוסל</b> <b>בה</b> <b>דבר</b> <b>ערוה</b> <b>ועבודת</b> <b>כוכבים</b> <b>פוסל</b> <b>בה</b> <b>דכתיב</b> <b>כי</b>",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "<b>משחתם</b> <b>בהם</b> <b>מום</b> <b>ותנא</b> <b>דבי</b> <b>ר'</b> <b>ישמעאל</b> <b>כל</b> <b>מקום</b> <b>כו'</b> <b>עד</b> <b>פן</b>",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "<b>תשחיתון</b> <b>כל</b> <b>שהמום</b> <b>פוסל</b> <b>בו</b> <b>כו'.</b> לא תימא דטעמא דמיפסלא",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "ברביעה משום דחטאת קרייה רחמנא אלא היינו טעמא דאע\"ג",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "דקדשי בדק הבית הואיל ומום פוסל בה כדכתיב אשר אין בו",
      "source_ref": "Rashi on Avodah Zarah 23b:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "מום: <b>דְּבַר עֶרְוָה</b> נרבע: <b>ועבודת</b> <b>כוכבים.</b> כגון מוקצה ונעבד",
      "source_ref": "Rashi on Avodah Zarah 23b:8:2",
      "gemara_segment_ids": [
        6
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "פסולין בה דאיתקש השחתה למום: <b>״כִּי הִשְׁחִית כׇּל בָּשָׂר אֶת דַּרְכּוֹ.</b>",
      "source_ref": "Rashi on Avodah Zarah 23b:9:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "תשמיש. דור המבול בעבירה קלקלו דכתיב ויראו בני האלהים וגו':",
      "source_ref": "Rashi on Avodah Zarah 23b:9:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "<b>וְכִי תֵּימָא, <span class=\"dh-divergent\">ה&quot;נ</span></b> דאסור לקנות זהב ואבנים טובות למלאכת המשכן",
      "source_ref": "Rashi on Avodah Zarah 23b:11:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "מן העובדי כוכבים: <b>עַד הֵיכָן כִּיבּוּד אָב וָאֵם</b> כמה אדם מצווה להזהר",
      "source_ref": "Rashi on Avodah Zarah 23b:11:2",
      "gemara_segment_ids": [
        9
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "בכיבוד אב ואם: <b>מָה עָשָׂה <span class=\"dh-divergent\">עובד</span> <span class=\"dh-divergent\">כוכבים</span>.</b> וכ\"ש ישראל שמצווה על כך:",
      "source_ref": "Rashi on Avodah Zarah 23b:11:3",
      "gemara_segment_ids": [
        9
      ]
    }
  ],
  "vilna_piskaot": [],
  "steinsaltz_sugyot": [
    {
      "id": 89,
      "sentence_id": 3,
