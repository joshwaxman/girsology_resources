  "tosafot": [
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "<big><b>מִינַּהּ דְּפָרָה קׇדְשֵׁי מִזְבֵּחַ הִיא</b></big> ואינו אוסר עצמו",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "410px",
      "right": "40px",
      "left": "",
      "text": "אלא בשלו <big><b><span class=\"dh-divergent\">הכא</span>.</b></big> בקונטרס פי' דל\"ג ליה",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "ושיבוש הוא אלא ה\"ג מי מיחייב אכללי ופרטי ונראה דיש",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "ליישבו מי מחית כו' וה\"פ כלומר מי איכא למימר",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הכא גבי שבועת ביטוי דנוקי שבועה אכללא דפת",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "חטין ושעורין וכוסמין לענין פחות מכשיעור",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דאם אכל מכל מין",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ומין פחות מכשיעור",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שיצטרפו דמסיק",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אדעתא דאי",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אכל שיעור",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אכילה מכולן שיתחייב",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דאיכוין לצירוף",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ואחשבה",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לאכילה פחות מכשיעור מכל מין",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ומין ומסיק הכי",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "השתא התם דמצי",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "למיחל",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אכללי ופרטי דכי",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אישתבע",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "והדר אישתבע",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "חייל נמי אפחות מכשיעור",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "מכל מין ומין",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אבל בשבועת ביטוי דלא מצי למיחל",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אכללי ופרטי",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כשיעור שלם אין לנו לומר",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דנתכוין אכללי גם לענין צירוף <big><b>רישא</b></big>. קצת",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "תימה כיון דרישא וסיפא איירי",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בנבילה",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "וטריפה מ\"ש דברישא נקט",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אוכלין שאינן ראוין ובסיפא נקט נבילה וטריפה",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<big><b>בכולל</b></big>. אין להקשות",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דלוקי כולה",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "במפרש ורישא",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "בשאינו",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "כולל",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דברים האסורים עם",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דברים המותרים",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דהא משמע דוקא אכל אוכלין",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "שאינן ראוין פטור אבל",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "ראוין חייב <big><b>דמוקי</b></big>. אף על גב דאיכא תנאי",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "דלית להו איסור כולל",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "בהא לא חיישינן כיון דלא",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "מיתנו במתני' ועוד",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "דאין לחוש במאי דאיכא",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "תנאי דלית להו",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "איסור כולל כיון",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "דבהדיא פליג ר\"ש",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "מהאי טעמא",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "דלית ליה איסור",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "כולל וא\"ת ולוקמי במפרש וד\"ה וי\"ל דאי במפרש לא",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "מיתוקמא מתניתין כרבי עקיבא דמשמע הא סתם פטור וא\"ת",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "לימא דהיינו טעמא דלא אמר כר\"ל משום דר' יוחנן סבר",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "880px",
      "right": "50px",
      "left": "",
      "text": "(<a href=\"/yoma/73b\">יומא עג:</a>) חצי שיעור אסור מן התורה ובכל שהוא נמי מושבע ועומד הוא",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "וי\"ל כיון דליכא אלא איסור בעלמא לאו מושבע ועומד חשיב ליה כדפ\"ל אע\"ג דאין איסור",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "לאו חייל על איסור עשה דהא לקמן (<a href=\"/avodah_zarah/25a\">דף כה.</a>) פריך אילימא מתנה לעני מושבע",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "ועומד מהר סיני הוא דכתיב נתן תתן לו ואמר",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "נמי בפרק אלו הן הנשרפין (<a href=\"/sanhedrin/83a\">סנהדרין דף פג.</a>) מנין לכהן טמא שאכל תרומה טמאה שאינו",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "במיתה שנאמר ומתו בו כי יחללוהו פרט לזו שמחוללת ועומדת ומפרש בפרק כל הבשר (<a href=\"/chullin/113b\">חולין דף קיג:</a>)",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "דטעמא משום דאין איסור חל על איסור אע\"ג דבתרומה טמאה אין בה אלא איסור עשה",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "מ\"מ חצי שיעור דליכא אפי' עשה אלא איסור בעלמא לא חשיב מושבע ועומד ועוד דמצי לאוקמי שלא כדרך הנאתן",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "דאין אסור אלא מדרבנן כמו חצי שיעור לר\"ל וזה הפירוש נראה יותר דלפירוש קמא",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "קשיא דמ\"מ הכי המ\"ל דלא אמר כר\"ל כיון דסבר דחצי",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "שיעור אסור מן התורה לא משכחת לה הן ולאו דהיכי מישתבע",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "שאוכל חצי שיעור הא מושבע ועומד מהר",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "סיני הוא",
      "source_ref": "Tosafot on Avodah Zarah 23b:4:1",
      "gemara_segment_ids": [
        2
      ]
    }
  ]
}