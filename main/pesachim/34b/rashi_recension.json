  "segments": [
    {
      "segment_id": 2,
      "original_text": "הוּרְצָה. מַאי נִפְסַל — לָאו בְּהֶיסַּח הַדַּעַת? אִי אָמְרַתְּ בִּשְׁלָמָא פְּסוּלֵי טוּמְאָה הָוֵי, הַיְינוּ דְּמַשְׁכַּחַתְּ לַהּ דִּמְרַצֵּי צִיץ. אֶלָּא אִי אָמְרַתְּ פְּסוּל הַגּוּף הָוֵי,",
