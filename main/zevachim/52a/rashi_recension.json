  "segments": [
    {
      "segment_id": 6,
      "original_text": "מְעַכְּבִי, וּמָר סָבַר לָא מְעַכְּבִי. רַב פָּפָּא אָמַר: דְּכוּלֵּי עָלְמָא – שִׁירַיִם אֵין מְעַכְּבִים; וְהָכָא בְּמִיצּוּי חַטַּאת הָעוֹף מְעַכֵּב קָא מִיפַּלְגִי – מָר",
      "reconstructed_text": "מְעַכְּבִי, וּמָר סָבַר לָא מְעַכְּבִי. רַב פָּפָּא אָמַר: דְּכוּלֵּי עָלְמָא – שִׁירַיִם לא מְעַכְּבִים; וְהָכָא בְּמִיצּוּי חַטַּאת הָעוֹף מְעַכֵּב קָא מִיפַּלְגִי – מָר",
      "reconstructed_html": "מְעַכְּבִי, וּמָר סָבַר לָא מְעַכְּבִי. רַב פָּפָּא אָמַר: דְּכוּלֵּי עָלְמָא – שִׁירַיִם <span class=\"girsa-change girsa-dh\" data-change-type=\"substitution\" data-confidence=\"medium\" data-source=\"rashi_dh\" data-source-ref=\"Rashi on Zevachim 52a:6:2\" data-marker=\"(dibbur hamatchil)\" data-original=\"אֵין\">לא</span> מְעַכְּבִים; וְהָכָא בְּמִיצּוּי חַטַּאת הָעוֹף מְעַכֵּב קָא מִיפַּלְגִי – מָר",
