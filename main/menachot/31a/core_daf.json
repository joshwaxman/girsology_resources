      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Shimon ben Shezuri, fifth-generation Tanna\" data-authority-id=\"2920\" data-full-name=\"Rabbi Shimon ben Shezuri\" data-name-he=\"רבי שמעון שזורי\" data-crossline-group=\"name-ref-crossline-47686\">שִׁמְעוֹן שֵׁזוּרִי</span>: פַּעַם אַחַת נִתְעָרֵב לִי טֶבֶל בְּחוּלִּין,",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וּבָאתִי וְשָׁאַלְתִּי אֶת <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Tarfon, third and fourth-generation Tanna\" data-authority-id=\"1383\" data-full-name=\"Rabbi Tarfon\" data-name-he=\"רבי טרפון\">רַבִּי טַרְפוֹן</span>, וְאָמַר לִי: לֵךְ קַח",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לְךָ מִן הַשּׁוּק וְעַשֵּׂר עָלָיו. <span class=\"sentence\" id=\"4\" type=\"start\">&star;</span>קָסָבַר דְּאוֹרָיְיתָא",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בְּרוּבָּא בָּטֵל, וְרוֹב עַמֵּי הָאָרֶץ מְעַשְּׂרִים הֵן,",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וְהָוֵה לֵיהּ כְּתוֹרֵם מִן הַפְּטוּר עַל הַפְּטוּר. <span class=\"sentence\" id=\"5\" type=\"start\">&star;</span>וְלֵימָא",
      "segment_ids": [
        5
      ]
    },
    {
