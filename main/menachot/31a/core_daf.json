    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Yeimar bar Shelamya, fifth-generation Amora\" data-authority-id=\"1807\" data-full-name=\"Rav Yeimar bar Shelamya\" data-name-he=\"רב יימר בר שלמיא\">רַב יֵימַר בַּר שֶׁלֶמְיָא</span> <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rav Pappa, fifth-generation Amora\" data-authority-id=\"2518\" data-full-name=\"Rav Pappa\" data-name-he=\"רב פפא\">לְרַב פָּפָּא</span>: הָא דְּאָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Ravin bar Ḥinnana, fourth-generation Amora\" data-authority-id=\"149\" data-full-name=\"Ravin bar Ḥinnana\" data-name-he=\"רבין בר חיננא\" data-crossline-group=\"name-ref-crossline-47690\">רָבִין</span>",
