        0
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מִבִּפְנִים, <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Beit Hillel, first and second-generation Tanna\" data-authority-id=\"963\" data-full-name=\"Beit Hillel\" data-name-he=\"בית הלל\">וּבֵית הִלֵּל</span> אוֹמְרִים מִבַּחוּץ, וּמוֹדִים",
      "segment_ids": [
        0
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אֵלּוּ וְאֵלּוּ שֶׁאֵין עוֹבִי הָרַגְלַיִם וְעוֹבִי הַלְּבִזְבְּזִין",
      "segment_ids": [
        0
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "נִמְדָּד. <span class=\"sentence\" id=\"1\" type=\"start\">&star;</span><span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yosei, fifth-generation Tanna\" data-authority-id=\"1657\" data-full-name=\"Rabbi Yosei\" data-name-he=\"רבי יוסי בן חלפתא\">רַבִּי יוֹסֵי</span> אוֹמֵר: מוֹדִים שֶׁעוֹבִי הָרַגְלַיִם",
      "segment_ids": [
        1
      ]
