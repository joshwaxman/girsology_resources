      "text": "<span class=\"sentence\" id=\"6\" type=\"start\">&star;</span>אִיכָּא דְאָמְרִי, אֲמַר לֵיהּ: ״לֵךְ קַח מִן",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הַגּוֹי״, קָסָבַר יֵשׁ קִנְיָן לְגוֹי",
      "segment_ids": [
