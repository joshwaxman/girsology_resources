    }
  ],
  "steinsaltz_sugyot": [
    {
      "id": 155,
      "sentence_id": 3,
      "line_number": 7,
      "label": "א משנה"
    },
    {
      "id": 156,
      "sentence_id": 4,
      "line_number": 11,
      "label": "ב גמרא"
    }
  ],
  "tosafot": [
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "<big><b>הַתְּכֵלֶת אֵינָהּ מְעַכֶּבֶת אֶת הַלָּבָן.</b></big> מצוה לתת ב' חוטין תכלת",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "340px",
      "right": "",
      "left": "",
      "text": "וב' חוטין לבן בציצית ומשמע לכאורה דאין זה מעכב",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "את זה שאם הטיל שני חוטין מן האחד יצא כי (הנך) [צ\"ל הא צאן קדשים] דקתני תפלה",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "של יד אינה מעכבת את של ראש כו' אבל בקונטרס פירש אי עבד",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "ארבעתן תכלת או ארבעתן לבן יצא",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "וכן אנו נוהגין ובגמרא מוכיח כן",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "והלא כל המטיל תכלת בסדינו בירושלים",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "אינו אלא מן המתמיהין ומפרש דאסוריה",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "גזירה משום קלא אילן ופריך לא יהא",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "אלא לבן משמע דאי הוי לבן אין כאן",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "איסורא אף על גב דבלא הני דקלא אילן",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "איכא שני חוטי לבן ומיהו יש לדחות",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "דאע\"ג דבשני חוטי לבן איכא מצוה",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "כי רמי טפי ליכא איסור כלאים דאין",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "זה מוסיף על המצוה דגדיל שנים",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "גדילים ארבעה דדרשינן מיניה שנים",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "לבן ושנים תכלת לאו למעוטי טפי",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "קאתי כדאשכחן גבי ערבי נחל",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "דדרשינן (<a href=\"/sukkah/34b\">סוכה דף לד:</a>) ערבי שתים",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "ונוהגים להשים הרבה בלולב ולקמן",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "גבי טלית שכולה תכלת כו' דאמרינן",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "בטלית בת שמונה חוטין פירש",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "בקונטרס שאין כאן איסור בל תוסיף",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "כיון שכל השמונה בכרך אחד ולא דמי",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "להטיל למוטלת והיינו טעמא דבהטיל",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "למוטלת לבד שייך בל תוסיף משום",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "דציצית אחד על כנף אחד אמר רחמנא",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "ומהתם נמי יש ראיה דכי ליכא אלא",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "לבן או תכלת בעינן לעולם ד' חוטין",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "דמשמע דבטלית בת ד' חוטין לא",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "",
      "text": "חיישינן שמא יסיר ב' מהן ויניח בטלית (אחד) [צ\"ל אחר",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "צאן קדשים] דארבעתן מצוה מיהו בסוף אלו הן הנחנקין (<a href=\"/sanhedrin/88b\">סנהדרין דף פח:</a>)",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "משמע דאם הוסיף חוטין בכרך אחד פסול גבי זקן ממרא דא\"ר",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "אלעזר אינו חייב אלא על דבר שעיקרו מדברי תורה ופירושו מדברי",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "סופרים ויש בו להוסיף ואם הוסיף גורע ואנו אין לנו אלא תפילין",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "",
      "text": "ופריך והאיכא ציצית ומשני אי קשר העליון לאו דאורייתא האי לחודיה",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "קאי והאי לחודיה קאי ואי קשר העליון דאורייתא גרוע ועומד הוא והאי דלא מוקי לה התם בהטיל למוטלת משום דדילמא לא מיפסלא",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "בכך אף על גב דעובר על בל תוסיף אם נתכוין להוסיף ואם לא נתכוין להוסיף שרי ומאן דמפליג לקמן (<a href=\"/menachot/41b\">דף מא:</a>) בין טלית בת ארבעה לטלית",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "בת שמונה ה\"פ בטלית בת ארבעה דהיינו שנים חוטין שהן ארבעה כשהן כפולין שלא היה לו תכלת ונותן אלו שצבועין קלא אילן במקום לבן",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "וטלית בת ח' היינו בת ד' שהן כפולין שיסבור כולם תכלת ויקח מהן לפטור טלית אחרת ומיהו קשה לפי' זה דבת ד' נמי יסבור שהוא",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "תכלת ויוסיף עליהן לבן של פשתן ועוד דההיא ברייתא דמוקי בבת ד' קתני מביא תכלת ודבר אחר ותולה בה וקלא אילן לא יביא ואם",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "הביא כשר אלמא משמע דמיירי בתולה קלא אילן עם התכלת ועל כרחיך ארבעה ושמונה דוקא קאמר בלא כפולות ושמא כל מה שמוסיף",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "חוטין מד' עד ח' לאו מוסיף הוא ולא מיפסיל בכך כדאשכחן אמוראי לקמן (<a href=\"/menachot/42a\">דף מב.</a>) דרב אחא בר יעקב רמי ד' ורב אחא מדפתי",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "רמי ח' והשתא לא פליגי כולי האי אלא דמר עביד הפחות ומר עביד היתר ובסנהדרין מיירי דמוסיף טפי מתמניא וצריך טעם מנלן",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "דבשלמא אי פליגי בהא דמאן דרמי ד' סבר כדדרשינן גדיל שנים גדילים ארבעה ומאן דרמי תמניא סבר דגדילים דקאמר רחמנא",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "אכל מין ומין קאי גדילים מלבן וגדילים מתכלת דהיינו צמר ופשתים דעלייהו קאי אבל אי לא פליגי מה סברא היא זו דאי בעי עביד הכי ואי בעי",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "עביד הכי וצ\"ל דכל זה יש במשמעות גדילים דאי עביד תכלת ולבן בין שניהם ד' חוטין גדילים קרינא ביה ואי עביד מכל חד וחד גדילים",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "כגון ד' חוטין לבן וד' חוטין תכלת גדילים נמי קרינא ביה ולאו מוסיף הוא אבל אי רמי טפי מוסיף הוא וגרוע ועומד הוא ועוד צריך",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "טעם מנלן דכי לית ליה אלא או לבן או תכלת דלא מיפטר בתרי חוטי לחודייהו עד דרמי ד' ושמא משום דדרשינן גדיל שנים גדילים",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "ד' בין יש בו מין אחד בין יש בו שני מינין וקצת קשה הא דאמרי' בגמרא אם הקדים תכלת ללבן יצא אלא שחיסר מצוה מאי חיסר",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "מצוה [אילימא חיסר מצוה] דלבן וקיים מצוה דתכלת לרבי עכובי מעכבי אהדדי דמשמע דאי לא מעכבי ניחא אלמא אף על גב דחיסר",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "מצוה דלבן קיים מצוה דתכלת בב' חוטין ויש לומר דלהכשיר תכלת מיהא מהני לבן דקרינא ביה גדילים ד' וא\"ת ומנלן דבעינן ב'",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "חוטין לבן וב' חוטין דתכלת דילמא אגדילים קפיד קרא אפילו חד מהאי וג' מהאי ויש לומר כיון דתרי מיני בעי רחמנא סברא הוא",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "שיהיו שוין ועוד פתיל תכלת כתיב ופתיל משמע תרי כדדרשינן פרק בא לו (<a href=\"/yoma/72a\">יומא עב.</a>) וקיצץ פתילים פתיל שנים פתילים ד' ולבן נמי",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "לא פחות מתרי דקדיש טפי כדאמרינן בגמרא דמתחיל בלבן ומסיים בלבן דמעלין בקודש ולא מורידין ומיהו טעם זה דפתיל לא יתכן",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "דבפרק בא לו משמע וקיצץ דמקצץ אחד לשנים והכא על כרחין לא משמע תרי כדמוכח בספרי בפרשת [שלח] לך ובפרשת כי תצא",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "ועשו להם ציצית שומע אני חוט אחד בפני עצמו ת\"ל גדילים כמה גדילים נעשין אין [גדיל] פחות משלשה חוטין כדברי בית הילל",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "משמע דמפתיל לא הוה שמעינן אלא חד ועוד דאי פתיל משמע תרי והכנף מין כנף לכל הפחות חד א\"כ בלא גדילים נמי תיפוק ליה",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "תלתא וצריך לומר שחולק על הש\"ס שלנו דמשמע דחד מתכלת מהני ומה שאנו כופלים הד' לח' סמכינן אהא דאמרינן לקמן (<a href=\"/menachot/42a\">דף מב.</a>)",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "רב אחא בר יעקב רמי ד' ועייף להו מיעף ומעייל להו בגלימא ואביק להו כו' עד מר בריה דרבנא עביד כי דידן ופירש בקונטרס",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "דלא אביק להו ועוד תניא בספרי ב\"ש אומרים ד' של צמר וד' של תכלת ואם תאמר היא גופה מנלן שצריך לכופלן ואי הוה מפרשינן עשה",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "גדיל ופותליהו מתוכו היינו שצריך לפותלו כעין פתילה שהיא כפולה ניחא אבל בקונט' לא פירש כן ושם אפרש.",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "<big><b>כתיב הכנף מין הכנף</b></big>. ואפילו לתנא דבי ר''י פ''ק דיבמות (<a href=\"/yevamot/4b\">דף ד:</a>) דפליג ארבא דדריש הכי לא פליג אלא אהא דמרבה שאר",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "850px",
      "right": "",
      "left": "",
      "text": "מינים אבל הכנף מין כנף דריש שפיר: <big><b>ואם הקדים תכלת ללבן יצא.</b></big> תימה כיון דמקרא הוא דדרשינן דלבן ברישא",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "נימא דמעכב דהא לא בעינן שנה הכתוב לעכב אלא בקדשים ויש לומר דלית לן למימר דאסדר לבד יקפיד הכתוב לעכב כמו גבי",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    },
    {
      "width": "930px",
      "right": "",
      "left": "",
      "text": "חליצה (<a href=\"/yevamot/105a\">יבמות דף קה.</a>) הקדים רקיקה לחליצה מה שעשה עשוי ואע''ג דכתיב ככה עיכובא לא קאי אלא אחסרון מעשה:",
      "source_ref": "Tosafot on Menachot 38a:4:1",
      "gemara_segment_ids": [
        2
      ]
    }
  ]
}