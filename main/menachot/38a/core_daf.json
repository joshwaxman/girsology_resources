      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "מותר להכניס לבית הכסא משום כבוד הבריות אבל לשאת משא",
      "source_ref": "Rashi on Menachot 38a:1:1",
