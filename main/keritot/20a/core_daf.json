    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"1\" type=\"start\">&star;</span><span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda bar Rabbi Elai, fifth-generation Tanna\" data-authority-id=\"1395\" data-full-name=\"Rabbi Yehuda bar Rabbi Elai\" data-name-he=\"רבי יהודה ברבי אילעאי\">וְרַבִּי יְהוּדָה</span> מַאי קָאָמַר דִּפְלִיגִי? בְּנִתְכַּוֵּין",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לְלַקֵּט עֲנָבִים וְלִקֵּט תְּאֵנִים, שְׁחוֹרוֹת וְלִקֵּט לְבָנוֹת –",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "עֲנָבִים וּתְאֵנִים, שְׁחוֹרוֹת וּלְבָנוֹת, מַאי",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "נִיהוּ? שְׁנֵי שֵׁמוֹת? הַיְינוּ <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Shimon ben Yoḥai, fifth-generation Tanna\" data-authority-id=\"2830\" data-full-name=\"Rabbi Shimon ben Yoḥai\" data-name-he=\"רבי שמעון בן יוחאי\">רַבִּי שִׁמְעוֹן</span> <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Shimon ben Shezuri, fifth-generation Tanna\" data-authority-id=\"2920\" data-full-name=\"Rabbi Shimon ben Shezuri\" data-name-he=\"רבי שמעון שזורי\">וְרַבִּי שִׁמְעוֹן שֵׁזוּרִי</span>!",
      "segment_ids": [
        1
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda bar Rabbi Elai, fifth-generation Tanna\" data-authority-id=\"1395\" data-full-name=\"Rabbi Yehuda bar Rabbi Elai\" data-name-he=\"רבי יהודה ברבי אילעאי\">רַבִּי יְהוּדָה</span> מַאי אֲתָא לְאַשְׁמוֹעִינַן? <span class=\"sentence\" id=\"2\" type=\"start\">&star;</span>אֶלָּא לָאו",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מִתְעַסֵּק אִיכָּא בֵּינַיְיהוּ, <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda bar Rabbi Elai, fifth-generation Tanna\" data-authority-id=\"1395\" data-full-name=\"Rabbi Yehuda bar Rabbi Elai\" data-name-he=\"רבי יהודה ברבי אילעאי\">דְּרַבִּי יְהוּדָה</span> סָבַר: מִתְעַסֵּק",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "חַיָּיב, <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Shimon ben Shezuri, fifth-generation Tanna\" data-authority-id=\"2920\" data-full-name=\"Rabbi Shimon ben Shezuri\" data-name-he=\"רבי שמעון שזורי\">וְרַבִּי שִׁמְעוֹן שֵׁזוּרִי</span> סָבְרִי: מִתְעַסֵּק פָּטוּר?",
      "segment_ids": [
        2
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"3\" type=\"start\">&star;</span>לָא, מִתְעַסֵּק – דִּבְרֵי הַכֹּל פָּטוּר, וְהָכָא בְּהָא",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "קָא מִיפַּלְגִי, <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Shimon ben Shezuri, fifth-generation Tanna\" data-authority-id=\"2920\" data-full-name=\"Rabbi Shimon ben Shezuri\" data-name-he=\"רבי שמעון שזורי\">דְּרַבִּי שִׁמְעוֹן שֵׁזוּרִי</span> סָבַר: שָׁכַח",
      "segment_ids": [
        3
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מְלַקֵּט מִלִּבּוֹ. בְּשֵׁם אֶחָד – דִּבְרֵי הַכֹּל חַיָּיב, <span class=\"sentence\" id=\"4\" type=\"start\">&star;</span>כִּי פְּלִיגִי –",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בִּשְׁנֵי שֵׁמוֹת. <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yehuda bar Rabbi Elai, fifth-generation Tanna\" data-authority-id=\"1395\" data-full-name=\"Rabbi Yehuda bar Rabbi Elai\" data-name-he=\"רבי יהודה ברבי אילעאי\">רַבִּי יְהוּדָה</span> סָבַר: לָא שְׁנָא",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בְּשֵׁם אֶחָד וְלָא שְׁנָא בִּשְׁנֵי שֵׁמוֹת – פְּלִיגִי.",
      "segment_ids": [
        4
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sentence\" id=\"5\" type=\"start\">&star;</span><span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabba I, fourth-generation Amora\" data-authority-id=\"2582\" data-full-name=\"Rabba I\" data-name-he=\"רבא\">רָבָא</span> אָמַר: לִיקְדֹּם אִיכָּא בֵינַיְיהוּ. <span class=\"sentence\" id=\"6\" type=\"start\">&star;</span>וְהָתַנְיָא:",
      "segment_ids": [
        5,
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הָיוּ לְפָנָיו שְׁתֵּי נֵרוֹת דּוֹלְקוֹת אֲרוּכּוֹת,",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וְנִתְכַּוֵּין לְכַבּוֹת אֶת זוֹ וְכִיבָּה אֶת זוֹ, לְהַדְלִיק",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "אֶת זוֹ וְהִדְלִיק אֶת זוֹ – פָּטוּר. לְהַדְלִיק וּלְכַבּוֹת,",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "וְכִיבָּה וְהִדְלִיק בִּנְשִׁימָה אַחַת –",
      "segment_ids": [
        6
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "חַיָּיב. <span class=\"sentence\" id=\"7\" type=\"start\">&star;</span>פְּשִׁיטָא! מַהוּ דְּתֵימָא: לָא אִיתְעֲבִד",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מַחְשַׁבְתֵּיהּ, דְּהָא לְהַדְלִיק מֵעִיקָּרָא בָּעֵי וּלְבַסּוֹף",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "לְכַבּוֹת, וְכִי עֲבַד מַעֲשֶׂה – כִּיבָּה וּבַסּוֹף הִדְלִיק",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "הוּא, וְאֵימָא פָּטוּר, קָא מַשְׁמַע לַן: נְהִי דְּאַקְדּוֹמֵי",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "נָמֵי לָא מַקְדֵּים, אַחוֹרֵי נָמֵי לָא מְאַחַר.",
      "segment_ids": [
        7
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"sugya-marker sugya-marker-steinsaltz\" data-sugya-kind=\"steinsaltz\" data-sugya-id=\"116\" data-sentence-id=\"8\" data-steinsaltz-label=\"א\">§</span> <span class=\"sentence\" id=\"8\" type=\"start\">&star;</span>תָּנוּ רַבָּנַן: הַחוֹתֶה גֶּחָלִים בַּשַּׁבָּת – חַיָּיב חַטָּאת.",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Yishmael ben Elazar, sixth-generation Tanna\" data-authority-id=\"2846\" data-full-name=\"Rabbi Yishmael ben Elazar\" data-name-he=\"רבי שמעון בן אלעזר\">רַבִּי שִׁמְעוֹן בֶּן אֶלְעָזָר</span> אוֹמֵר מִשּׁוּם <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Elazar bar Tzadok I, third-generation Tanna\" data-authority-id=\"475\" data-full-name=\"Rabbi Elazar bar Tzadok I\" data-name-he=\"רבי אלעזר ברבי צדוק\" data-crossline-group=\"name-ref-crossline-37240\">רַבִּי</span>",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "<span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Elazar bar Tzadok I, third-generation Tanna\" data-authority-id=\"475\" data-full-name=\"Rabbi Elazar bar Tzadok I\" data-name-he=\"רבי אלעזר ברבי צדוק\" data-crossline-group=\"name-ref-crossline-37240\">אֱלִיעֶזֶר בְּרַבִּי צָדוֹק</span>: חַיָּיב שְׁתַּיִם, מִפְּנֵי שֶׁהוּא",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מְכַבֶּה אֶת הָעֶלְיוֹנוֹת, וּמַבְעִיר אֶת הַתַּחְתּוֹנוֹת.",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "בְּמַאי עָסְקִינַן? אִי דְּקָא מִיכַּוֵּין לְכַבּוֹת וּלְהַבְעִיר –",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מַאי טַעְמָא דְּמַאן דְּפָטַר? אֶלָּא דְּלָא קָא",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "מִכַּוֵּין לְהַבְעִיר – מַאי טַעְמָא דְּמַאן דִּמְחַיֵּיב",
      "segment_ids": [
        8
      ]
    },
    {
      "right": "275px",
      "width": "380px",
      "text": "תַּרְתֵּי? <span class=\"sentence\" id=\"9\" type=\"start\">&star;</span><span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabbi Elazar ben Pedat, second-generation Amora\" data-authority-id=\"467\" data-full-name=\"Rabbi Elazar ben Pedat\" data-name-he=\"רַבִּי אֶלְעָזָר בֶּן פְּדָת\">רַבִּי אֶלְעָזָר</span> <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabbi Ḥanina bar Ḥama II, first-generation I Amora\" data-authority-id=\"1212\" data-full-name=\"Rabbi Ḥanina bar Ḥama II\" data-name-he=\"רבי חנינא בר חמא\">וְרַבִּי חֲנִינָא</span> דְּאָמְרִי תַּרְוַויְיהוּ:",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "כְּגוֹן שֶׁנִּתְכַּוֵּין לְכַבּוֹת הָעֶלְיוֹנוֹת כְּדֵי לְהַבְעִיר אֶת הַתַּחְתּוֹנוֹת, דְּתַנָּא קַמָּא",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "קָסָבַר: מְקַלְקֵל בְּהַבְעָרָה פָּטוּר, <span class=\"name-reference-marker name-reference-tanna\" data-sage-type=\"tanna\" title=\"Rabbi Elazar bar Tzadok I, third-generation Tanna\" data-authority-id=\"475\" data-full-name=\"Rabbi Elazar bar Tzadok I\" data-name-he=\"רבי אלעזר ברבי צדוק\">וְרַבִּי אֱלִיעֶזֶר בְּרַבִּי צָדוֹק</span> אָמַר: חַיָּיב.",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "וְכֵן אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabbi Yoḥanan II, second-generation Amora\" data-authority-id=\"1570\" data-full-name=\"Rabbi Yoḥanan II\" data-name-he=\"רבי יוחנן\">רַבִּי יוֹחָנָן</span>: בְּנַפָּח שָׁנוּ. אָמַר <span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Rabbi Yoḥanan II, second-generation Amora\" data-authority-id=\"1570\" data-full-name=\"Rabbi Yoḥanan II\" data-name-he=\"רבי יוחנן\">רַבִּי יוֹחָנָן</span>: עַד כָּאן לֹא נִתְגַּלְּתָה",
      "segment_ids": [
        9
      ]
    },
    {
      "right": "275px",
      "width": "655px",
      "text": "טַעְמָהּ שֶׁל הֲלָכָה זוֹ. <span class=\"sentence\" id=\"10\" type=\"start\">&star;</span><span class=\"name-reference-marker name-reference-amora\" data-sage-type=\"amora\" title=\"Abaye bar Avin, fourth-generation Amora\" data-authority-id=\"124\" data-full-name=\"Abaye bar Avin\" data-name-he=\"אביי בר אבין\">אַמֵּי בַּר אָבִין</span> <span class=\"name-reference-marker name-reference-unknown\" data-sage-type=\"unknown\" title=\"Rav Ḥananya bar Avin\" data-authority-id=\"21038\" data-full-name=\"Rav Ḥananya bar Avin\" data-name-he=\"רב חנניא בר אבין\">וְרַב חֲנַנְיָא בַּר אָבִין</span> דְּאָמְרִי תַּרְוַויְיהוּ:",
      "segment_ids": [
        10
      ]
    }
  ],
  "rashi": [
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "<b>מַאי נִיהוּ? <span class=\"dh-divergent\">ב&#x27;</span> שֵׁמוֹת.</b> קא סלקא דעתך השתא שחורות ולבנות נמי כשני",
      "source_ref": "Rashi on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "מינין דמו ואי ר' שמעון ור' שמעון שזורי נמי כרבי יהודה מוקמי",
      "source_ref": "Rashi on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "פלוגתייהו בנתכוין ללקט את זה ולקט את זה רבי יהודה מאי אתא",
      "source_ref": "Rashi on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "0px",
      "left": "",
      "text": "לאשמועינן: <b>אֶלָּא לָאו מִתְעַסֵּק אִיכָּא בֵּינַיְיהוּ.</b> דשמעיה רבי יהודה",
      "source_ref": "Rashi on Keritot 20a:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לרבי שמעון שזורי דאוקי פלוגתא",
      "source_ref": "Rashi on Keritot 20a:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "באבד מלקט מלבו אבל במתעסק",
      "source_ref": "Rashi on Keritot 20a:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דברי הכל פטור ואתא איהו למימר",
      "source_ref": "Rashi on Keritot 20a:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אפילו נתכוין ללקט כו' הוי מתעסק",
      "source_ref": "Rashi on Keritot 20a:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הואיל ובאיסור נתעסק פליגי ומחייב",
      "source_ref": "Rashi on Keritot 20a:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "רבי אליעזר ואפילו רבי יהושע לא פטר",
      "source_ref": "Rashi on Keritot 20a:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אלא בשני שמות אבל בשם אחד חייב",
      "source_ref": "Rashi on Keritot 20a:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ותמה אני כו' אם כן למה נאמר בה",
      "source_ref": "Rashi on Keritot 20a:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "פרט למתעסק בהיתר או במתעסק",
      "source_ref": "Rashi on Keritot 20a:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "באב מלאכה ועשה אב מלאכה",
      "source_ref": "Rashi on Keritot 20a:3:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אחרת: <b><span class=\"dh-divergent\">אבד</span> <span class=\"dh-divergent\">מלקט</span> <span class=\"dh-divergent\">מלבו</span> <span class=\"dh-divergent\">בשם</span> אֶחָד.</b>",
      "source_ref": "Rashi on Keritot 20a:4:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שנתכוין לתאנה זו ושכח כסבור תאנה",
      "source_ref": "Rashi on Keritot 20a:4:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אחרת הסמוכה לה בעינא והלכה ידו",
      "source_ref": "Rashi on Keritot 20a:4:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "על הראשונה דברי הכל חייב הואיל",
      "source_ref": "Rashi on Keritot 20a:4:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ולכך נתכוין תחלה ועוד כששכח מחשבתו",
      "source_ref": "Rashi on Keritot 20a:4:1",
      "gemara_segment_ids": [
        1
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לא חשב אלא באותו מין עצמו: <b>בִּשְׁנֵי</b>",
      "source_ref": "Rashi on Keritot 20a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>שֵׁמוֹת.</b> שנתכוין לתאנים ושכח וכסבור",
      "source_ref": "Rashi on Keritot 20a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ענבים בעינא והלכה ידו על התאנים:",
      "source_ref": "Rashi on Keritot 20a:5:1",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b><span class=\"dh-divergent\">ורבי</span> יְהוּדָה סָבַר.</b> אפילו בשם אחד",
      "source_ref": "Rashi on Keritot 20a:5:2",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "פליגי וסבירא ליה דשחורות ולבנות",
      "source_ref": "Rashi on Keritot 20a:5:2",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שם אחד הן הואיל והן מין אחד:",
      "source_ref": "Rashi on Keritot 20a:5:2",
      "gemara_segment_ids": [
        3
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<br>(תוספות) מה שאמר במתניתין"
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "תמיה אני אם פטר בה ר' יהושע"
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "במין אחד שהרי נתקיימה מחשבתו."
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "עד כאן תוספות: <b>לִיקְדֹּם אִיכָּא בֵינַיְיהוּ.</b>",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שנתכוין ללקט זו תחלה ואחר כך זו",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "והלכה ידו על האחרונה ר' שמעון",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ורבי שמעון שזורי סברי אם משם אחד",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דברי הכל חייב הואיל ושם אחד הן",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "וסוף סוף תרווייהו עבד ולא איכפת",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לן במקדים המאוחר כי פליגי בשני",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "שמות ר' אליעזר מחייב חטאת הואיל",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ולשניהן נתכוין ושניהם עשה ולא איכפת",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לן במקדים המאוחר ורבי יהושע פוטר",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הואיל ובשעת לקיטת כל אחת ואחת",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לא לזה הוא מכוין הוה ליה כמתעסק",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "ופטור ורבי יהודה סבר אפילו בשם",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "אחד פליגי אבל תמהני למה פטר",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "הואיל וסוף סוף לשניהן נתכוין אבל",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "במתעסק בעלמא שלא נתכוין אלא",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "לאחת ולא עשאה ועשה את חברתה",
      "source_ref": "Rashi on Keritot 20a:6:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דכולי עלמא פטור: <b><span class=\"dh-divergent\">והא</span> <span class=\"dh-divergent\">תניא</span></b> סייעתא",
      "source_ref": "Rashi on Keritot 20a:7:1",
      "gemara_segment_ids": [
        4
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "דחיישינן למוקדם ומאוחר: <b>לְהַדְלִיק</b>",
      "source_ref": "Rashi on Keritot 20a:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>זוֹ</b> בשגגת שבת או בשגגת מלאכות:",
      "source_ref": "Rashi on Keritot 20a:7:2",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "<b>וְהִדְלִיק זוֹ פָּטוּר.</b> דהיינו מתעסק לא",
      "source_ref": "Rashi on Keritot 20a:7:3",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "נתכוין אלא לאחת ולא עשאה ועשה את",
      "source_ref": "Rashi on Keritot 20a:7:3",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "250px",
      "right": "0px",
      "left": "",
      "text": "חברתה: <b>לְהַדְלִיק וּלְכַבּוֹת</b> כשהיה",
      "source_ref": "Rashi on Keritot 20a:7:4",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "נר דולק ונר כבוי ונתכוין להדליק זה תחלה ואחר כך לכבות זה וכבה זה ואחר כך הדליק זה: <b><span class=\"dh-divergent\">אם</span> בִּנְשִׁימָה אַחַת</b> שנפח ומחמת",
      "source_ref": "Rashi on Keritot 20a:7:5",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "הנפיחה כבה זה והדליקה חייב דליכא למימר הי מוקדם והי מאוחר: <b><span class=\"dh-divergent\">בשתי</span> <span class=\"dh-divergent\">נשימות</span> פָּטוּר</b> דלא נעשית כסדר: <b>לא</b> <b>אתעביד</b> <b>מחשבתיה.</b>",
      "source_ref": "Rashi on Keritot 20a:8:1",
      "gemara_segment_ids": [
        5
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "דאיכא למימר כבה ואחר כך הדליק: <b>הַחוֹתֶה</b> הממלא כלים מצבור הגחלים: <b>מכבה</b> <b>העליונות.</b> שעכשיו נעשות תחתונות וכבו מחמת",
      "source_ref": "Rashi on Keritot 20a:9:1",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "המשא של עליונות ומבעיר התחתונות שהיו כבויות מחמת המשא שהיה עליהן וכשהן עכשיו עליונות נתבערות: <b>מַאי טַעְמָא דְּמַאן</b>",
      "source_ref": "Rashi on Keritot 20a:9:3",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "<b>דִּמְחַיֵּיב תַּרְתֵּי.</b> הא לא איכוין לחדא ולגביה מתעסק הוא: <b>כדי</b> <b>להבעיר</b> <b>את</b> <b>התחתונות.</b> כלומר להבערת התחתונות לא הוה צריך אלא",
      "source_ref": "Rashi on Keritot 20a:9:3",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "לכבוי עליונות היתה עיקר כוונתו שהיה נפח וצריך לפחמין נתכוין לכבות עליונות שהיו גסות ואף על פי שידע שיבערו התחתונות נתכוין",
      "source_ref": "Rashi on Keritot 20a:9:3",
      "gemara_segment_ids": [
        7
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "לכיבוי של אלו על מנת שיתבערו אלו אף על פי שהוא מקלקלם אצלו: <b>מְקַלְקֵל בְּהַבְעָרָה</b> כגון דנפח הוא כדאמר רבי יוחנן בנפח שנו",
      "source_ref": "Rashi on Keritot 20a:10:2",
      "gemara_segment_ids": [
        8
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "דלא ניחא ליה לנפח להבעיר גחלים: <b>מְקַלְקֵל בְּהַבְעָרָה <span class=\"dh-divergent\">חייב</span></b> דקיי\"ל אף על גב דשאר מקלקלים פטורין חובל ומבעיר חייבין: <b>אמי</b> <b>בר</b> <b>אבין</b>",
      "source_ref": "Rashi on Keritot 20a:10:3",
      "gemara_segment_ids": [
        8
      ]
    },
    {
      "width": "930px",
      "right": "0px",
      "left": "",
      "text": "<b><span class=\"dh-divergent\">כו&#x27;</span> כְּגוֹן שֶׁנִּתְכַּוֵּין.</b> לכבויי ולהבערה ואפילו הכי אהבערה פטור תנא קמא סבר לה כר' יוסי דאמר הבערה ללאו יצאת וליכא קרבן:",
      "source_ref": "Rashi on Keritot 20a:10:3",
      "gemara_segment_ids": [
        8
      ]
    }
  ],
  "vilna_piskaot": [],
  "steinsaltz_sugyot": [
    {
      "id": 116,
      "sentence_id": 8,
      "line_number": 28,
      "label": "א"
    }
  ],
  "tosafot": [
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "<big><b>הַיְינוּ <span class=\"dh-divergent\">ר&#x27;</span> שִׁמְעוֹן <span class=\"dh-divergent\">ור&#x27;</span> שִׁמְעוֹן שֵׁזוּרִי.</b></big> דעל כרחיך צריך לומר דהכי",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "360px",
      "right": "",
      "left": "0px",
      "text": "פירושו דמילתיה -לא נחלקו על דבר שהוא משם אחד שחייב",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "כגון תאנים ותאנים ובאבד מלקט מלבו , או לבנות ולבנות ושחורות",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "450px",
      "right": "",
      "left": "0px",
      "text": "ושחורות ואבד מלקט מלבו, כדפי' לעיל על מה נחלקו? על דבר שהוא",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "משני שמות כגון ענבים ותאנים",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "או שחורות ולבנות, ואבד מלקט מלבו,",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "כדמפרש לעיל טעמייהו דלא מצינו",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "למימר לר' שמעון ור' שמעון שזורי",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "-על מה נחלקו על דבר משום שני",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שמות כגון שלקט תאנים או ענבים",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ואינו יודע מה לקט דמאי קמשמע לן,היינו דרבי יוסי?",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "<big><b>אלא לאו מתעסק איכא בינייהו",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "180px",
      "right": "",
      "left": "0px",
      "text": "דרבי יהודה סבר דמתעסק",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "חייב ור' שמעון שזורי ורבי שמעון",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "סברי מתעסק פטור</b></big>. דרבי שמעון",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "סבר דפלוגתיה דרבי יהושע ורבי",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אליעזר באבד מלקט מלבו ונתכוין ללקט",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "תאנים ולקט ענבים, או שחורות ולקט",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לבנות, דשני מינין הן, כדמפרש לעיל",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "טעמייהו אבל במין אחד ובאבד מלקט",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מלבו לא נחלקו- דלכולי עלמא חייב אבל",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "במין אחד דשלא אבד מלקט מלבו",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "-כגון שנתכוין ללקט אלו ולקט אחרות,",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "פטור משום מתעסק. ורבי יהודה אמר",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אפילו נתכוין , דבשני מינים",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "פלוגתייהו, ובשלא אבד מלקט מלבו.",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ומינה דייקינן דוקא בשני מינין, אבל",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "בחד מינא לכולי עלמא חייב, כדדייק",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לעיל הש\"ס ואמאי, הא מתעסק הוא,",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "והדרן קושיין לדוכתיה? והא דפשיטא",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ליה להש\"ס האי שיטה -דלרבי שמעון",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מתעסק פטור, ומוקי פלוגתייהו באבד",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "מלקט מלבו, ולרבי יהודה מתעסק חייב,",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ומיירי ב'שלא אבד , ' דהכי משמע לישנא",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דמתניתין דר' יהודה מחייב טפי",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דקאמר 'ר\"ש שזורי ור' שמעון אומרים",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "לא נחלקו על דבר שהוא משום אחד",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "שחייב' -כלומר דהתם ודאי חייב; 'על מה",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "נחלקו? על שני שמות , ' כלומר דהתם",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "איכא מאן דפטר ועל זה השיב ר' יהודה",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "'אפילו נתכוין ללקט תאנים , פליגי,",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "ואיכא מאן דמחייב. ועוד, מדקאמר 'תמה",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "אני אם פטר בה רבי יהושע' '!משמע",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    },
    {
      "width": "250px",
      "right": "",
      "left": "0px",
      "text": "דר' יהודה מחייב טפי.",
      "source_ref": "Tosafot on Keritot 20a:2:1",
      "gemara_segment_ids": [
        0
      ]
    }
  ]
}